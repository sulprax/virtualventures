/* =========================================================
   HOME PAGE
   Poster-style landing page using the shared site header
   ========================================================= */

.hero {
  position: relative;
  overflow: hidden;

  min-height: 100vh;
  min-height: 100svh;

  display: grid;
  align-items: center;

  padding:
    calc(var(--site-header-height, 76px) + clamp(1.6rem, 4vw, 3rem))
    clamp(1rem, 5vw, 5rem)
    clamp(7rem, 10vw, 8.5rem);

  color: #fff7ed;
  background: #1d130d;
}

.hero .cover-slideshow {
  z-index: 0;
}

.hero::before {
  content: "";

  position: absolute;
  inset: 0;
  z-index: 1;

  pointer-events: none;

  background:
    radial-gradient(
      circle at 72% 42%,
      transparent 0 28%,
      rgba(16, 10, 6, 0.18) 58%,
      rgba(16, 10, 6, 0.66) 100%
    ),
    linear-gradient(
      to right,
      rgba(18, 11, 7, 0.78),
      rgba(18, 11, 7, 0.44) 38%,
      rgba(18, 11, 7, 0.14) 68%,
      rgba(18, 11, 7, 0.44)
    );
}

.hero-top-fade,
.hero-bottom-fade {
  position: absolute;
  right: 0;
  left: 0;
  z-index: 2;

  pointer-events: none;
}

.hero-top-fade {
  top: 0;
  height: clamp(6rem, 12vw, 9rem);

  background: linear-gradient(
    to bottom,
    rgba(28, 17, 10, 0.9),
    rgba(28, 17, 10, 0.4) 58%,
    transparent
  );
}

.hero-bottom-fade {
  bottom: 0;
  height: clamp(9rem, 18vw, 14rem);

  background: linear-gradient(
    to top,
    rgba(15, 10, 7, 0.95),
    rgba(15, 10, 7, 0.5) 48%,
    transparent
  );
}

/* =========================================================
   HERO CONTENT
   ========================================================= */

.hero-content {
  position: relative;
  z-index: 5;

  width: min(100%, 1180px);
  margin-inline: auto;

  display: grid;
  grid-template-columns: minmax(18rem, 28rem) minmax(0, 1fr);
  align-items: center;
}

.hero-panel {
  position: relative;

  width: min(100%, 27rem);
  padding: clamp(1.15rem, 3vw, 1.65rem);

  color: var(--dark);
  background:
    radial-gradient(
      circle at 50% 0%,
      rgba(255, 250, 245, 0.92),
      rgba(255, 250, 245, 0.68) 36%,
      rgba(245, 239, 230, 0.46) 76%
    ),
    linear-gradient(
      145deg,
      rgba(255, 250, 245, 0.76),
      rgba(245, 239, 230, 0.48)
    );

  border: 1px solid rgba(255, 246, 229, 0.58);
  border-radius: 28px;

  box-shadow:
    0 34px 80px rgba(0, 0, 0, 0.42),
    inset 0 1px 0 rgba(255, 255, 255, 0.52);

  backdrop-filter: blur(14px) saturate(1.05);
  -webkit-backdrop-filter: blur(14px) saturate(1.05);
}

.hero-panel::before {
  content: "";

  position: absolute;
  inset: 0;
  z-index: -1;

  border-radius: inherit;

  pointer-events: none;

  background:
    radial-gradient(
      ellipse at 10% 18%,
      rgba(239, 189, 114, 0.18),
      transparent 36%
    ),
    radial-gradient(
      ellipse at 88% 78%,
      rgba(122, 82, 48, 0.12),
      transparent 34%
    );
}

.hero-logo-wrap {
  width: min(13.5rem, 76%);
  margin: 0 auto 0.35rem;

  display: grid;
  place-items: center;

  opacity: 0.9;
  filter: drop-shadow(0 12px 20px rgba(45, 34, 24, 0.2));
}

.hero-logo {
  display: block;
  width: 100%;
  height: auto;
}

.hero-kicker {
  max-width: 17rem;
  margin: 0 auto 0.55rem;

  color: var(--coffee);

  font-family: var(--font-script);
  font-size: clamp(1.1rem, 2vw, 1.35rem);
  font-weight: 800;
  line-height: 1.08;
  text-align: center;
}

.hero-panel h1 {
  margin: 0;

  color: var(--dark);

  font-family: var(--font-title);
  font-size: clamp(2.75rem, 6vw, 4.75rem);
  font-weight: 500;
  line-height: 0.86;
  letter-spacing: -0.055em;
  text-align: center;
}

.hero-intro {
  margin: clamp(0.85rem, 2vw, 1.1rem) auto 0;
  max-width: 22rem;

  color: rgba(45, 34, 24, 0.88);

  font-family: var(--font-body);
  font-size: clamp(0.95rem, 1.2vw, 1.05rem);
  line-height: 1.58;
  text-align: center;
}

/* Hide slideshow captions on the homepage so the hero stays clean */
.hero .cover-slideshow__caption {
  display: none;
}

/* =========================================================
   HERO BUTTONS
   ========================================================= */

.hero-buttons {
  position: absolute;
  left: 50%;
  bottom: clamp(1.4rem, 4vw, 2.6rem);
  z-index: 6;

  width: min(100% - 2rem, 42rem);

  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: clamp(0.65rem, 2vw, 1.15rem);

  transform: translateX(-50%);
}

.hero-buttons a {
  min-height: 4.2rem;
  padding: 0.72rem 0.85rem;

  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 0.55rem;

  color: #fff6e9;
  background:
    radial-gradient(
      circle at 30% 10%,
      rgba(255, 239, 205, 0.18),
      transparent 44%
    ),
    linear-gradient(145deg, rgba(126, 78, 39, 0.9), rgba(54, 35, 23, 0.92));

  border: 1px solid rgba(216, 164, 93, 0.78);
  border-radius: 16px;

  text-decoration: none;

  font-family: "Bungee", var(--font-ancient), system-ui, sans-serif;
  font-size: clamp(0.82rem, 1.2vw, 0.98rem);
  font-weight: 900;
  letter-spacing: 0.015em;

  box-shadow:
    0 16px 34px rgba(0, 0, 0, 0.34),
    inset 0 1px 0 rgba(255, 246, 229, 0.2);

  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);

  transition:
    transform 180ms ease,
    background 180ms ease,
    color 180ms ease,
    border-color 180ms ease,
    box-shadow 180ms ease;
}

.hero-buttons a:hover,
.hero-buttons a:focus-visible {
  color: #1d1208;
  background:
    radial-gradient(
      circle at 30% 10%,
      rgba(255, 239, 205, 0.36),
      transparent 44%
    ),
    linear-gradient(145deg, #efbd72, #f6e3bd);

  border-color: rgba(255, 250, 245, 0.66);

  transform: translateY(-3px);

  box-shadow:
    0 22px 44px rgba(0, 0, 0, 0.42),
    inset 0 1px 0 rgba(255, 255, 255, 0.42);
}

.button-icon {
  width: 1.45rem;
  height: 1.45rem;

  display: inline-flex;
  align-items: center;
  justify-content: center;

  flex: 0 0 auto;
}

.button-icon svg {
  width: 100%;
  height: 100%;

  fill: none;
  stroke: currentColor;
  stroke-width: 1.8;
  stroke-linecap: round;
  stroke-linejoin: round;
}

/* =========================================================
   MOBILE POSTER LAYOUT
   ========================================================= */

@media (max-width: 760px) {
  .hero {
    min-height: 100svh;

    align-items: stretch;

    padding:
      calc(var(--site-header-height, 70px) + 0.9rem)
      0.9rem
      6.3rem;
  }

  .hero::before {
    background:
      linear-gradient(
        to bottom,
        rgba(18, 11, 7, 0.08),
        rgba(18, 11, 7, 0.12) 36%,
        rgba(18, 11, 7, 0.62) 84%,
        rgba(18, 11, 7, 0.88)
      ),
      radial-gradient(
        circle at 52% 36%,
        transparent 0 32%,
        rgba(16, 10, 6, 0.22) 68%,
        rgba(16, 10, 6, 0.58) 100%
      );
  }

  .hero-top-fade {
    height: 6.5rem;
  }

  .hero-bottom-fade {
    height: 9rem;
  }

  .hero-content {
    width: 100%;

    display: grid;
    grid-template-columns: 1fr;
    align-items: start;
  }

  .hero-panel {
    width: min(100%, 22rem);
    margin: 0 auto;
    padding: 0.85rem 0.95rem 1rem;

    background:
      linear-gradient(
        145deg,
        rgba(255, 250, 245, 0.18),
        rgba(245, 239, 230, 0.08)
      );

    border-color: rgba(255, 246, 229, 0.28);
    border-radius: 24px;

    box-shadow:
      0 16px 42px rgba(0, 0, 0, 0.22),
      inset 0 1px 0 rgba(255, 255, 255, 0.18);

    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
  }

  .hero-logo-wrap {
    width: min(9.5rem, 58%);
    margin-bottom: 0.15rem;

    opacity: 0.72;
    filter:
      drop-shadow(0 8px 18px rgba(0, 0, 0, 0.25))
      drop-shadow(0 0 16px rgba(239, 189, 114, 0.18));
  }

  .hero-kicker {
    max-width: 15rem;
    margin-bottom: 0.45rem;

    color: rgba(255, 250, 245, 0.92);

    font-size: 1.08rem;
    text-shadow:
      0 2px 8px rgba(0, 0, 0, 0.55),
      0 0 14px rgba(239, 189, 114, 0.18);
  }

  .hero-panel h1 {
    color: #fff7ed;

    font-size: clamp(2.15rem, 12vw, 3.15rem);
    text-shadow:
      0 2px 10px rgba(0, 0, 0, 0.58),
      0 0 18px rgba(239, 189, 114, 0.16);
  }

  .hero-intro {
    display: none;
  }

  .hero-buttons {
    bottom: 1rem;
    width: calc(100% - 1.15rem);
    gap: 0.5rem;
  }

  .hero-buttons a {
    min-height: 4rem;
    padding: 0.52rem 0.35rem;

    flex-direction: column;
    gap: 0.25rem;

    border-radius: 14px;

    font-size: clamp(0.68rem, 3vw, 0.82rem);
  }

  .button-icon {
    width: 1.45rem;
    height: 1.45rem;
  }
}

@media (max-width: 390px) {
  .hero {
    padding-inline: 0.65rem;
  }

  .hero-panel {
    width: min(100%, 20rem);
  }

  .hero-buttons {
    width: calc(100% - 0.8rem);
  }

  .hero-buttons a {
    min-height: 3.75rem;
  }
}

/* =========================================================
   REDUCED MOTION
   ========================================================= */

@media (prefers-reduced-motion: reduce) {
  .hero-buttons a {
    transition: none;
  }
}

/* =========================================================
   HOME DESKTOP FINAL SCREEN FIT
   Keeps the desktop homepage poster inside one screen
   ========================================================= */

@media (min-width: 761px) {
  .hero {
    min-height: 100vh;
    min-height: 100svh;

    padding:
      calc(var(--site-header-height, 76px) + 0.85rem)
      clamp(2rem, 6vw, 7.5rem)
      clamp(5.8rem, 8vh, 7.1rem);

    align-items: center;
  }

  .hero-content {
    width: min(100%, 1240px);

    grid-template-columns: minmax(20rem, 31rem) minmax(0, 1fr);
    align-items: center;
  }

  .hero-panel {
    width: min(30vw, 29rem);
    min-width: 23rem;
    max-height: calc(100svh - var(--site-header-height, 76px) - 8.5rem);

    padding: clamp(1.1rem, 2.2vh, 1.55rem) clamp(1.25rem, 2.2vw, 1.75rem);

    overflow: hidden;

    border-radius: 28px;
  }

  .hero-logo-wrap {
    width: min(14.5rem, 72%);
    margin-bottom: clamp(0.15rem, 1vh, 0.45rem);
  }

  .hero-panel h1 {
    font-size: clamp(3.05rem, 4.55vw, 4.85rem);
    line-height: 0.86;
  }

  .hero-kicker {
    margin-top: 0.3rem;
    margin-bottom: 0.65rem;

    font-size: clamp(1.02rem, 1.25vw, 1.25rem);
  }

  .hero-intro {
    max-width: 22rem;
    margin-top: clamp(0.75rem, 1.8vh, 1.05rem);

    font-size: clamp(0.9rem, 1vw, 1.02rem);
    line-height: 1.55;
    text-align: left;
  }

  .hero-buttons {
    bottom: clamp(1.25rem, 2.4vh, 2rem);

    width: min(42rem, 48vw);
    min-width: 34rem;

    gap: clamp(0.7rem, 1.1vw, 1rem);
  }

  .hero-buttons a {
    min-height: clamp(3.55rem, 6vh, 4.2rem);
    padding: 0.65rem 0.9rem;

    font-size: clamp(0.78rem, 0.92vw, 0.94rem);
  }

  .button-icon {
    width: 1.25rem;
    height: 1.25rem;
  }

  /* Show home slideshow caption bottom-right, readable, not huge */
  .hero .cover-slideshow__caption {
    display: block !important;

    right: clamp(2.2rem, 5vw, 5.5rem);
    bottom: clamp(5.7rem, 9vh, 7.2rem);

    width: min(34rem, 38vw);

    color: #fffaf2;
    text-align: right;

    opacity: 1;
    transform: none;

    text-shadow:
      0 2px 8px rgba(0, 0, 0, 0.8),
      0 10px 28px rgba(0, 0, 0, 0.56);
  }

  .hero .cover-slideshow__caption::before {
    inset: -1.35rem -1.65rem -1.25rem -1.65rem;

    background:
      radial-gradient(
        ellipse at center,
        rgba(20, 12, 8, 0.66),
        rgba(20, 12, 8, 0.36) 48%,
        transparent 78%
      );

    filter: blur(1px);
  }

  .hero .cover-slideshow__eyebrow {
    margin-bottom: 0.35rem;

    color: #eec17d;

    font-family: "Bungee", var(--font-ancient), system-ui, sans-serif;
    font-size: clamp(0.62rem, 0.7vw, 0.78rem);
    letter-spacing: 0.12em;
  }

  .hero .cover-slideshow__caption h2 {
    max-width: 30rem;
    margin-left: auto;

    font-family: "Bungee", var(--font-ancient), system-ui, sans-serif;
    font-size: clamp(1.25rem, 2vw, 2rem);
    line-height: 1.12;
    letter-spacing: 0.01em;
  }

  .hero .cover-slideshow__description {
    max-width: 29rem;
    margin-top: 0.65rem;
    margin-left: auto;

    color: rgba(255, 250, 245, 0.9);

    font-size: clamp(0.82rem, 0.96vw, 1rem);
    font-weight: 750;
    line-height: 1.45;
  }

  .hero .cover-slideshow__link {
    margin-top: 0.75rem;

    color: #d7efb7;

    font-family: var(--font-body);
    font-size: clamp(0.78rem, 0.9vw, 0.92rem);
    font-weight: 900;
  }
}

/* Slightly shorter desktop screens */
@media (min-width: 761px) and (max-height: 760px) {
  .hero {
    padding-top: calc(var(--site-header-height, 76px) + 0.45rem);
    padding-bottom: 5.2rem;
  }

  .hero-panel {
    width: min(28vw, 25rem);
    min-width: 21rem;
    padding: 1rem 1.25rem;
  }

  .hero-logo-wrap {
    width: min(11.8rem, 64%);
  }

  .hero-panel h1 {
    font-size: clamp(2.65rem, 4vw, 3.85rem);
  }

  .hero-kicker {
    font-size: 1rem;
  }

  .hero-intro {
    font-size: 0.88rem;
    line-height: 1.45;
  }

  .hero .cover-slideshow__caption {
    bottom: 5.1rem;
  }

  .hero-buttons {
    bottom: 0.85rem;
  }

  .hero-buttons a {
    min-height: 3.35rem;
  }
}

/* =========================================================
   HOME DESKTOP TAG CARD + SCREEN FIT TUNING
   Lifts buttons, raises slide text, and turns brand card into a tag
   ========================================================= */

@media (min-width: 761px) {
  .hero {
    padding-bottom: clamp(6.6rem, 10vh, 8rem);
  }

  .hero-content {
    width: min(100%, 1280px);
  }

  .hero-panel {
    position: relative;

    width: min(29vw, 28.5rem);
    min-width: 22.5rem;

    padding:
      clamp(1.15rem, 2.1vh, 1.45rem)
      clamp(1.25rem, 2vw, 1.65rem)
      clamp(1.25rem, 2.1vh, 1.55rem);

    border-radius: 30px 30px 30px 30px;

    /* tag/card shape without breaking layout */
    clip-path: polygon(
      0 0,
      100% 0,
      100% calc(100% - 2.2rem),
      calc(100% - 1.15rem) 100%,
      0 100%
    );

    box-shadow:
      0 34px 85px rgba(0, 0, 0, 0.44),
      0 0 0 1px rgba(122, 82, 48, 0.08),
      inset 0 1px 0 rgba(255, 255, 255, 0.62);
  }

  .hero-panel::after {
    content: "";

    position: absolute;
    top: 1.1rem;
    left: 50%;
    z-index: 3;

    width: 0.72rem;
    height: 0.72rem;

    background:
      radial-gradient(circle, rgba(34, 22, 14, 0.24), rgba(34, 22, 14, 0.08));
    border: 1px solid rgba(122, 82, 48, 0.32);
    border-radius: 999px;

    box-shadow:
      inset 0 1px 2px rgba(0, 0, 0, 0.14),
      0 1px 0 rgba(255, 255, 255, 0.72);

    transform: translateX(-50%);
  }

  .hero-panel::before {
    /* subtle string from the punched hole */
    background:
      linear-gradient(
        to bottom,
        rgba(122, 82, 48, 0.38),
        rgba(122, 82, 48, 0.08) 4.8rem,
        transparent 4.8rem
      ),
      radial-gradient(
        ellipse at 10% 18%,
        rgba(239, 189, 114, 0.18),
        transparent 36%
      ),
      radial-gradient(
        ellipse at 88% 78%,
        rgba(122, 82, 48, 0.12),
        transparent 34%
      );
    background-size:
      1px 5.4rem,
      auto,
      auto;
    background-position:
      center 0,
      center,
      center;
    background-repeat:
      no-repeat,
      no-repeat,
      no-repeat;
  }

  .hero-logo-wrap {
    width: min(13rem, 68%);
    margin-top: 0.2rem;
    margin-bottom: 0.25rem;
  }

  .hero-panel h1 {
    font-size: clamp(2.9rem, 4.25vw, 4.45rem);
  }

  .hero-kicker {
    max-width: 17.5rem;
    margin-top: 0.25rem;
    margin-bottom: 0.55rem;
  }

  .hero-intro {
    font-size: clamp(0.88rem, 0.95vw, 0.98rem);
    line-height: 1.5;
  }

  .hero-buttons {
    bottom: clamp(2.15rem, 4.2vh, 3.15rem);

    width: min(43rem, 50vw);
    min-width: 36rem;

    gap: clamp(1.05rem, 1.6vw, 1.45rem);
  }

  .hero-buttons a {
    min-height: clamp(3.55rem, 5.7vh, 4rem);
    padding-inline: 1rem;
  }

  .hero .cover-slideshow__caption {
    bottom: clamp(8.15rem, 13vh, 10.2rem);
    right: clamp(2.4rem, 5.4vw, 6.2rem);

    width: min(35rem, 39vw);
  }

  .hero .cover-slideshow__caption h2 {
    font-size: clamp(1.15rem, 1.75vw, 1.75rem);
  }

  .hero .cover-slideshow__description {
    font-size: clamp(0.8rem, 0.88vw, 0.94rem);
  }

  .hero .cover-slideshow__link {
    margin-top: 0.65rem;
  }
}

/* Keep short laptop screens usable */
@media (min-width: 761px) and (max-height: 780px) {
  .hero {
    padding-top: calc(var(--site-header-height, 76px) + 0.55rem);
    padding-bottom: 5.9rem;
  }

  .hero-panel {
    width: min(27vw, 25rem);
    min-width: 21rem;
  }

  .hero-logo-wrap {
    width: min(10.8rem, 60%);
  }

  .hero-panel h1 {
    font-size: clamp(2.55rem, 3.65vw, 3.65rem);
  }

  .hero-kicker {
    font-size: 0.98rem;
  }

  .hero-intro {
    font-size: 0.84rem;
    line-height: 1.42;
  }

  .hero .cover-slideshow__caption {
    bottom: 7.15rem;
  }

  .hero-buttons {
    bottom: 1.45rem;

    width: min(41rem, 52vw);
  }

  .hero-buttons a {
    min-height: 3.35rem;
  }
}

/* =========================================================
   HOME BRAND TAG TEXT ORDER TUNING
   Logo, overlapping H1, right-aligned tagline, star divider
   ========================================================= */

@media (min-width: 761px) {
  .hero-logo-wrap {
    width: min(15rem, 74%);
    margin-bottom: 0;
  }

  .hero-panel h1 {
    position: relative;
    z-index: 4;

    margin-top: -60px;

    color: var(--dark);

    font-family: var(--font-title);
    font-size: clamp(3.05rem, 4.4vw, 4.75rem);
    line-height: 0.86;
    letter-spacing: -0.055em;
    text-align: center;
  }

  .hero-kicker {
    width: 100%;
    max-width: none;

    margin: 0.8rem 0 0.55rem;
    padding-right: 20px;

    color: var(--coffee);

    font-family: var(--font-script);
    font-size: clamp(1.02rem, 1.25vw, 1.22rem);
    font-weight: 800;
    line-height: 1.08;
    text-align: right;
  }

  .hero-divider {
    width: min(82%, 18rem);
    margin: 0.75rem 0 1rem auto;

    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 0.6rem;

    color: var(--gold);
  }

  .hero-divider span {
    height: 1px;

    background: linear-gradient(
      to right,
      transparent,
      rgba(122, 82, 48, 0.34),
      transparent
    );
  }

  .hero-divider strong {
    display: inline-grid;
    place-items: center;

    color: var(--gold);
    font-size: 0.78rem;
    line-height: 1;

    animation: vv-star-twinkle 2.8s ease-in-out infinite;
  }

  .hero-intro {
    max-width: none;

    margin-top: 0;

    color: rgba(45, 34, 24, 0.9);

    font-family: var(--font-body);
    font-size: clamp(0.9rem, 0.95vw, 1rem);
    line-height: 1.58;
    text-align: justify;
    text-wrap: pretty;
  }
}

@media (min-width: 761px) and (max-height: 780px) {
  .hero-logo-wrap {
    width: min(12rem, 65%);
  }

  .hero-panel h1 {
    margin-top: -48px;
    font-size: clamp(2.65rem, 3.8vw, 3.85rem);
  }

  .hero-kicker {
    margin-top: 0.65rem;
    font-size: 0.98rem;
  }

  .hero-divider {
    margin-block: 0.55rem 0.75rem;
  }

  .hero-intro {
    font-size: 0.84rem;
    line-height: 1.45;
  }
}

@media (max-width: 760px) {
  .hero-logo-wrap {
    margin-bottom: 0;
  }

  .hero-panel h1 {
    margin-top: -42px;
  }

  .hero-kicker {
    width: 100%;
    max-width: none;

    margin: 0.65rem 0 0.45rem;
    padding-right: 20px;

    text-align: right;
  }

  .hero-divider {
    width: min(82%, 16rem);
    margin: 0.55rem 0 0.75rem auto;

    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 0.55rem;

    color: var(--gold);
  }

  .hero-divider span {
    height: 1px;
    background: linear-gradient(
      to right,
      transparent,
      rgba(255, 246, 229, 0.38),
      transparent
    );
  }

  .hero-divider strong {
    font-size: 0.72rem;
    animation: vv-star-twinkle 2.8s ease-in-out infinite;
  }

  .hero-intro {
    text-align: justify;
  }
}

/* =========================================================
   HOME TAG LOGO FADE + STITCH BORDER
   Softens logo under brand name and adds handmade stitched edge
   ========================================================= */

.hero-logo {
  -webkit-mask-image: linear-gradient(
    to bottom,
    black 0%,
    black 52%,
    rgba(0, 0, 0, 0.72) 68%,
    rgba(0, 0, 0, 0.22) 84%,
    transparent 100%
  );

  mask-image: linear-gradient(
    to bottom,
    black 0%,
    black 52%,
    rgba(0, 0, 0, 0.72) 68%,
    rgba(0, 0, 0, 0.22) 84%,
    transparent 100%
  );
}

.hero-panel {
  outline: 1px dashed rgba(166, 97, 34, 0.7);
  outline-offset: -0.72rem;
}

.hero-panel::after {
  box-shadow:
    inset 0 1px 2px rgba(0, 0, 0, 0.14),
    0 1px 0 rgba(255, 255, 255, 0.72),
    0 0 0 0.42rem rgba(255, 250, 245, 0.34);
}

/* tiny stitch holes, subtle enough to feel handmade not noisy */
.hero-panel .hero-divider::before,
.hero-panel .hero-divider::after {
  content: "";

  position: absolute;
  top: 50%;

  width: 0.22rem;
  height: 0.22rem;

  background: rgba(166, 97, 34, 0.48);
  border-radius: 999px;

  transform: translateY(-50%);
}

.hero-divider {
  position: relative;
}

.hero-panel .hero-divider::before {
  left: -0.55rem;
}

.hero-panel .hero-divider::after {
  right: -0.55rem;
}

@media (max-width: 760px) {
  .hero-panel {
    outline-color: rgba(239, 189, 114, 0.42);
    outline-offset: -0.55rem;
  }

  .hero-logo {
    -webkit-mask-image: linear-gradient(
      to bottom,
      black 0%,
      black 48%,
      rgba(0, 0, 0, 0.66) 64%,
      rgba(0, 0, 0, 0.18) 82%,
      transparent 100%
    );

    mask-image: linear-gradient(
      to bottom,
      black 0%,
      black 48%,
      rgba(0, 0, 0, 0.66) 64%,
      rgba(0, 0, 0, 0.18) 82%,
      transparent 100%
    );
  }
}

/* =========================================================
   HOME TAG BIGGER KICKER + LEATHER STITCHES
   Stronger handmade leather-tag feel
   ========================================================= */

@media (min-width: 761px) {
  .hero-kicker {
    padding-right: 20px !important;

    font-size: clamp(1.18rem, 1.55vw, 1.55rem) !important;
    line-height: 1.08 !important;
    text-align: right !important;
  }

  .hero-panel {
    outline: 2px dashed rgba(166, 97, 34, 0.76) !important;
    outline-offset: -0.82rem !important;
  }

  .hero-panel::before {
    background:
      linear-gradient(
        to bottom,
        rgba(122, 82, 48, 0.42),
        rgba(122, 82, 48, 0.08) 4.8rem,
        transparent 4.8rem
      ),
      radial-gradient(
        ellipse at 10% 18%,
        rgba(239, 189, 114, 0.18),
        transparent 36%
      ),
      radial-gradient(
        ellipse at 88% 78%,
        rgba(122, 82, 48, 0.12),
        transparent 34%
      ),
      repeating-linear-gradient(
        90deg,
        transparent 0 1rem,
        rgba(166, 97, 34, 0.055) 1rem 1.08rem,
        transparent 1.08rem 2rem
      ) !important;
  }

  .hero-panel::after {
    width: 0.82rem !important;
    height: 0.82rem !important;

    border-color: rgba(122, 82, 48, 0.46) !important;

    box-shadow:
      inset 0 1px 2px rgba(0, 0, 0, 0.18),
      0 1px 0 rgba(255, 255, 255, 0.74),
      0 0 0 0.5rem rgba(255, 250, 245, 0.38) !important;
  }
}

/* Extra visible stitch feel without touching the real card shape */
@media (min-width: 761px) {
  .hero-panel {
    background:
      radial-gradient(
        circle at 50% 0%,
        rgba(255, 250, 245, 0.94),
        rgba(255, 250, 245, 0.72) 36%,
        rgba(245, 239, 230, 0.5) 76%
      ),
      linear-gradient(
        145deg,
        rgba(255, 250, 245, 0.78),
        rgba(245, 239, 230, 0.52)
      ) !important;
  }
}

@media (max-width: 760px) {
  .hero-kicker {
    padding-right: 20px !important;

    font-size: clamp(1.16rem, 5.2vw, 1.45rem) !important;
    line-height: 1.08 !important;
    text-align: right !important;
  }

  .hero-panel {
    outline: 2px dashed rgba(239, 189, 114, 0.58) !important;
    outline-offset: -0.62rem !important;
  }
}

/* =========================================================
   HOME BRAND EMBOSSED TITLE
   Gives Virtual Ventures a pressed leather/card effect
   ========================================================= */

.hero-panel h1 {
  color: #2b1b12 !important;

  text-shadow:
    0 1px 0 rgba(255, 250, 245, 0.72),
    0 -1px 0 rgba(74, 45, 27, 0.32),
    1px 2px 0 rgba(74, 45, 27, 0.16),
    0 8px 14px rgba(45, 34, 24, 0.16),
    0 0 18px rgba(166, 97, 34, 0.08);

  filter:
    drop-shadow(0 1px 0 rgba(255, 250, 245, 0.42))
    drop-shadow(0 5px 8px rgba(45, 34, 24, 0.14));
}

.hero-panel h1::selection {
  color: #fff7ed;
  background: #7a5230;
}

/* Extra depth on desktop where the card has room to breathe */
@media (min-width: 761px) {
  .hero-panel h1 {
    -webkit-text-stroke: 0.35px rgba(45, 27, 17, 0.18);

    text-shadow:
      0 1px 0 rgba(255, 250, 245, 0.82),
      0 -1px 0 rgba(74, 45, 27, 0.36),
      1px 2px 0 rgba(74, 45, 27, 0.18),
      -1px -1px 0 rgba(255, 250, 245, 0.22),
      0 10px 16px rgba(45, 34, 24, 0.18),
      0 0 22px rgba(166, 97, 34, 0.1);
  }
}

/* Slightly simpler on phones so it stays readable */
@media (max-width: 760px) {
  .hero-panel h1 {
    text-shadow:
      0 1px 0 rgba(255, 250, 245, 0.5),
      0 -1px 0 rgba(74, 45, 27, 0.28),
      0 5px 10px rgba(0, 0, 0, 0.28);
  }
}

/* =========================================================
   HOME DESKTOP HANGING TAG + LEATHER BUTTONS
   Better desktop screen fit, hemp string, leather CTA buttons
   ========================================================= */

@media (min-width: 761px) {
  .hero {
    padding:
      calc(var(--site-header-height, 76px) + clamp(1.15rem, 2.7vh, 2rem))
      clamp(1.35rem, 4vw, 4.5rem)
      clamp(6.6rem, 10vh, 8rem);
  }

  .hero-content {
    width: 100%;
    max-width: none;
    margin-inline: 0;

    grid-template-columns: minmax(22rem, 30rem) minmax(0, 1fr);

    align-self: start;

    padding-left: clamp(1.35rem, 6.8vw, 7.2rem);
    padding-right: clamp(1rem, 4vw, 4rem);

    transform: translateY(clamp(0.35rem, 1.6vh, 1.1rem));
  }

  .hero-panel {
    width: clamp(22rem, 27vw, 29rem);
    min-width: 0;

    margin: 0;
  }

  /* Hemp string loop from the nav area into the tag hole */
  .hero-panel .hero-logo-wrap::before,
  .hero-panel .hero-logo-wrap::after {
    content: "";

    position: absolute;
    left: 50%;
    z-index: 8;

    pointer-events: none;
  }

  .hero-panel .hero-logo-wrap::before {
    top: -5.8rem;

    width: 2.4rem;
    height: 6.25rem;

    border: 3px solid rgba(118, 84, 55, 0.74);
    border-bottom-color: transparent;
    border-radius: 999px 999px 0 0;

    transform: translateX(-50%);

    filter:
      drop-shadow(0 1px 0 rgba(255, 246, 229, 0.34))
      drop-shadow(0 3px 5px rgba(39, 24, 14, 0.28));

    opacity: 0;

    animation: vv-hemp-string-drop 900ms ease-out 220ms forwards;
  }

  .hero-panel .hero-logo-wrap::after {
    top: -5.55rem;

    width: 2px;
    height: 5.75rem;

    background:
      repeating-linear-gradient(
        to bottom,
        rgba(92, 64, 42, 0.82) 0 4px,
        rgba(186, 145, 91, 0.72) 4px 7px
      );

    transform: translateX(-50%) rotate(2deg);

    opacity: 0;

    animation: vv-hemp-string-drop 900ms ease-out 260ms forwards;
  }

  @keyframes vv-hemp-string-drop {
    from {
      opacity: 0;
      transform: translateX(-50%) translateY(-0.9rem) scaleY(0.88);
    }

    to {
      opacity: 1;
      transform: translateX(-50%) translateY(0) scaleY(1);
    }
  }

  .hero-panel h1 {
    color: #2a170d !important;

    text-shadow:
      0 1px 0 rgba(255, 243, 222, 0.34),
      0 -1px 0 rgba(61, 32, 16, 0.58),
      1px 1px 0 rgba(122, 66, 30, 0.24),
      0 3px 0 rgba(91, 50, 23, 0.12),
      0 8px 13px rgba(45, 28, 16, 0.28),
      0 0 12px rgba(122, 66, 30, 0.12) !important;

    -webkit-text-stroke: 0.45px rgba(61, 32, 16, 0.22);
  }

  /* Lift and enlarge the three main buttons */
  .hero-buttons {
    bottom: clamp(2.65rem, 5.2vh, 4.2rem);

    width: min(51rem, 56vw);
    min-width: 42rem;

    gap: clamp(1.35rem, 2vw, 1.9rem);
  }

  .hero-buttons a {
    position: relative;

    min-height: clamp(4.25rem, 7vh, 5rem);
    padding: 0.9rem 1.35rem;

    color: #fff3df;
    background:
      radial-gradient(
        circle at 28% 12%,
        rgba(255, 224, 165, 0.22),
        transparent 38%
      ),
      linear-gradient(145deg, #8b562d, #4a2c19 62%, #2d1a10);

    border: 2px solid rgba(216, 164, 93, 0.85);
    border-radius: 18px;

    outline: 1.5px dashed rgba(239, 189, 114, 0.56);
    outline-offset: -0.48rem;

    font-size: clamp(0.9rem, 1.05vw, 1.08rem);

    box-shadow:
      0 16px 34px rgba(0, 0, 0, 0.4),
      inset 0 1px 0 rgba(255, 246, 229, 0.26),
      inset 0 -14px 26px rgba(32, 18, 10, 0.34);
  }

  .hero-buttons a::before,
  .hero-buttons a::after {
    content: "";

    position: absolute;
    top: 50%;

    width: 0.42rem;
    height: 0.42rem;

    background:
      radial-gradient(circle at 35% 30%, #fff3cc, #d8a45d 42%, #8b562d 78%);
    border: 1px solid rgba(255, 246, 229, 0.38);
    border-radius: 999px;

    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.32),
      inset 0 -1px 1px rgba(45, 24, 12, 0.44),
      0 0 10px rgba(239, 189, 114, 0.2);

    transform: translateY(-50%);
  }

  .hero-buttons a::before {
    left: 0.72rem;
  }

  .hero-buttons a::after {
    right: 0.72rem;
  }

  .hero-buttons a:hover,
  .hero-buttons a:focus-visible {
    color: #201209;

    background:
      radial-gradient(
        circle at 28% 12%,
        rgba(255, 239, 205, 0.38),
        transparent 38%
      ),
      linear-gradient(145deg, #efbd72, #b57435 58%, #6a3d1d);

    border-color: rgba(255, 246, 229, 0.68);

    outline-color: rgba(255, 246, 229, 0.62);

    transform: translateY(-4px);

    box-shadow:
      0 22px 44px rgba(0, 0, 0, 0.44),
      0 0 24px rgba(216, 164, 93, 0.2),
      inset 0 1px 0 rgba(255, 255, 255, 0.42);
  }

  .hero-buttons a span:last-child {
    padding-inline: 0.72rem;
  }

  .button-icon {
    width: 1.45rem;
    height: 1.45rem;
  }

  /* Raise caption so it clears the larger buttons */
  .hero .cover-slideshow__caption {
    bottom: clamp(9.9rem, 15vh, 12.2rem);
  }
}

/* Tablet / smaller desktop safety */
@media (min-width: 761px) and (max-width: 1180px) {
  .hero-content {
    padding-left: clamp(1.35rem, 4vw, 3rem);
    grid-template-columns: minmax(20rem, 26rem) minmax(0, 1fr);
  }

  .hero-panel {
    width: clamp(20rem, 32vw, 26rem);
  }

  .hero-buttons {
    width: min(46rem, 70vw);
    min-width: 34rem;
  }
}

/* Short screens must keep buttons visible */
@media (min-width: 761px) and (max-height: 780px) {
  .hero {
    padding-top: calc(var(--site-header-height, 76px) + 0.8rem);
    padding-bottom: 6.2rem;
  }

  .hero-content {
    transform: translateY(0);
  }

  .hero-panel {
    width: clamp(20rem, 25vw, 25rem);
  }

  .hero-panel .hero-logo-wrap::before {
    top: -4.8rem;
    height: 5.25rem;
  }

  .hero-panel .hero-logo-wrap::after {
    top: -4.55rem;
    height: 4.8rem;
  }

  .hero-buttons {
    bottom: 1.55rem;
  }

  .hero-buttons a {
    min-height: 3.85rem;
  }

  .hero .cover-slideshow__caption {
    bottom: 7.2rem;
  }
}

/* =========================================================
   HOME DESKTOP HERO VISIBILITY TUNING
   Makes buttons instantly visible and lifts slide caption
   ========================================================= */

@media (min-width: 761px) {
  /* Move hero photos slightly lower for planned consistent product shots */
  .hero .cover-slideshow__slide {
    background-position: center 58% !important;
  }

  /* Less heavy darkness where the caption/buttons live */
  .hero::before {
    background:
      radial-gradient(
        circle at 72% 46%,
        transparent 0 30%,
        rgba(16, 10, 6, 0.14) 58%,
        rgba(16, 10, 6, 0.52) 100%
      ),
      linear-gradient(
        to right,
        rgba(18, 11, 7, 0.74),
        rgba(18, 11, 7, 0.36) 38%,
        rgba(18, 11, 7, 0.1) 68%,
        rgba(18, 11, 7, 0.34)
      ) !important;
  }

  .hero-bottom-fade {
    height: clamp(7.2rem, 13vw, 10rem) !important;

    background: linear-gradient(
      to top,
      rgba(15, 10, 7, 0.72),
      rgba(15, 10, 7, 0.34) 46%,
      transparent
    ) !important;
  }

  /* The important three buttons must be visible on first load */
  .hero-buttons {
    bottom: clamp(3.8rem, 7vh, 5.6rem) !important;

    width: min(52rem, 57vw) !important;
    min-width: 42rem !important;

    gap: clamp(1.45rem, 2.1vw, 2rem) !important;
  }

  .hero-buttons a {
    min-height: clamp(4.3rem, 7vh, 5.05rem) !important;
    padding: 0.92rem 1.4rem !important;
  }

  /* Lift caption out of the dark bottom vignette */
  .hero .cover-slideshow__caption {
    bottom: clamp(13.2rem, 22vh, 16.5rem) !important;
    right: clamp(2.6rem, 5.5vw, 6.3rem) !important;

    width: min(36rem, 40vw) !important;
  }

  .hero .cover-slideshow__caption::before {
    background:
      radial-gradient(
        ellipse at center,
        rgba(20, 12, 8, 0.52),
        rgba(20, 12, 8, 0.28) 48%,
        transparent 78%
      ) !important;
  }

  .hero .cover-slideshow__caption h2 {
    font-size: clamp(1.15rem, 1.65vw, 1.72rem) !important;
  }

  .hero .cover-slideshow__description {
    font-size: clamp(0.78rem, 0.86vw, 0.92rem) !important;
    line-height: 1.42 !important;
  }
}

/* Medium desktop / tablet landscape safety */
@media (min-width: 761px) and (max-width: 1180px) {
  .hero .cover-slideshow__slide {
    background-position: center 56% !important;
  }

  .hero-buttons {
    bottom: clamp(3.4rem, 6vh, 4.6rem) !important;

    width: min(46rem, 72vw) !important;
    min-width: 34rem !important;
  }

  .hero .cover-slideshow__caption {
    bottom: clamp(11.5rem, 19vh, 14rem) !important;
    width: min(31rem, 42vw) !important;
  }
}

/* Short screens: keep buttons visible without crushing the tag */
@media (min-width: 761px) and (max-height: 780px) {
  .hero .cover-slideshow__slide {
    background-position: center 60% !important;
  }

  .hero-content {
    transform: translateY(-0.35rem) !important;
  }

  .hero-buttons {
    bottom: 2.25rem !important;
  }

  .hero-buttons a {
    min-height: 3.85rem !important;
  }

  .hero .cover-slideshow__caption {
    bottom: 8.4rem !important;
  }

  .hero-bottom-fade {
    height: 7.2rem !important;
  }
}

/* Very short laptop windows */
@media (min-width: 761px) and (max-height: 680px) {
  .hero-panel {
    transform: scale(0.92);
    transform-origin: left center;
  }

  .hero-buttons {
    bottom: 1.55rem !important;
  }

  .hero .cover-slideshow__caption {
    bottom: 7.1rem !important;
  }
}

/* =========================================================
   HOME DESKTOP FINAL BUTTON + IMAGE POSITION
   Keeps CTA buttons visible and nudges slideshow framing down
   ========================================================= */

@media (min-width: 761px) {
  /* Nudge product hero images down so the subject stays in frame */
  .hero .cover-slideshow__slide {
    background-position: center 64% !important;
    background-size: cover !important;
  }

  /* Give the bottom of the hero more breathing room */
  .hero {
    padding-bottom: clamp(8.2rem, 13vh, 10.2rem) !important;
  }

  /* Make the bottom darkness less aggressive around the CTAs */
  .hero-bottom-fade {
    height: clamp(8rem, 13vw, 10.5rem) !important;

    background: linear-gradient(
      to top,
      rgba(15, 10, 7, 0.62),
      rgba(15, 10, 7, 0.28) 48%,
      transparent
    ) !important;
  }

  /* Bring the three key buttons fully into the first screen */
  .hero-buttons {
    bottom: clamp(4.9rem, 8.8vh, 6.7rem) !important;

    width: min(52rem, 57vw) !important;
    min-width: 42rem !important;

    gap: clamp(1.5rem, 2.2vw, 2.1rem) !important;
  }

  .hero-buttons a {
    min-height: clamp(4.25rem, 6.8vh, 4.9rem) !important;
  }

  /* Caption should sit above the buttons, not inside the black vignette */
  .hero .cover-slideshow__caption {
    bottom: clamp(14.6rem, 24vh, 18rem) !important;
  }
}

/* Large but shorter screens, like laptop/browser with taskbar */
@media (min-width: 761px) and (max-height: 860px) {
  .hero .cover-slideshow__slide {
    background-position: center 66% !important;
  }

  .hero {
    padding-bottom: 8.6rem !important;
  }

  .hero-content {
    transform: translateY(-0.65rem) !important;
  }

  .hero-buttons {
    bottom: 4.25rem !important;
  }

  .hero-buttons a {
    min-height: 4rem !important;
  }

  .hero .cover-slideshow__caption {
    bottom: 12.4rem !important;
  }
}

/* Very short desktop windows */
@media (min-width: 761px) and (max-height: 740px) {
  .hero-content {
    transform: translateY(-1.1rem) !important;
  }

  .hero-panel {
    transform: scale(0.92) !important;
    transform-origin: left center;
  }

  .hero-buttons {
    bottom: 3.35rem !important;
  }

  .hero-buttons a {
    min-height: 3.65rem !important;
  }

  .hero .cover-slideshow__caption {
    bottom: 9.4rem !important;
  }
}

/* =========================================================
   HOME DESKTOP FINAL MICRO FIT
   Extra taskbar breathing room and gentle image framing
   ========================================================= */

@media (min-width: 761px) {
  .hero .cover-slideshow__slide {
    background-position: center 68% !important;
  }

  .hero-buttons {
    bottom: clamp(5.7rem, 10vh, 7.4rem) !important;
  }

  .hero .cover-slideshow__caption {
    bottom: clamp(15.8rem, 26vh, 19.5rem) !important;
  }
}

/* Laptop browser windows with a visible OS taskbar */
@media (min-width: 761px) and (max-height: 860px) {
  .hero .cover-slideshow__slide {
    background-position: center 70% !important;
  }

  .hero-buttons {
    bottom: 5.05rem !important;
  }

  .hero .cover-slideshow__caption {
    bottom: 13.4rem !important;
  }
}

/* Shorter windows still keep the buttons visible */
@media (min-width: 761px) and (max-height: 740px) {
  .hero-buttons {
    bottom: 4.1rem !important;
  }

  .hero .cover-slideshow__caption {
    bottom: 10.4rem !important;
  }
}

/* =========================================================
   HOME SLIDESHOW TOP RIGHT FOCAL POINT
   Full-width slideshow with product focus pulled upward/right
   ========================================================= */

@media (min-width: 761px) {
  .hero {
    background:
      radial-gradient(
        ellipse at 72% 38%,
        rgba(166, 97, 34, 0.2),
        transparent 34rem
      ),
      linear-gradient(135deg, #160c07, #332012 48%, #120b08) !important;
  }

  .hero .cover-slideshow {
    background: #160c07 !important;
  }

  .hero .cover-slideshow__slide {
    background-size: cover !important;
    background-position: 68% 34% !important;
    background-repeat: no-repeat !important;

    -webkit-mask-image: none !important;
    mask-image: none !important;

    filter: saturate(1.05) contrast(1.03) brightness(1.02) !important;
  }

  .hero .cover-slideshow::after {
    content: "";

    position: absolute;
    inset: 0;
    z-index: 8;

    pointer-events: none;

    background:
      radial-gradient(
        ellipse at 68% 38%,
        transparent 0 42%,
        rgba(18, 11, 7, 0.16) 70%,
        rgba(18, 11, 7, 0.44) 100%
      ),
      linear-gradient(
        to right,
        rgba(18, 11, 7, 0.82) 0%,
        rgba(18, 11, 7, 0.42) 14%,
        rgba(18, 11, 7, 0.1) 30%,
        transparent 52%,
        rgba(18, 11, 7, 0.12) 86%,
        rgba(18, 11, 7, 0.5) 100%
      ),
      linear-gradient(
        to bottom,
        rgba(18, 11, 7, 0.32) 0%,
        transparent 24%,
        transparent 72%,
        rgba(18, 11, 7, 0.34) 100%
      ) !important;
  }

  .hero::before {
    background:
      radial-gradient(
        circle at 68% 38%,
        transparent 0 42%,
        rgba(16, 10, 6, 0.08) 66%,
        rgba(16, 10, 6, 0.36) 100%
      ),
      linear-gradient(
        to right,
        rgba(18, 11, 7, 0.6),
        rgba(18, 11, 7, 0.24) 36%,
        rgba(18, 11, 7, 0.04) 68%,
        rgba(18, 11, 7, 0.22)
      ) !important;
  }
}

/* Wider screens: keep the subject high and right */
@media (min-width: 1280px) {
  .hero .cover-slideshow__slide {
    background-position: 70% 32% !important;
  }
}

/* Very wide screens need a slightly softer right pull */
@media (min-width: 1700px) {
  .hero .cover-slideshow__slide {
    background-position: 66% 34% !important;
  }
}

/* Laptop/browser windows with visible taskbar */
@media (min-width: 761px) and (max-height: 860px) {
  .hero .cover-slideshow__slide {
    background-position: 68% 30% !important;
  }
}

/* Smaller desktop/tablet landscape */
@media (min-width: 761px) and (max-width: 1180px) {
  .hero .cover-slideshow__slide {
    background-position: 66% 38% !important;
  }
}

/* =========================================================
   HOME DESKTOP CAPTION + TAG MICRO POLISH
   Softer slide caption and slightly lower leather tag
   ========================================================= */

@media (min-width: 761px) {
  /* Drop the leather tag by about 10px */
  .hero-content {
    transform: translateY(calc(clamp(0.35rem, 1.6vh, 1.1rem) + 10px)) !important;
  }

  /* Make slideshow caption feel less heavy and more premium */
  .hero .cover-slideshow__caption {
    color: rgba(255, 250, 245, 0.96);

    text-shadow:
      0 2px 8px rgba(0, 0, 0, 0.78),
      0 8px 22px rgba(0, 0, 0, 0.48);
  }

  .hero .cover-slideshow__eyebrow {
    color: rgba(239, 189, 114, 0.92);

    font-size: clamp(0.58rem, 0.62vw, 0.72rem) !important;
    letter-spacing: 0.1em;
  }

  .hero .cover-slideshow__caption h2 {
    color: rgba(255, 250, 245, 0.92);

    font-size: clamp(1rem, 1.45vw, 1.5rem) !important;
    line-height: 1.12 !important;
    letter-spacing: 0.005em;

    text-shadow:
      0 2px 8px rgba(0, 0, 0, 0.78),
      0 8px 18px rgba(0, 0, 0, 0.38);
  }

  .hero .cover-slideshow__description {
    color: rgba(255, 250, 245, 0.96);

    font-size: clamp(0.82rem, 0.88vw, 0.94rem) !important;
    font-weight: 850 !important;
    line-height: 1.45 !important;

    text-shadow:
      0 2px 7px rgba(0, 0, 0, 0.82),
      0 6px 16px rgba(0, 0, 0, 0.42);
  }

  .hero .cover-slideshow__link {
    color: rgba(211, 239, 178, 0.92);

    font-size: clamp(0.76rem, 0.84vw, 0.88rem) !important;
    font-weight: 850 !important;
  }
}

/* Keep short screens from dropping the tag too far */
@media (min-width: 761px) and (max-height: 780px) {
  .hero-content {
    transform: translateY(0.15rem) !important;
  }

  .hero .cover-slideshow__caption h2 {
    font-size: clamp(0.95rem, 1.35vw, 1.35rem) !important;
  }

  .hero .cover-slideshow__description {
    font-size: 0.8rem !important;
  }
}

/* =========================================================
   HOME MOBILE FINAL POSTER LAYOUT
   One clean mobile poster layout. No duplicate mobile overrides.
   ========================================================= */

@media (max-width: 760px) {
  .hero {
    position: relative !important;

    width: 100%;
    min-height: 100svh !important;
    height: 100svh !important;

    display: block !important;

    padding: 0 !important;
    overflow: hidden !important;

    color: #fff7ed;
    background: #160c07 !important;
  }

  .hero .cover-slideshow {
    position: absolute !important;
    inset: 0 !important;
    z-index: 0 !important;

    background: #160c07 !important;
  }

  .hero .cover-slideshow__slide {
    background-size: cover !important;
    background-position: 68% 28% !important;
    background-repeat: no-repeat !important;

    filter: saturate(1.04) contrast(1.03) brightness(0.9) !important;

    -webkit-mask-image: none !important;
    mask-image: none !important;
  }

  .hero::before {
    content: "";

    position: absolute;
    inset: 0;
    z-index: 1;

    pointer-events: none;

    background:
      radial-gradient(
        ellipse at 60% 34%,
        transparent 0 26%,
        rgba(18, 11, 7, 0.22) 54%,
        rgba(18, 11, 7, 0.74) 100%
      ),
      linear-gradient(
        to bottom,
        rgba(18, 11, 7, 0.1) 0%,
        rgba(18, 11, 7, 0.18) 42%,
        rgba(18, 11, 7, 0.74) 82%,
        rgba(18, 11, 7, 0.94) 100%
      ) !important;
  }

  .hero-top-fade {
    position: absolute;
    inset: 0 0 auto;
    z-index: 2;

    height: 6.2rem;

    background: linear-gradient(
      to bottom,
      rgba(18, 11, 7, 0.5),
      rgba(18, 11, 7, 0.16) 58%,
      transparent
    ) !important;

    pointer-events: none;
  }

  .hero-bottom-fade {
    position: absolute;
    inset: auto 0 0;
    z-index: 2;

    height: 13rem;

    background: linear-gradient(
      to top,
      rgba(15, 10, 7, 0.9),
      rgba(15, 10, 7, 0.58) 46%,
      rgba(15, 10, 7, 0.12) 78%,
      transparent
    ) !important;

    pointer-events: none;
  }

  /*
    Mobile brand panel becomes invisible.
    We keep its children, but position them around the hero.
  */
  .hero-content {
    position: static !important;
    z-index: auto !important;

    width: auto !important;
    height: auto !important;

    display: block !important;

    padding: 0 !important;
    margin: 0 !important;

    transform: none !important;
  }

  .hero-panel {
    position: static !important;

    width: auto !important;
    min-width: 0 !important;
    max-width: none !important;

    display: block !important;

    padding: 0 !important;
    margin: 0 !important;

    background: transparent !important;
    border: 0 !important;
    border-radius: 0 !important;
    outline: 0 !important;
    box-shadow: none !important;
    backdrop-filter: none !important;
    -webkit-backdrop-filter: none !important;

    transform: none !important;
  }

  .hero-panel::before,
  .hero-panel::after,
  .hero-divider,
  .hero-intro {
    display: none !important;
    content: none !important;
  }

  /*
    Soft oversized logo, tucked top-left and partly off-screen.
  */
  .hero-logo-wrap {
    position: absolute !important;
    top: calc(var(--site-header-height, 70px) - 4.2rem) !important;
    left: -4.4rem !important;
    z-index: 4 !important;

    width: 14.5rem !important;
    height: 14.5rem !important;
    margin: 0 !important;

    opacity: 0.38 !important;
    filter:
      drop-shadow(0 8px 22px rgba(0, 0, 0, 0.42))
      drop-shadow(0 0 18px rgba(239, 189, 114, 0.16)) !important;

    pointer-events: none;
  }

  .hero-logo {
    width: 100% !important;
    height: auto !important;
  }

  /*
    Hide normal desktop H1 on mobile.
    Curved SVG wordmark becomes the mobile brand.
  */
  .hero-panel h1 {
    position: absolute !important;

    width: 1px !important;
    height: 1px !important;

    overflow: hidden !important;
    clip: rect(0 0 0 0) !important;
    white-space: nowrap !important;
  }

  .hero-mobile-curve-brand {
    position: absolute !important;
    top: calc(var(--site-header-height, 70px) + 0.2rem) !important;
    left: -1.25rem !important;
    z-index: 7 !important;

    width: 14.6rem !important;
    height: 14.6rem !important;

    display: block !important;

    overflow: visible !important;

    transform: rotate(-2deg) !important;
    transform-origin: center !important;

    pointer-events: none;

    filter:
      drop-shadow(0 2px 2px rgba(0, 0, 0, 0.92))
      drop-shadow(0 8px 12px rgba(0, 0, 0, 0.58)) !important;
  }

  .hero-mobile-curve-brand text {
    fill: rgba(255, 250, 245, 0.98);

    font-family: var(--font-title);
    font-size: 2.25rem;
    font-weight: 500;
    letter-spacing: -0.045em;
  }

  /*
    Slogan locked to bottom-right, aligned to the right of leather tabs.
    This now positions against .hero, not the old panel.
  */
  .hero-kicker {
    position: absolute !important;
    left: 8.2rem !important;
    right: 1.15rem !important;
    bottom: calc(1.25rem + env(safe-area-inset-bottom, 0px)) !important;
    z-index: 32 !important;

    width: auto !important;
    max-width: none !important;

    margin: 0 !important;
    padding: 0 !important;

    color: rgba(255, 246, 229, 0.98) !important;

    font-family: var(--font-script) !important;
    font-size: clamp(1.18rem, 5.6vw, 1.48rem) !important;
    font-weight: 900 !important;
    line-height: 1.04 !important;
    text-align: right !important;

    text-shadow:
      0 2px 5px rgba(0, 0, 0, 0.98),
      0 8px 18px rgba(0, 0, 0, 0.72),
      0 0 14px rgba(239, 189, 114, 0.18) !important;

    pointer-events: none;
  }

  .hero-kicker::after {
    content: "✦";

    display: block;
    margin-top: 0.24rem;

    color: var(--gold);
    font-size: 0.72rem;
    line-height: 1;

    animation: vv-star-twinkle 2.8s ease-in-out infinite;
  }

  /*
    Slideshow caption centred above the leather tabs.
    Kept above dark overlay and without a box.
  */
  .hero .cover-slideshow__caption {
    display: block !important;

    position: absolute !important;
    left: 50% !important;
    right: auto !important;
    bottom: calc(10.35rem + env(safe-area-inset-bottom, 0px)) !important;
    z-index: 34 !important;

    width: min(58vw, 13rem) !important;
    padding: 0 !important;

    color: rgba(255, 250, 245, 0.98) !important;
    background: transparent !important;
    border: 0 !important;
    border-radius: 0 !important;
    box-shadow: none !important;

    text-align: center !important;

    opacity: 1 !important;
    transform: translateX(-50%) !important;

    text-shadow:
      0 2px 5px rgba(0, 0, 0, 0.98),
      0 7px 18px rgba(0, 0, 0, 0.78),
      0 0 16px rgba(0, 0, 0, 0.58) !important;

    backdrop-filter: none !important;
    -webkit-backdrop-filter: none !important;
  }

  .hero .cover-slideshow__caption::before {
    content: none !important;
  }

  .hero .cover-slideshow__eyebrow {
    margin: 0 0 0.18rem !important;

    color: rgba(239, 189, 114, 0.96) !important;

    font-family: "Bungee", var(--font-ancient), system-ui, sans-serif !important;
    font-size: 0.52rem !important;
    line-height: 1 !important;
    letter-spacing: 0.1em !important;
    text-align: center !important;
    text-transform: uppercase !important;
  }

  .hero .cover-slideshow__caption h2 {
    max-width: 100% !important;
    margin: 0 auto !important;

    color: rgba(255, 250, 245, 0.98) !important;

    font-family: "Bungee", var(--font-ancient), system-ui, sans-serif !important;
    font-size: clamp(0.78rem, 3.65vw, 0.98rem) !important;
    font-weight: 900 !important;
    line-height: 1.08 !important;
    letter-spacing: 0.005em !important;
    text-align: center !important;
  }

  .hero .cover-slideshow__description {
    display: none !important;
  }

  .hero .cover-slideshow__link {
    display: inline-block !important;

    margin-top: 0.28rem !important;

    color: rgba(211, 239, 178, 0.96) !important;

    font-family: var(--font-body) !important;
    font-size: 0.6rem !important;
    font-weight: 950 !important;
    line-height: 1.1 !important;
    text-align: center !important;
  }

  /*
    Stacked leather tabs, locked bottom-left.
  */
  .hero-buttons {
    position: absolute !important;
    left: -0.15rem !important;
    bottom: calc(1.55rem + env(safe-area-inset-bottom, 0px)) !important;
    z-index: 31 !important;

    width: 7.45rem !important;
    min-width: 0 !important;

    display: grid !important;
    grid-template-columns: 1fr !important;
    gap: 0.48rem !important;

    transform: none !important;
  }

  .hero-buttons a {
    position: relative !important;

    min-height: 3.15rem !important;
    padding: 0.48rem 0.78rem 0.48rem 1rem !important;

    display: inline-flex !important;
    flex-direction: row !important;
    align-items: center !important;
    justify-content: flex-start !important;
    gap: 0.42rem !important;

    color: #fff3df !important;
    background:
      radial-gradient(
        circle at 28% 12%,
        rgba(255, 224, 165, 0.24),
        transparent 38%
      ),
      linear-gradient(145deg, #8b562d, #4a2c19 62%, #2d1a10) !important;

    border: 1.5px solid rgba(216, 164, 93, 0.9) !important;
    border-radius: 0 14px 14px 0 !important;

    outline: 1px dashed rgba(239, 189, 114, 0.6) !important;
    outline-offset: -0.36rem !important;

    font-family: "Bungee", var(--font-ancient), system-ui, sans-serif !important;
    font-size: 0.68rem !important;
    font-weight: 900 !important;
    line-height: 1 !important;
    letter-spacing: 0.01em !important;

    box-shadow:
      0 14px 28px rgba(0, 0, 0, 0.38),
      inset 0 1px 0 rgba(255, 246, 229, 0.22),
      inset 0 -12px 22px rgba(32, 18, 10, 0.32) !important;

    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  .hero-buttons a::before,
  .hero-buttons a::after {
    content: "";

    position: absolute;
    top: 50%;

    width: 0.28rem;
    height: 0.28rem;

    background:
      radial-gradient(circle at 35% 30%, #fff3cc, #d8a45d 44%, #8b562d 78%);
    border-radius: 999px;

    transform: translateY(-50%);
  }

  .hero-buttons a::before {
    left: 0.42rem;
  }

  .hero-buttons a::after {
    right: 0.38rem;
  }

  .button-icon {
    width: 1rem !important;
    height: 1rem !important;
  }
}

/* Smaller phone safety */
@media (max-width: 390px) {
  .hero-logo-wrap {
    top: calc(var(--site-header-height, 70px) - 4.35rem) !important;
    left: -4.6rem !important;

    width: 14.2rem !important;
    height: 14.2rem !important;
  }

  .hero-mobile-curve-brand {
    top: calc(var(--site-header-height, 70px) + 0.05rem) !important;
    left: -1.45rem !important;

    width: 14rem !important;
    height: 14rem !important;
  }

  .hero-mobile-curve-brand text {
    font-size: 2.12rem;
  }

  .hero .cover-slideshow__caption {
    bottom: calc(10.15rem + env(safe-area-inset-bottom, 0px)) !important;

    width: min(56vw, 12.4rem) !important;
  }

  .hero .cover-slideshow__caption h2 {
    font-size: clamp(0.72rem, 3.45vw, 0.9rem) !important;
  }

  .hero-kicker {
    left: 8rem !important;
    right: 0.78rem !important;
    bottom: calc(1.15rem + env(safe-area-inset-bottom, 0px)) !important;

    font-size: clamp(1.02rem, 5.1vw, 1.28rem) !important;
  }

  .hero-buttons {
    width: 7.15rem !important;
    bottom: calc(1.45rem + env(safe-area-inset-bottom, 0px)) !important;
    gap: 0.42rem !important;
  }

  .hero-buttons a {
    min-height: 2.95rem !important;
    font-size: 0.62rem !important;
  }
}


/* =========================================================
   HOME MOBILE BRAND FIX AFTER CLEANUP
   Bigger readable curved name + soft background logo
   ========================================================= */

@media (max-width: 760px) {
  .hero-logo-wrap {
    top: calc(var(--site-header-height, 70px) - 5.05rem) !important;
    left: -5.25rem !important;
    z-index: 4 !important;

    width: 16.8rem !important;
    height: 16.8rem !important;

    opacity: 0.34 !important;

    filter:
      drop-shadow(0 10px 24px rgba(0, 0, 0, 0.48))
      drop-shadow(0 0 18px rgba(239, 189, 114, 0.18)) !important;
  }

  .hero-logo-wrap::after {
    content: "";

    position: absolute;
    inset: 18%;

    border-radius: 999px;

    background:
      radial-gradient(
        circle,
        rgba(255, 232, 184, 0.14),
        rgba(239, 189, 114, 0.08) 38%,
        transparent 72%
      );

    filter: blur(14px);
    opacity: 0.9;

    pointer-events: none;
  }

  .hero-mobile-curve-brand {
    top: calc(var(--site-header-height, 70px) + 0.05rem) !important;
    left: -0.95rem !important;
    z-index: 8 !important;

    width: 17.8rem !important;
    height: 13.8rem !important;

    overflow: visible !important;

    transform: rotate(3deg) !important;
    transform-origin: 42% 48% !important;

    opacity: 1 !important;

    filter:
      drop-shadow(0 2px 1px rgba(0, 0, 0, 0.98))
      drop-shadow(0 8px 12px rgba(0, 0, 0, 0.62))
      drop-shadow(0 0 12px rgba(239, 189, 114, 0.16)) !important;
  }

  .hero-mobile-curve-brand text {
    fill: rgba(255, 250, 245, 0.99) !important;

    font-family: var(--font-title) !important;
    font-size: 2.35rem !important;
    font-weight: 500 !important;
    letter-spacing: -0.045em !important;

    paint-order: stroke fill;
    stroke: rgba(45, 24, 13, 0.72);
    stroke-width: 1.8px;
    stroke-linejoin: round;
  }

  .hero-mobile-curve-brand textPath {
    text-anchor: middle;
  }
}

@media (max-width: 390px) {
  .hero-logo-wrap {
    top: calc(var(--site-header-height, 70px) - 5.15rem) !important;
    left: -5.4rem !important;

    width: 16.3rem !important;
    height: 16.3rem !important;
  }

  .hero-mobile-curve-brand {
    top: calc(var(--site-header-height, 70px) - 0.05rem) !important;
    left: -1.08rem !important;

    width: 17.3rem !important;
    height: 13.4rem !important;
  }

  .hero-mobile-curve-brand text {
    font-size: 2.22rem !important;
  }
}


/* =========================================================
   HOME MOBILE BRAND SIZE + EXTRA STAR
   Larger mobile wordmark, larger slogan, extra animated star
   ========================================================= */

@media (max-width: 760px) {
  .hero-mobile-curve-brand {
    top: calc(var(--site-header-height, 70px) - 0.12rem) !important;
    left: -1.35rem !important;

    width: 19.2rem !important;
    height: 14.8rem !important;

    transform: rotate(3deg) !important;
  }

  .hero-mobile-curve-brand text {
    font-size: 2.72rem !important;
    letter-spacing: -0.055em !important;

    stroke: rgba(45, 24, 13, 0.74) !important;
    stroke-width: 1.95px !important;
  }

  .hero-kicker {
    left: 8rem !important;
    right: 0.85rem !important;
    bottom: calc(1.45rem + env(safe-area-inset-bottom, 0px)) !important;

    font-size: clamp(1.38rem, 6.4vw, 1.72rem) !important;
    line-height: 1.02 !important;
  }

  /*
    Extra animated star in the top-left brand area.
    Uses the hidden desktop H1 as the sparkle anchor on mobile.
  */
  .hero-panel h1::after {
    content: "✦" !important;

    position: fixed !important;
    top: calc(var(--site-header-height, 70px) + 0.72rem) !important;
    left: 1.15rem !important;
    z-index: 35 !important;

    display: block !important;

    width: 1.15rem !important;
    height: 1.15rem !important;

    color: rgba(239, 189, 114, 0.96) !important;

    font-family: var(--font-title) !important;
    font-size: 1.08rem !important;
    line-height: 1 !important;

    text-shadow:
      0 2px 5px rgba(0, 0, 0, 0.78),
      0 0 14px rgba(239, 189, 114, 0.36) !important;

    animation:
      vv-star-twinkle 2.6s ease-in-out infinite,
      vv-mobile-extra-star-float 5.2s ease-in-out infinite !important;

    pointer-events: none;
  }

  @keyframes vv-mobile-extra-star-float {
    0%,
    100% {
      transform: translate3d(0, 0, 0) rotate(0deg);
    }

    50% {
      transform: translate3d(0.18rem, -0.14rem, 0) rotate(12deg);
    }
  }
}

@media (max-width: 390px) {
  .hero-mobile-curve-brand {
    top: calc(var(--site-header-height, 70px) - 0.18rem) !important;
    left: -1.48rem !important;

    width: 18.45rem !important;
    height: 14.25rem !important;
  }

  .hero-mobile-curve-brand text {
    font-size: 2.56rem !important;
  }

  .hero-kicker {
    left: 7.75rem !important;
    right: 0.65rem !important;
    bottom: calc(1.35rem + env(safe-area-inset-bottom, 0px)) !important;

    font-size: clamp(1.22rem, 6.1vw, 1.5rem) !important;
  }

  .hero-panel h1::after {
    top: calc(var(--site-header-height, 70px) + 0.58rem) !important;
    left: 0.95rem !important;
  }
}


/* =========================================================
   HOME MOBILE STAR + CAPTION TOP LAYER FIX
   Visible logo-area star + slideshow text above vignette/shadows
   ========================================================= */

@media (max-width: 760px) {
  /*
    Animated star in the top-left brand/logo area.
    Anchored to hero-content instead of the hidden h1.
  */
  .hero-content::after {
    content: "✦";

    position: fixed;
    top: calc(var(--site-header-height, 70px) + 0.7rem);
    left: 1.05rem;
    z-index: 120;

    display: grid;
    place-items: center;

    width: 1.3rem;
    height: 1.3rem;

    color: rgba(239, 189, 114, 0.98);

    font-family: var(--font-title);
    font-size: 1.14rem;
    line-height: 1;

    text-shadow:
      0 2px 5px rgba(0, 0, 0, 0.84),
      0 0 14px rgba(239, 189, 114, 0.42);

    animation:
      vv-star-twinkle 2.5s ease-in-out infinite,
      vv-mobile-logo-star-float 5.4s ease-in-out infinite;

    pointer-events: none;
  }

  @keyframes vv-mobile-logo-star-float {
    0%,
    100% {
      transform: translate3d(0, 0, 0) rotate(0deg) scale(1);
    }

    50% {
      transform: translate3d(0.18rem, -0.16rem, 0) rotate(12deg) scale(1.08);
    }
  }

  /*
    Put slideshow text above every vignette/shadow layer.
    Fixed positioning avoids it being trapped under slideshow overlays.
  */
  .hero .cover-slideshow__caption {
    display: block !important;

    position: fixed !important;
    left: 58% !important;
    right: auto !important;
    bottom: calc(10.85rem + env(safe-area-inset-bottom, 0px)) !important;
    z-index: 115 !important;

    width: min(52vw, 12.5rem) !important;
    padding: 0 !important;

    color: rgba(255, 250, 245, 0.98) !important;
    background: transparent !important;
    border: 0 !important;
    border-radius: 0 !important;
    box-shadow: none !important;

    text-align: center !important;

    opacity: 1 !important;
    transform: translateX(-50%) !important;

    backdrop-filter: none !important;
    -webkit-backdrop-filter: none !important;

    pointer-events: none;

    text-shadow:
      0 2px 4px rgba(0, 0, 0, 1),
      0 7px 16px rgba(0, 0, 0, 0.86),
      0 0 18px rgba(0, 0, 0, 0.72) !important;
  }

  .hero .cover-slideshow__caption::before {
    content: none !important;
  }

  .hero .cover-slideshow__eyebrow {
    margin: 0 0 0.18rem !important;

    color: rgba(239, 189, 114, 0.98) !important;

    font-family: "Bungee", var(--font-ancient), system-ui, sans-serif !important;
    font-size: 0.54rem !important;
    line-height: 1 !important;
    letter-spacing: 0.1em !important;
    text-align: center !important;
    text-transform: uppercase !important;

    text-shadow:
      0 2px 4px rgba(0, 0, 0, 1),
      0 0 12px rgba(0, 0, 0, 0.86) !important;
  }

  .hero .cover-slideshow__caption h2 {
    max-width: 100% !important;
    margin: 0 auto !important;

    color: rgba(255, 250, 245, 0.99) !important;

    font-family: "Bungee", var(--font-ancient), system-ui, sans-serif !important;
    font-size: clamp(0.82rem, 3.95vw, 1.05rem) !important;
    font-weight: 900 !important;
    line-height: 1.08 !important;
    letter-spacing: 0.005em !important;
    text-align: center !important;

    text-shadow:
      0 2px 4px rgba(0, 0, 0, 1),
      0 8px 18px rgba(0, 0, 0, 0.88),
      0 0 18px rgba(0, 0, 0, 0.78) !important;
  }

  .hero .cover-slideshow__description {
    display: none !important;
  }

  .hero .cover-slideshow__link {
    display: inline-block !important;

    margin-top: 0.3rem !important;

    color: rgba(211, 239, 178, 0.98) !important;

    font-family: var(--font-body) !important;
    font-size: 0.64rem !important;
    font-weight: 950 !important;
    line-height: 1.1 !important;
    text-align: center !important;

    pointer-events: auto;

    text-shadow:
      0 2px 4px rgba(0, 0, 0, 1),
      0 0 12px rgba(0, 0, 0, 0.86) !important;
  }
}

@media (max-width: 390px) {
  .hero-content::after {
    top: calc(var(--site-header-height, 70px) + 0.58rem);
    left: 0.86rem;

    font-size: 1.04rem;
  }

  .hero .cover-slideshow__caption {
    left: 59% !important;
    bottom: calc(10.45rem + env(safe-area-inset-bottom, 0px)) !important;

    width: min(51vw, 11.7rem) !important;
  }

  .hero .cover-slideshow__caption h2 {
    font-size: clamp(0.74rem, 3.6vw, 0.92rem) !important;
  }

  .hero .cover-slideshow__link {
    font-size: 0.6rem !important;
  }
}


/* =========================================================
   HOME MOBILE DETACHED SLIDE CAPTION
   New caption layer outside slideshow shadows and vignettes
   ========================================================= */

@media (min-width: 761px) {
  .hero-mobile-slide-copy {
    display: none !important;
  }
}

@media (max-width: 760px) {
  /*
    Hide the original mobile slideshow caption.
    It lives inside the slideshow/vignette stack, so it gets swallowed.
  */
  .hero .cover-slideshow__caption {
    display: none !important;
  }

  /*
    New clean mobile caption layer.
    Sits above the three leather tabs and outside the slideshow overlays.
  */
  .hero-mobile-slide-copy {
    position: absolute !important;
    left: 0.85rem !important;
    right: 0.85rem !important;
    bottom: calc(11.35rem + env(safe-area-inset-bottom, 0px)) !important;
    z-index: 80 !important;

    display: grid !important;
    gap: 0.22rem !important;

    width: auto !important;
    margin: 0 !important;
    padding: 0 !important;

    color: rgba(255, 250, 245, 0.98) !important;

    pointer-events: none;

    text-shadow:
      0 2px 4px rgba(0, 0, 0, 1),
      0 7px 16px rgba(0, 0, 0, 0.86),
      0 0 18px rgba(0, 0, 0, 0.76) !important;
  }

  .hero-mobile-slide-tag {
    margin: 0 !important;

    color: rgba(239, 189, 114, 0.98) !important;

    font-family: "Bungee", var(--font-ancient), system-ui, sans-serif !important;
    font-size: 0.58rem !important;
    font-weight: 900 !important;
    line-height: 1 !important;
    letter-spacing: 0.1em !important;
    text-align: right !important;
    text-transform: uppercase !important;
  }

  .hero-mobile-slide-copy h2 {
    max-width: 100% !important;
    margin: 0 auto !important;

    color: rgba(255, 250, 245, 0.99) !important;

    font-family: "Bungee", var(--font-ancient), system-ui, sans-serif !important;
    font-size: clamp(0.92rem, 4.25vw, 1.18rem) !important;
    font-weight: 900 !important;
    line-height: 1.06 !important;
    letter-spacing: 0.005em !important;
    text-align: center !important;
  }

  .hero-mobile-slide-description {
    margin: 0.16rem 0 0 !important;

    color: rgba(255, 250, 245, 0.95) !important;

    font-family: var(--font-body) !important;
    font-size: clamp(0.72rem, 3.25vw, 0.84rem) !important;
    font-weight: 850 !important;
    line-height: 1.28 !important;
    text-align: justify !important;
    text-align-last: left !important;
  }

  .hero-mobile-slide-copy a {
    justify-self: end !important;

    margin-top: 0.18rem !important;

    color: rgba(211, 239, 178, 0.98) !important;

    font-family: var(--font-body) !important;
    font-size: 0.72rem !important;
    font-weight: 950 !important;
    line-height: 1.1 !important;
    text-align: right !important;
    text-decoration: none !important;

    pointer-events: auto;

    border-bottom: 1px solid rgba(211, 239, 178, 0.44);
  }

  .hero-mobile-slide-copy a:hover,
  .hero-mobile-slide-copy a:focus-visible {
    color: #f6ffd8 !important;
    border-bottom-color: rgba(246, 255, 216, 0.9);
  }

  /*
    Make room for the detached caption above the tabs.
  */
  .hero-bottom-fade {
    height: 13.8rem !important;

    background: linear-gradient(
      to top,
      rgba(15, 10, 7, 0.92),
      rgba(15, 10, 7, 0.62) 44%,
      rgba(15, 10, 7, 0.2) 72%,
      transparent
    ) !important;
  }
}

@media (max-width: 390px) {
  .hero-mobile-slide-copy {
    left: 0.78rem !important;
    right: 0.78rem !important;
    bottom: calc(10.95rem + env(safe-area-inset-bottom, 0px)) !important;
  }

  .hero-mobile-slide-tag {
    font-size: 0.52rem !important;
  }

  .hero-mobile-slide-copy h2 {
    font-size: clamp(0.82rem, 4vw, 1rem) !important;
  }

  .hero-mobile-slide-description {
    font-size: clamp(0.66rem, 3.05vw, 0.76rem) !important;
  }

  .hero-mobile-slide-copy a {
    font-size: 0.66rem !important;
  }
}


/* =========================================================
   HOME MOBILE DETACHED CAPTION VISIBILITY FIX
   Keeps detached caption above vignette and visible when populated
   ========================================================= */

@media (max-width: 760px) {
  .hero-mobile-slide-copy[hidden] {
    display: none !important;
  }

  .hero-mobile-slide-copy:not([hidden]) {
    display: grid !important;
  }

  .hero-mobile-slide-copy {
    position: absolute !important;
    left: 8.05rem !important;
    right: 0.85rem !important;
    bottom: calc(8.3rem + env(safe-area-inset-bottom, 0px)) !important;
    z-index: 140 !important;

    gap: 0.22rem !important;

    color: rgba(255, 250, 245, 0.98) !important;
    text-shadow:
      0 2px 4px rgba(0, 0, 0, 1),
      0 7px 16px rgba(0, 0, 0, 0.88),
      0 0 18px rgba(0, 0, 0, 0.78) !important;

    pointer-events: none;
  }

  .hero-mobile-slide-tag {
    text-align: right !important;
  }

  .hero-mobile-slide-copy h2 {
    text-align: center !important;
  }

  .hero-mobile-slide-description {
    text-align: justify !important;
    text-align-last: left !important;
  }

  .hero-mobile-slide-copy a {
    justify-self: end !important;
    text-align: right !important;
    pointer-events: auto;
  }
}

@media (max-width: 390px) {
  .hero-mobile-slide-copy {
    left: 7.8rem !important;
    right: 0.7rem !important;
    bottom: calc(8rem + env(safe-area-inset-bottom, 0px)) !important;
  }
}
