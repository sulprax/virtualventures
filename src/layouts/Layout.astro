---
import "../styles/global.css";
import Footer from "../components/site/Footer.astro";

const {
  title = "Virtual Ventures",
  description = "A cozy craft workshop for crochet creatures, fantasy-inspired makes, laser engraved details, 3D printed helpers, patterns, stories, and small handmade treasures.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />

    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <link rel="icon" href="/favicon.ico?v=3" sizes="any" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=3" />
    <link rel="icon" type="image/png" sizes="32x32" href="/icons/favicon-32x32.png?v=3" />
    <link rel="icon" type="image/png" sizes="16x16" href="/icons/favicon-16x16.png?v=3" />
    <link rel="apple-touch-icon" sizes="180x180" href="/icons/apple-touch-icon.png?v=3" />
    <link rel="manifest" href="/icons/site.webmanifest?v=3" />

    <title>{title}</title>
  </head>

  <body>
    <slot />
    <Footer />
  </body>
</html>