---
import "../styles/global.css";
import "../styles/mobile.css";
import Header from "../components/site/Header.astro";
import Footer from "../components/site/Footer.astro";
import Breadcrumbs from "../components/site/Breadcrumbs.astro";

type BreadcrumbItem = {
  label: string;
  href?: string;
};

const {
  title = "Virtual Ventures",
  description = "A cozy craft workshop for crochet creatures, fantasy-inspired makes, laser engraved details, 3D printed helpers, patterns, stories, and small handmade treasures.",
  showHeader = true,
  headerMode = "sticky",
  showFooterBreadcrumbs = true,
  footerBreadcrumbs = [],
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />

    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <link rel="icon" type="image/svg+xml" href="/vv-mark/mark.svg?v=6000" />
    <link
      rel="icon"
      type="image/png"
      sizes="32x32"
      href="/vv-mark/mark-32.png?v=6000"
    />
    <link
      rel="icon"
      type="image/png"
      sizes="16x16"
      href="/vv-mark/mark-16.png?v=6000"
    />
    <link rel="shortcut icon" href="/vv-mark/mark.ico?v=6000" />
    <link
      rel="apple-touch-icon"
      sizes="180x180"
      href="/vv-mark/apple-touch.png?v=6000"
    />
    <link rel="manifest" href="/vv-mark/manifest.json?v=6000" />
    <meta name="theme-color" content="#140f0a" />

    <title>{title}</title>
  </head>

  <body>
    <div id="top"></div>

    {showHeader && <Header mode={headerMode} />}

    <slot />

    <a href="#top" class="back-to-top-button" aria-label="Back to top"> ↑ </a>

    {
      showFooterBreadcrumbs && footerBreadcrumbs.length > 0 && (
        <div class="footer-breadcrumb-wrap">
          <Breadcrumbs items={footerBreadcrumbs} />
        </div>
      )
    }

    <Footer />

    <script>
      const backToTopButton = document.querySelector(".back-to-top-button");
      const footer = document.querySelector(".site-footer");

      function updateFloatingControls() {
        const scrollY = window.scrollY;
        const shouldShow = scrollY > 180;

        if (!(backToTopButton instanceof HTMLElement)) return;

        backToTopButton.classList.toggle("is-visible", shouldShow);

        if (!(footer instanceof HTMLElement)) return;

        const windowHeight = window.innerHeight;
        const buttonGap = 24;
        const footerTop = footer.offsetTop;
        const buttonHeight = backToTopButton.offsetHeight;
        const buttonBottomPosition = scrollY + windowHeight - buttonGap;

        if (buttonBottomPosition + buttonHeight >= footerTop) {
          backToTopButton.classList.add("is-above-footer");
          backToTopButton.style.top = `${footerTop - buttonHeight - buttonGap}px`;
          backToTopButton.style.bottom = "auto";
        } else {
          backToTopButton.classList.remove("is-above-footer");
          backToTopButton.style.top = "auto";
          backToTopButton.style.bottom = "1.25rem";
        }
      }

      window.addEventListener("scroll", updateFloatingControls);
      window.addEventListener("resize", updateFloatingControls);

      updateFloatingControls();
    </script>
  </body>
</html>
