---
import Layout from "../../layouts/Layout.astro";
import PageHero from "../../components/page/PageHero.astro";
---

<Layout
  title="Report a Copy | Virtual Ventures"
  description="How to report suspicious copies, stolen pattern files, copied photos or confusing Virtual Ventures listings."
  showFooterBreadcrumbs={false}
>
  <PageHero
    eyebrow="Copyright Help"
    title="Report a Copy"
    description="Found a suspicious Virtual Ventures pattern, PDF, photo, QR code or listing? This page explains what to send."
  />

  <main class="page-shell">
    <section class="page-intro">
      <p class="eyebrow">Report a concern</p>
      <h1>Spot a suspicious copy?</h1>
      <p>
        Pattern theft and confusing copied downloads make it harder for makers to
        find the real source. Reports help keep the official trail clear.
      </p>
    </section>

    <section class="content-section content-left">
      <article class="content-card">
        <h2>What to report</h2>
        <p>
          You can report copied Virtual Ventures pattern text, copied PDFs,
          copied photos, changed QR codes, fake verification pages, marketplace
          listings using Virtual Ventures images, or downloads pretending to be
          official.
        </p>
      </article>
    </section>

    <section class="content-section content-right">
      <article class="content-card">
        <h2>Helpful details to include</h2>
        <p>
          Please include the link, platform name, seller or account name,
          screenshots if possible, date found, pattern name or pattern ID, and a
          short note explaining why it looks suspicious.
        </p>
        <p>
          Contact email placeholder: [contact email]. A future report form can
          be added here once the form provider, storage and privacy notice are
          confirmed.
        </p>
      </article>
    </section>

    <section class="content-section content-left">
      <article class="content-card">
        <h2>What happens next</h2>
        <p>
          Virtual Ventures can review the report, compare it with the official
          pattern, save evidence where needed, and decide whether to contact the
          platform or seller.
        </p>
        <p>
          Not every similar-looking crochet project is a copy. Reports are used
          to check carefully, not to start drama in the yarn basket.
        </p>
      </article>
    </section>

    <section class="content-closing-card">
      <p>
        Thank you for helping keep the official pattern trail tidy, honest and
        easy to follow.
      </p>
    </section>
  </main>
</Layout>
