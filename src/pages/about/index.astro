---
import Layout from "../../layouts/Layout.astro";
import PageHero from "../../components/page/PageHero.astro";
---

<Layout
  title="About | Virtual Ventures"
  description="Learn about Virtual Ventures, a cosy handmade workshop for crochet creatures, patterns, laser engraved details, 3D printed helpers and creative experiments."
  showFooterBreadcrumbs={false}
>
  <PageHero
    eyebrow="About"
    title="About Virtual Ventures"
    description="A cosy handmade workshop for crochet creatures, pattern ideas, laser engraved details, 3D printed helpers and creative chaos."
  />

  <main class="page-shell">
    <section class="page-intro">
      <p class="eyebrow">Hello from the workshop</p>
      <h1>Handmade with a little everyday magic</h1>
      <p>
        Virtual Ventures is where soft yarn, warm wood, careful details and
        slightly feral creative ideas become useful, giftable and story-filled things.
      </p>
    </section>
  </main>
</Layout>
