---
import Layout from "../../layouts/Layout.astro";
import PageHero from "../../components/page/PageHero.astro";
---

<Layout
  title="Contact | Virtual Ventures"
  description="Contact Virtual Ventures for crochet patterns, handmade projects, shop questions, custom ideas and workshop notes."
  showFooterBreadcrumbs={false}
>
  <PageHero
    eyebrow="Send a Note"
    title="Contact"
    description="Questions, pattern help, shop notes or creative sparks? Send a message into the workshop."
  />

  <main class="page-shell">
    <section class="page-intro">
      <p class="eyebrow">Say hello</p>
      <h1>Need a hand?</h1>
      <p>
        This page will hold the contact form, support links and the best ways to
        reach Virtual Ventures.
      </p>
    </section>
  </main>
</Layout>
