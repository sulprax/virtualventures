---
import Layout from "../../layouts/Layout.astro";
import PageHero from "../../components/page/PageHero.astro";
---

<Layout
  title="FAQ | Virtual Ventures"
  description="Frequently asked questions about Virtual Ventures patterns, handmade products, downloads, shipping, crochet help and shop updates."
  showFooterBreadcrumbs={false}
>
  <PageHero
    eyebrow="Quick Answers"
    title="FAQ"
    description="Quick answers for patterns, downloads, handmade items, shop bits and workshop questions."
  />

  <main class="page-shell">
    <section class="page-intro">
      <p class="eyebrow">Helpful notes</p>
      <h1>Frequently Asked Questions</h1>
      <p>A growing little shelf of answers for the things people ask most often.</p>
    </section>
  </main>
</Layout>
