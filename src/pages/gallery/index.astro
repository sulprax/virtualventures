---
import Layout from "../../layouts/Layout.astro";
---

<Layout
  title="Gallery | Virtual Ventures"
  description="A gallery of crochet creatures, handmade projects, laser engraved details, 3D printed helpers and creative experiments from Virtual Ventures."
  showFooterBreadcrumbs={false}
>
  <section class="blog-hero-banner page-hero-banner">
    <div class="blog-hero-banner-inner">
      <p class="eyebrow">Gallery</p>
      <h1>Gallery</h1>
      <p>
        A cosy lookbook of crochet creatures, handmade details, laser engraved
        pieces, 3D printed helpers and workshop experiments.
      </p>
    </div>
  </section>

  <main class="page-shell">
    <section class="page-intro">
      <p class="eyebrow">Project peeks</p>
      <h1>Made, tested and photographed</h1>
      <p>
        This will become the visual home for finished makes, behind-the-scenes
        shots and tiny handmade treasures.
      </p>
    </section>
  </main>
</Layout>