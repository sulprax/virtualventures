---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import PageHero from "../../components/page/PageHero.astro";
import "../../styles/pages/gallery.css";

const posts = await getCollection("blog", ({ data }) => !data.draft);

const galleryItems = posts
  .flatMap((post) =>
    (post.data.images ?? [])
      .filter((item) => item.gallery !== false)
      .map((item) => ({
        ...item,
        mediaType: item.mediaType ?? "image",
        poster: item.poster ?? item.src,
        shape: item.shape ?? "square",
        category: item.category ?? "uncategorised",
        tags: item.tags ?? [],
        colours: item.colours ?? [],
        blogTitle: post.data.title,
        blogDescription: post.data.description,
        blogUrl: `/blog/${post.id.replace(/\.md$/, "")}/`,
        pubDate: post.data.pubDate,
        updatedDate: post.data.updatedDate ?? post.data.pubDate,
      })),
  )
  .sort((a, b) => b.pubDate.getTime() - a.pubDate.getTime());

const latestItems = galleryItems
  .filter((item) => item.latest !== false)
  .slice(0, 3);

const categories = [
  "all",
  ...new Set(galleryItems.map((item) => item.category)),
].sort((a, b) => {
  if (a === "all") return -1;
  if (b === "all") return 1;

  return a.localeCompare(b);
});

const colourCount = new Set(galleryItems.flatMap((item) => item.colours)).size;
const photoCount = galleryItems.filter(
  (item) => item.mediaType !== "video",
).length;
const videoCount = galleryItems.filter(
  (item) => item.mediaType === "video",
).length;

const mediaLabel = (mediaType: string) =>
  mediaType === "video" ? "video" : "photo";

const optionLabel = (value: string) => {
  if (value === "all") return "All";

  return value
    .split("-")
    .map((word) => word.charAt(0).toUpperCase() + word.slice(1))
    .join(" ");
};

const tagChoices = [
  ...new Set(galleryItems.flatMap((item) => item.tags)),
].sort((a, b) => a.localeCompare(b));

const colourChoices = [
  ...new Set(galleryItems.flatMap((item) => item.colours)),
].sort((a, b) => a.localeCompare(b));

const filterChoices = [
  { value: "all", label: "All" },
  { value: "media:image", label: "Photos" },
  { value: "media:video", label: "Videos" },
  ...categories
    .filter((category) => category !== "all")
    .map((category) => ({
      value: category,
      label: optionLabel(category),
    })),
  ...colourChoices.map((colour) => ({
    value: `colour:${colour}`,
    label: `Colour: ${optionLabel(colour)}`,
  })),
  ...tagChoices.map((tag) => ({
    value: `tag:${tag}`,
    label: `Tag: ${optionLabel(tag)}`,
  })),
];
---

<Layout
  title="Gallery | Virtual Ventures"
  description="A gallery of crochet creatures, handmade projects, laser engraved details, 3D printed helpers and creative experiments from Virtual Ventures."
  showFooterBreadcrumbs={false}
>
  <PageHero
    eyebrow="Handmade Showcase"
    title="Gallery"
    description="This is the visual home for finished makes, behind-the-scenes shots, experiments, product photos and tiny handmade treasures."
  />

  <main class="gallery-page">
    {
      latestItems.length > 0 && (
        <section class="gallery-latest" aria-labelledby="latest-gallery-title">
          <div class="gallery-section-heading">
            <h2 id="latest-gallery-title">Latest photos & videos</h2>

            <p class="gallery-mobile-latest-note">
              {latestItems[0]?.mediaType === "video"
                ? "1 recently uploaded video"
                : "1 recently uploaded photo"}
            </p>
          </div>

          <div class="gallery-latest-grid">
            {latestItems.map((item) => (
              <article class="gallery-latest-card">
                <button
                  class="gallery-latest-button"
                  type="button"
                  data-gallery-open
                  data-title={item.title}
                  data-description={item.description}
                  data-image={item.src}
                  data-video-src={item.videoSrc ?? ""}
                  data-poster={item.poster ?? item.src}
                  data-media-type={item.mediaType}
                  data-alt={item.alt}
                  data-category={item.category}
                  data-tags={item.tags.join(", ")}
                  data-colours={item.colours.join(", ")}
                  data-blog-url={item.blogUrl}
                  data-blog-title={item.blogTitle}
                  data-blog-description={item.blogDescription}
                >
                  <span class="gallery-media-wrap">
                    {item.mediaType === "video" && item.videoSrc ? (
                      <>
                        <video
                          src={item.videoSrc}
                          poster={item.poster ?? item.src}
                          muted
                          playsinline
                          preload="metadata"
                          data-gallery-preview-video
                          data-autoplay-preview={String(item.autoplayPreview)}
                        />
                        <span class="gallery-media-badge">
                          ▶ {item.duration ?? "Video"}
                        </span>
                      </>
                    ) : (
                      <img src={item.src} alt={item.alt} loading="lazy" />
                    )}
                  </span>

                  <div class="gallery-latest-content">
                    <p class="gallery-card-category">
                      {item.category} · {mediaLabel(item.mediaType)}
                    </p>
                    <h3>{item.title}</h3>
                  </div>
                </button>
              </article>
            ))}
          </div>
        </section>
      )
    }

    <div
      class="gallery-layout has-mobile-side-drawer"
      data-mobile-side-drawer-root
    >
      <button
        class="mobile-side-drawer-toggle"
        type="button"
        aria-label="Open gallery tools"
        aria-controls="gallery-side-drawer"
        aria-expanded="false"
        data-mobile-side-toggle
        data-open-label="Gallery Tools"
        data-close-label="Close"
      >
        Gallery Tools
      </button>

      <button
        class="mobile-side-drawer-backdrop"
        type="button"
        aria-label="Close gallery tools"
        hidden
        data-mobile-side-backdrop></button>

      <aside
        id="gallery-side-drawer"
        class="gallery-controls gallery-tools-drawer mobile-side-drawer"
        aria-label="Gallery tools"
        data-mobile-side-drawer
      >
        <section class="blog-widget gallery-tool-widget gallery-sort-widget">
          <h2>Sort Gallery</h2>

          <label>
            <span>Sort</span>

            <select id="gallery-sort">
              <option value="newest">Newest first</option>
              <option value="oldest">Oldest first</option>
              <option value="title">Title A to Z</option>
              <option value="title-desc">Title Z to A</option>
              <option value="type">Type</option>
              <option value="media">Photos first</option>
              <option value="shape">Shape</option>
              <option value="colour">Colour</option>
              <option value="modified">Recently modified</option>
            </select>

            <div class="gallery-choice-list" aria-label="Desktop gallery sort choices">
              <button type="button" data-gallery-sort-choice="newest">
                Newest first
              </button>
              <button type="button" data-gallery-sort-choice="oldest">
                Oldest first
              </button>
              <button type="button" data-gallery-sort-choice="title">
                Title A to Z
              </button>
              <button type="button" data-gallery-sort-choice="title-desc">
                Title Z to A
              </button>
              <button type="button" data-gallery-sort-choice="type">
                Type
              </button>
              <button type="button" data-gallery-sort-choice="media">
                Photos first
              </button>
              <button type="button" data-gallery-sort-choice="shape">
                Shape
              </button>
              <button type="button" data-gallery-sort-choice="colour">
                Colour
              </button>
              <button type="button" data-gallery-sort-choice="modified">
                Recently modified
              </button>
            </div>
          </label>
        </section>

        <section class="blog-widget gallery-tool-widget gallery-filter-widget">
          <h2>Filter Gallery</h2>

          <label>
            <span>Filter</span>

            <select id="gallery-filter">
              {
                filterChoices.map((choice) => (
                  <option value={choice.value}>{choice.label}</option>
                ))
              }
            </select>

            <div class="gallery-choice-list" aria-label="Desktop gallery filter choices">
              {
                filterChoices.map((choice) => (
                  <button type="button" data-gallery-filter-choice={choice.value}>
                    {choice.label}
                  </button>
                ))
              }
            </div>
          </label>
        </section>

        <section class="blog-widget gallery-helper-widget gallery-stats-widget">
          <h2>Gallery Snapshot</h2>

          <div class="gallery-stat-grid" aria-label="Gallery snapshot">
            <span>
              <strong>{galleryItems.length}</strong>
              <small>Items</small>
            </span>

            <span>
              <strong>{photoCount}</strong>
              <small>Photos</small>
            </span>

            <span>
              <strong>{videoCount}</strong>
              <small>Videos</small>
            </span>

            <span>
              <strong>{colourCount}</strong>
              <small>Colours</small>
            </span>
          </div>

          <p class="gallery-result-note">
            Showing{" "}
            <strong data-gallery-result-count>{galleryItems.length}</strong>{" "}
            item{galleryItems.length === 1 ? "" : "s"} right now.
          </p>
        </section>

        <section class="blog-widget gallery-helper-widget gallery-action-widget">
          <h2>Quick Reset</h2>

          <p>
            Lost in the scrapbook? Reset the view back to all photos and newest
            first.
          </p>

          <button type="button" class="gallery-reset-button" data-gallery-reset>
            ✦ Reset gallery view
          </button>
        </section>

        <section class="blog-widget gallery-helper-widget gallery-tip-widget">
          <h2>Viewing Tip</h2>

          <p>
            Tap a photo to open the cosy lightbox with tags, colours, blog links,
            likes and sharing.
          </p>
        </section>
      </aside>

      <span class="mobile-side-drawer-frame" aria-hidden="true"></span>

      <section class="gallery-grid" aria-label="Gallery photos and videos">
        {
          galleryItems.map((item) => (
            <article
              class:list={["gallery-card", `gallery-card--${item.shape}`]}
              data-category={item.category}
              data-colours={item.colours.join(",")}
              data-tags={item.tags.join(",")}
              data-title={item.title}
              data-media-type={item.mediaType}
              data-shape={item.shape}
              data-date={item.pubDate.toISOString()}
              data-modified={item.updatedDate.toISOString()}
            >
              <button
                class="gallery-card-button"
                type="button"
                data-gallery-open
                data-title={item.title}
                data-description={item.description}
                data-image={item.src}
                data-video-src={item.videoSrc ?? ""}
                data-poster={item.poster ?? item.src}
                data-media-type={item.mediaType}
                data-alt={item.alt}
                data-category={item.category}
                data-tags={item.tags.join(", ")}
                data-colours={item.colours.join(", ")}
                data-blog-url={item.blogUrl}
                data-blog-title={item.blogTitle}
                data-blog-description={item.blogDescription}
              >
                <span class="gallery-media-wrap">
                  {item.mediaType === "video" && item.videoSrc ? (
                    <>
                      <video
                        src={item.videoSrc}
                        poster={item.poster ?? item.src}
                        muted
                        playsinline
                        preload="metadata"
                        data-gallery-preview-video
                        data-autoplay-preview={String(item.autoplayPreview)}
                      />
                      <span class="gallery-media-badge">
                        ▶ {item.duration ?? "Video"}
                      </span>
                    </>
                  ) : (
                    <img src={item.src} alt={item.alt} loading="lazy" />
                  )}
                </span>

                <span class="gallery-card-glow" aria-hidden="true" />

                <span class="gallery-like-pill" data-like-pill>
                  <span data-like-heart>♡</span>
                  <span data-like-count>0</span>
                </span>
              </button>
            </article>
          ))
        }
      </section>
    </div>
  </main>

  <div class="gallery-lightbox" data-gallery-lightbox hidden>
    <div class="gallery-lightbox-backdrop" data-gallery-close></div>

    <article
      class="gallery-lightbox-panel"
      role="dialog"
      aria-modal="true"
      aria-labelledby="gallery-lightbox-title"
    >
      <button
        class="gallery-lightbox-close"
        type="button"
        data-gallery-close
        aria-label="Close gallery media"
      >
        ×
      </button>

      <button
        class="gallery-lightbox-arrow gallery-lightbox-arrow--left"
        type="button"
        data-gallery-prev
        aria-label="Previous gallery item"
      >
        ‹
      </button>

      <div class="gallery-lightbox-image-wrap">
        <img data-gallery-lightbox-image src="" alt="" />
        <video data-gallery-lightbox-video controls playsinline hidden></video>
      </div>

      <div class="gallery-lightbox-content">
        <div class="gallery-lightbox-meta-row">
          <p class="gallery-card-category" data-gallery-lightbox-category></p>

          <div class="gallery-lightbox-icon-actions">
            <button
              class="gallery-lightbox-like"
              type="button"
              data-gallery-lightbox-like
              aria-label="Like this gallery item"
            >
              ♡
            </button>

            <button
              class="gallery-lightbox-share"
              type="button"
              data-gallery-lightbox-share
              aria-label="Share this gallery item"
            >
              ↗
            </button>
          </div>
        </div>

        <section class="gallery-lightbox-index-card gallery-lightbox-title-card">
          <h2 id="gallery-lightbox-title" data-gallery-lightbox-title></h2>

          <div class="gallery-lightbox-detail-block">
            <h3>Description</h3>

            <p class="gallery-lightbox-description-line">
              <span data-gallery-lightbox-description></span>
              <a class="gallery-lightbox-link" data-gallery-lightbox-blog href="#">
                Continue reading
              </a>
            </p>
          </div>
        </section>

        <section class="gallery-lightbox-index-card gallery-lightbox-tags-card">
          <div class="gallery-lightbox-detail-block">
            <h3 class="gallery-tags-heading">Tags</h3>
            <div class="gallery-tags" data-gallery-lightbox-tags></div>
          </div>

          <div class="gallery-lightbox-detail-block">
            <h3 class="gallery-colours-heading">Colours</h3>
            <div class="gallery-tags" data-gallery-lightbox-colours></div>
          </div>
        </section>
      </div>

      <button
        class="gallery-lightbox-arrow gallery-lightbox-arrow--right"
        type="button"
        data-gallery-next
        aria-label="Next gallery item"
      >
        ›
      </button>
    </article>
  </div>

  <script>
    const filter = document.querySelector<HTMLSelectElement>("#gallery-filter");
    const sort = document.querySelector<HTMLSelectElement>("#gallery-sort");
    const grid = document.querySelector<HTMLElement>(".gallery-grid");
    const resetButton = document.querySelector<HTMLButtonElement>(
      "[data-gallery-reset]",
    );
    const resultCount = document.querySelector<HTMLElement>(
      "[data-gallery-result-count]",
    );
    const sortChoiceButtons = Array.from(
      document.querySelectorAll<HTMLButtonElement>("[data-gallery-sort-choice]"),
    );
    const filterChoiceButtons = Array.from(
      document.querySelectorAll<HTMLButtonElement>("[data-gallery-filter-choice]"),
    );

    const lightbox = document.querySelector<HTMLElement>(
      "[data-gallery-lightbox]",
    );
    const lightboxImage = document.querySelector<HTMLImageElement>(
      "[data-gallery-lightbox-image]",
    );
    const lightboxVideo = document.querySelector<HTMLVideoElement>(
      "[data-gallery-lightbox-video]",
    );
    const lightboxTitle = document.querySelector<HTMLElement>(
      "[data-gallery-lightbox-title]",
    );
    const lightboxDescription = document.querySelector<HTMLElement>(
      "[data-gallery-lightbox-description]",
    );
    const lightboxCategory = document.querySelector<HTMLElement>(
      "[data-gallery-lightbox-category]",
    );
    const lightboxTags = document.querySelector<HTMLElement>(
      "[data-gallery-lightbox-tags]",
    );
    const lightboxColours = document.querySelector<HTMLElement>(
      "[data-gallery-lightbox-colours]",
    );
    const lightboxBlog = document.querySelector<HTMLAnchorElement>(
      "[data-gallery-lightbox-blog]",
    );
    const lightboxLike = document.querySelector<HTMLButtonElement>(
      "[data-gallery-lightbox-like]",
    );
    const lightboxShare = document.querySelector<HTMLButtonElement>(
      "[data-gallery-lightbox-share]",
    );

    let activeIndex = 0;

    function getCards() {
      return Array.from(
        document.querySelectorAll<HTMLElement>(".gallery-card"),
      );
    }

    function getOpenButtons() {
      return Array.from(
        document.querySelectorAll<HTMLButtonElement>("[data-gallery-open]"),
      );
    }

    function getVisibleButtons() {
      return getCards()
        .filter((card) => !card.hidden)
        .map((card) =>
          card.querySelector<HTMLButtonElement>("[data-gallery-open]"),
        )
        .filter((button): button is HTMLButtonElement => Boolean(button));
    }

    function getButtonKey(button: HTMLButtonElement) {
      return `${button.dataset.image ?? ""}::${button.dataset.title ?? ""}`;
    }

    function getNumberDate(card: HTMLElement, key: "date" | "modified") {
      const value = card.dataset[key];

      return value ? new Date(value).getTime() : 0;
    }

    function getLikeKey(button: HTMLButtonElement) {
      return `vv-gallery-liked:${
        button.dataset.image ?? button.dataset.title ?? "unknown"
      }`;
    }

    function isLiked(button: HTMLButtonElement) {
      return localStorage.getItem(getLikeKey(button)) === "true";
    }

    function setLiked(button: HTMLButtonElement, liked: boolean) {
      localStorage.setItem(getLikeKey(button), String(liked));

      const card = button.closest<HTMLElement>(".gallery-card");
      const heartElement =
        card?.querySelector<HTMLElement>("[data-like-heart]");
      const countElement =
        card?.querySelector<HTMLElement>("[data-like-count]");
      const pillElement = card?.querySelector<HTMLElement>("[data-like-pill]");

      if (heartElement) {
        heartElement.textContent = liked ? "♥" : "♡";
      }

      if (countElement) {
        countElement.textContent = liked ? "1" : "0";
      }

      pillElement?.classList.toggle("is-liked", liked);

      if (lightboxLike) {
        lightboxLike.textContent = liked ? "♥" : "♡";
        lightboxLike.setAttribute(
          "aria-label",
          liked ? "Unlike this gallery item" : "Like this gallery item",
        );
        lightboxLike.classList.toggle("is-liked", liked);
      }
    }

    function hydrateLikes() {
      getOpenButtons().forEach((button) => {
        setLiked(button, isLiked(button));
      });
    }

    function syncGalleryChoiceButtons() {
      sortChoiceButtons.forEach((button) => {
        button.classList.toggle(
          "is-active",
          button.dataset.gallerySortChoice === sort?.value,
        );
      });

      filterChoiceButtons.forEach((button) => {
        button.classList.toggle(
          "is-active",
          button.dataset.galleryFilterChoice === filter?.value,
        );
      });
    }

    function fillTagList(
      container: HTMLElement | null,
      rawValue: string,
      emptyText: string,
    ) {
      if (!container) return;

      container.innerHTML = "";

      const items = rawValue
        .split(",")
        .map((item) => item.trim())
        .filter(Boolean)
        .slice(0, 3);

      if (items.length === 0) {
        const emptyElement = document.createElement("span");
        emptyElement.className = "gallery-empty-pill";
        emptyElement.textContent = emptyText;
        container.appendChild(emptyElement);
        return;
      }

      items.forEach((item) => {
        const tagElement = document.createElement("span");
        tagElement.textContent = item;
        container.appendChild(tagElement);
      });
    }

    function applyGalleryControls() {
      if (!filter || !sort || !grid) return;

      const selectedCategory = filter.value;
      const selectedSort = sort.value;
      const cards = getCards();

      cards.forEach((card) => {
        const cardTags = (card.dataset.tags ?? "")
          .split(",")
          .map((item) => item.trim())
          .filter(Boolean);
        const cardColours = (card.dataset.colours ?? "")
          .split(",")
          .map((item) => item.trim())
          .filter(Boolean);

        const matchesFilter =
          selectedCategory === "all" ||
          card.dataset.category === selectedCategory ||
          (selectedCategory.startsWith("tag:") &&
            cardTags.includes(selectedCategory.replace("tag:", ""))) ||
          (selectedCategory.startsWith("colour:") &&
            cardColours.includes(selectedCategory.replace("colour:", ""))) ||
          (selectedCategory.startsWith("media:") &&
            card.dataset.mediaType === selectedCategory.replace("media:", ""));

        card.hidden = !matchesFilter;
      });

      const sortedCards = cards.sort((a, b) => {
        if (selectedSort === "oldest") {
          return getNumberDate(a, "date") - getNumberDate(b, "date");
        }

        if (selectedSort === "modified") {
          return getNumberDate(b, "modified") - getNumberDate(a, "modified");
        }

        if (selectedSort === "title") {
          return (a.dataset.title ?? "").localeCompare(b.dataset.title ?? "");
        }

        if (selectedSort === "title-desc") {
          return (b.dataset.title ?? "").localeCompare(a.dataset.title ?? "");
        }

        if (selectedSort === "type") {
          return (a.dataset.category ?? "").localeCompare(
            b.dataset.category ?? "",
          );
        }

        if (selectedSort === "media") {
          return (a.dataset.mediaType ?? "image").localeCompare(
            b.dataset.mediaType ?? "image",
          );
        }

        if (selectedSort === "shape") {
          return (a.dataset.shape ?? "square").localeCompare(
            b.dataset.shape ?? "square",
          );
        }

        if (selectedSort === "colour") {
          return (a.dataset.colours ?? "").localeCompare(
            b.dataset.colours ?? "",
          );
        }

        return getNumberDate(b, "date") - getNumberDate(a, "date");
      });

      sortedCards.forEach((card) => grid.appendChild(card));

      if (resultCount) {
        const visibleCount = cards.filter((card) => !card.hidden).length;

        resultCount.textContent = String(visibleCount);
      }

      syncGalleryChoiceButtons();
    }

    function pausePreviewVideo(video: HTMLVideoElement) {
      video.pause();
      video.currentTime = 0;
    }

    function setupVideoPreviews() {
      const prefersReducedMotion = window.matchMedia(
        "(prefers-reduced-motion: reduce)",
      ).matches;

      if (prefersReducedMotion) return;

      document
        .querySelectorAll<HTMLVideoElement>("[data-gallery-preview-video]")
        .forEach((video) => {
          if (video.dataset.autoplayPreview !== "true") return;

          const cardButton = video.closest<HTMLButtonElement>(
            "[data-gallery-open]",
          );

          if (!cardButton) return;

          cardButton.addEventListener("mouseenter", () => {
            video.play().catch(() => {});
          });

          cardButton.addEventListener("mouseleave", () => {
            pausePreviewVideo(video);
          });

          cardButton.addEventListener("focus", () => {
            video.play().catch(() => {});
          });

          cardButton.addEventListener("blur", () => {
            pausePreviewVideo(video);
          });
        });
    }

    function stopLightboxVideo() {
      if (!lightboxVideo) return;

      lightboxVideo.pause();
      lightboxVideo.removeAttribute("src");
      lightboxVideo.removeAttribute("poster");
      lightboxVideo.load();
    }

    function openLightbox(index: number) {
      const buttons = getVisibleButtons();
      const button = buttons[index];

      if (
        !button ||
        !lightbox ||
        !lightboxImage ||
        !lightboxVideo ||
        !lightboxTitle ||
        !lightboxDescription ||
        !lightboxCategory ||
        !lightboxBlog
      ) {
        return;
      }

      activeIndex = index;

      stopLightboxVideo();

      const mediaType = button.dataset.mediaType ?? "image";
      const poster = button.dataset.poster ?? button.dataset.image ?? "";
      const videoSrc = button.dataset.videoSrc ?? "";

      if (mediaType === "video" && videoSrc) {
        lightboxImage.hidden = true;
        lightboxImage.src = "";
        lightboxImage.alt = "";

        lightboxVideo.hidden = false;
        lightboxVideo.src = videoSrc;
        lightboxVideo.poster = poster;
      } else {
        lightboxVideo.hidden = true;

        lightboxImage.hidden = false;
        lightboxImage.src = button.dataset.image ?? "";
        lightboxImage.alt = button.dataset.alt ?? "";
      }

      lightboxTitle.textContent = button.dataset.title ?? "Gallery item";
      lightboxCategory.textContent = button.dataset.category ?? "";

      lightboxDescription.textContent =
        button.dataset.description?.trim() ||
        "No description has been added yet. Future Sulprax can sprinkle words here later.";

      fillTagList(lightboxTags, button.dataset.tags ?? "", "No tags yet");
      fillTagList(
        lightboxColours,
        button.dataset.colours ?? "",
        "No colours yet",
      );

      lightboxBlog.href = button.dataset.blogUrl ?? "#";
      lightboxBlog.textContent = "Continue reading";

      setLiked(button, isLiked(button));

      lightbox.hidden = false;
      document.body.classList.add("gallery-lightbox-is-open");
      document.dispatchEvent(new CustomEvent("vv:close-mobile-side-drawers"));
    }

    function openLightboxForButton(button: HTMLButtonElement) {
      const visibleButtons = getVisibleButtons();
      const key = getButtonKey(button);
      const index = visibleButtons.findIndex(
        (visibleButton) => getButtonKey(visibleButton) === key,
      );

      openLightbox(index >= 0 ? index : 0);
    }

    function closeLightbox() {
      if (!lightbox) return;

      stopLightboxVideo();
      lightbox.hidden = true;
      document.body.classList.remove("gallery-lightbox-is-open");
    }

    function moveLightbox(direction: number) {
      const buttons = getVisibleButtons();
      if (buttons.length === 0) return;

      const nextIndex =
        (activeIndex + direction + buttons.length) % buttons.length;
      openLightbox(nextIndex);
    }

    function closeGalleryToolsDrawer() {
      document.dispatchEvent(new CustomEvent("vv:close-mobile-side-drawers"));
    }

    getOpenButtons().forEach((button) => {
      button.addEventListener("click", () => {
        openLightboxForButton(button);
      });
    });

    document.querySelectorAll("[data-gallery-close]").forEach((button) => {
      button.addEventListener("click", closeLightbox);
    });

    document
      .querySelector("[data-gallery-prev]")
      ?.addEventListener("click", () => {
        moveLightbox(-1);
      });

    document
      .querySelector("[data-gallery-next]")
      ?.addEventListener("click", () => {
        moveLightbox(1);
      });

    lightboxLike?.addEventListener("click", () => {
      const buttons = getVisibleButtons();
      const button = buttons[activeIndex];

      if (!button) return;

      setLiked(button, !isLiked(button));
    });

    lightboxShare?.addEventListener("click", async () => {
      const buttons = getVisibleButtons();
      const button = buttons[activeIndex];

      if (!button || !lightboxShare) return;

      const shareUrl = `${window.location.origin}${
        button.dataset.blogUrl ?? "/gallery/"
      }`;
      const shareTitle = button.dataset.title ?? "Virtual Ventures Gallery";

      try {
        if (navigator.share) {
          await navigator.share({
            title: shareTitle,
            text: button.dataset.description ?? "",
            url: shareUrl,
          });
          return;
        }

        await navigator.clipboard.writeText(shareUrl);
        lightboxShare.textContent = "✓";

        setTimeout(() => {
          lightboxShare.textContent = "↗";
        }, 1600);
      } catch {
        lightboxShare.textContent = "!";

        setTimeout(() => {
          lightboxShare.textContent = "↗";
        }, 1600);
      }
    });

    document.addEventListener("keydown", (event) => {
      if (!lightbox || lightbox.hidden) return;

      if (event.key === "Escape") {
        closeLightbox();
      }

      if (event.key === "ArrowLeft") {
        moveLightbox(-1);
      }

      if (event.key === "ArrowRight") {
        moveLightbox(1);
      }
    });

    filter?.addEventListener("change", () => {
      applyGalleryControls();
      closeGalleryToolsDrawer();
    });

    sort?.addEventListener("change", () => {
      applyGalleryControls();
      closeGalleryToolsDrawer();
    });

    sortChoiceButtons.forEach((button) => {
      button.addEventListener("click", () => {
        if (!sort) return;

        sort.value = button.dataset.gallerySortChoice ?? "newest";
        applyGalleryControls();
      });
    });

    filterChoiceButtons.forEach((button) => {
      button.addEventListener("click", () => {
        if (!filter) return;

        filter.value = button.dataset.galleryFilterChoice ?? "all";
        applyGalleryControls();
      });
    });

    resetButton?.addEventListener("click", () => {
      if (filter) filter.value = "all";
      if (sort) sort.value = "newest";

      applyGalleryControls();
      closeGalleryToolsDrawer();
    });

    applyGalleryControls();
    hydrateLikes();
    setupVideoPreviews();
  </script>
</Layout>
