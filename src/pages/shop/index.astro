---
import Layout from "../../layouts/Layout.astro";
---

<Layout
  title="Shop | Virtual Ventures"
  description="Shop Virtual Ventures crochet patterns, handmade gifts, laser engraved pieces, creative tools and cosy workshop treasures."
  showFooterBreadcrumbs={false}
>
  <section class="blog-hero-banner page-hero-banner">
    <div class="blog-hero-banner-inner">
      <p class="eyebrow">Shop</p>
      <h1>Shop</h1>
      <p>
        Patterns, handmade gifts, laser engraved pieces, creative tools and
        cosy workshop treasures.
      </p>
    </div>
  </section>

  <main class="page-shell shop-page">
    <section class="shop-hero">
      <p class="eyebrow">Workshop shelf</p>
      <h1>Handmade treasures and useful little things</h1>
      <p>
        The shop will grow slowly with patterns, planners, laser engraved pieces,
        crochet helpers and small creative tools.
      </p>
    </section>
  </main>
</Layout>