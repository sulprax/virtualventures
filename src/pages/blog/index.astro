---
import Layout from "../../layouts/Layout.astro";
import Breadcrumbs from "../../components/site/Breadcrumbs.astro";
import { getCollection, render } from "astro:content";

const categoryLabels: Record<string, string> = {
  crochet: "Crochet",
  laser: "Laser",
  "3d-printing": "3D Printing",
  "books-patterns": "Books / Patterns",
  shop: "Shop",
  website: "Website",
  "behind-the-scenes": "Behind the Scenes",
};

function formatISODate(date: Date) {
  const year = date.getFullYear();
  const month = String(date.getMonth() + 1).padStart(2, "0");
  const day = String(date.getDate()).padStart(2, "0");

  return `${year}-${month}-${day}`;
}

const rawPosts = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => {
    if (a.data.pinned && !b.data.pinned) return -1;
    if (!a.data.pinned && b.data.pinned) return 1;

    return b.data.pubDate.valueOf() - a.data.pubDate.valueOf();
  });

const posts = await Promise.all(
  rawPosts.map(async (post) => {
    const { Content } = await render(post);

    const categoryLabel =
      categoryLabels[post.data.category] ?? post.data.category;

    return {
      ...post,
      Content,
      categoryLabel,
      isoDate: formatISODate(post.data.pubDate),
      displayTags: [categoryLabel, ...post.data.tags.map((tag) => `#${tag}`)],
    };
  })
);

const topicCounts = new Map<string, { label: string; count: number }>();

rawPosts.forEach((post) => {
  const categoryLabel = categoryLabels[post.data.category] ?? post.data.category;

  topicCounts.set(post.data.category, {
    label: categoryLabel,
    count: (topicCounts.get(post.data.category)?.count ?? 0) + 1,
  });

  post.data.tags.forEach((tag) => {
    topicCounts.set(tag, {
      label: `#${tag}`,
      count: (topicCounts.get(tag)?.count ?? 0) + 1,
    });
  });
});

const topicFilters = [...topicCounts.entries()]
  .map(([id, topic]) => ({ id, ...topic }))
  .sort((a, b) => {
    if (b.count !== a.count) return b.count - a.count;

    return a.label.localeCompare(b.label);
  });

const latestPosts = rawPosts.slice(0, 4);

const archiveMonths = [
  ...new Map(
    rawPosts.map((post) => {
      const date = post.data.pubDate;
      const key = `${date.getFullYear()}-${String(date.getMonth() + 1).padStart(2, "0")}`;

      const count = rawPosts.filter((item) => {
        const itemDate = item.data.pubDate;

        return (
          itemDate.getFullYear() === date.getFullYear() &&
          itemDate.getMonth() === date.getMonth()
        );
      }).length;

      return [
        key,
        {
          label: date.toLocaleDateString("en-GB", {
            month: "long",
            year: "numeric",
          }),
          count,
        },
      ];
    })
  ).values(),
];

const calendarBaseDate = rawPosts[0]?.data.pubDate ?? new Date();
const postIndex = rawPosts.map((post) => ({
  id: post.id,
  title: post.data.title,
  isoDate: formatISODate(post.data.pubDate),
}));
---

<Layout
  title="The Blog | Virtual Ventures"
  description="Updates from the Virtual Ventures workshop, including crochet progress, pattern plans, laser engraving notes, 3D printed helpers, shop news, tutorials, videos and behind-the-scenes stories."
  footerBreadcrumbs={[
    { label: "Home", href: "/" },
    { label: "Blog" },
  ]}
>
    <section class="blog-hero-banner">
        <div class="blog-hero-banner-inner">
            <p class="eyebrow">Workshop Notes</p>
            <h1>The Blog</h1>
            <p>
            Project updates, pattern plans, videos, shop news and behind-the-scenes
            stories from the cosy handmade corner of Virtual Ventures.
            </p>
        </div>
    </section>

    <Breadcrumbs
    items={[
            { label: "Home", href: "/" },
            { label: "Blog" },
        ]}
    />

  <main class="page-shell blog-page">
    <button
      class="blog-tools-toggle"
      type="button"
      aria-label="Open blog tools"
      aria-controls="blog-tools-drawer"
      aria-expanded="false"
      data-blog-tools-toggle
    >
      ☰ Filters
    </button>

    <div class="blog-layout">
      <section class="blog-posts-area" aria-label="Blog posts">
        <div class="blog-grid" data-blog-grid>
          {posts.map((post) => (
            <article
              id={`post-${post.id}`}
              class:list={["blog-card", { "is-pinned": post.data.pinned }]}
              data-blog-card
              data-post-id={post.id}
              data-category={post.data.category}
              data-tags={post.data.tags.join(",")}
              data-date={post.isoDate}
            >
              <button class="blog-card-toggle" type="button" data-post-toggle>
                <span class="blog-card-topline">
                  <span class="blog-date">
                    {post.data.pubDate.toLocaleDateString("en-GB", {
                      day: "numeric",
                      month: "long",
                      year: "numeric",
                    })}
                  </span>

                  <span class="blog-card-top-tags">
                    {post.displayTags.map((tag) => (
                      <span>{tag}</span>
                    ))}
                  </span>
                </span>

                <span class="blog-card-title-row">
                  <span class="blog-card-emoji" aria-hidden="true">
                    {post.data.emoji}
                  </span>

                  {post.data.pinned && (
                    <span class="blog-pin-badge">
                      ✦ {post.data.pinLabel || "Pinned"}
                    </span>
                  )}
                </span>

                <span class="blog-card-title">{post.data.title}</span>

                <span class="blog-card-description">
                  {post.data.description}
                </span>

                <span class="blog-read-more" data-read-label>
                  Open post
                </span>
              </button>

              <div class="blog-card-expanded" hidden data-post-content>
                {post.data.image && (
                  <img
                    src={post.data.image}
                    alt=""
                    loading="lazy"
                    class="blog-card-image"
                  />
                )}

                <div class="blog-post-content blog-post-content-inline">
                  <post.Content />
                </div>

                <div class="blog-inline-actions">
                  {post.data.shopUrl && (
                    <a href={post.data.shopUrl} class="featured-shop-link">
                      View in shop
                    </a>
                  )}

                  <a href={`/blog/${post.id}/`} class="blog-full-link">
                    Open standalone post
                  </a>
                </div>
              </div>
            </article>
          ))}
        </div>

        <nav class="blog-pagination" data-blog-pagination aria-label="Blog pagination">
          <button type="button" class="blog-page-button" data-page-prev>‹</button>

          <div class="blog-page-numbers" data-page-numbers></div>

          <button type="button" class="blog-page-button" data-page-next>›</button>

          <form class="blog-page-jump" data-page-jump-form>
            <label for="blog-page-jump-input">Go to page</label>
            <input
              id="blog-page-jump-input"
              type="number"
              min="1"
              value="1"
              data-page-jump-input
            />
          </form>
        </nav>

        <p class="blog-empty-message" data-empty-message hidden>
          No posts found for this filter. Try ✨ All Posts.
        </p>
      </section>

      <aside
        id="blog-tools-drawer"
        class="blog-sidebar"
        aria-label="Blog sidebar"
        data-blog-tools
      >
        <div class="blog-tools-header">
          <strong>Blog Tools</strong>
          <button type="button" aria-label="Close blog tools" data-blog-tools-close>
            ×
          </button>
        </div>

        <section class="blog-widget blog-calendar-widget">
          <h2>Post Calendar</h2>

          <div
            class="blog-calendar"
            data-calendar
            data-calendar-year={calendarBaseDate.getFullYear()}
            data-calendar-month={calendarBaseDate.getMonth()}
            data-post-index={JSON.stringify(postIndex)}
          >
            <div class="blog-calendar-header">
              <button type="button" data-calendar-prev-year aria-label="Previous year">«</button>
              <button type="button" data-calendar-prev-month aria-label="Previous month">‹</button>
              <span data-calendar-label></span>
              <button type="button" data-calendar-next-month aria-label="Next month">›</button>
              <button type="button" data-calendar-next-year aria-label="Next year">»</button>
              <button type="button" data-clear-date-filter title="Show all dates" aria-label="Show all dates">
                ✦
              </button>
            </div>

            <div class="blog-calendar-grid" data-calendar-grid></div>

            <div class="blog-calendar-results" data-calendar-results aria-live="polite"></div>
          </div>
        </section>

        <section class="blog-widget">
          <h2>Filter Topics</h2>

          <div class="blog-filter-stack" data-blog-filters>
            <button type="button" class="blog-filter-chip is-active" data-filter="all">
              ✨ All Posts
            </button>

            {topicFilters.map((topic, index) => (
              <button
                type="button"
                class:list={["blog-filter-chip", { "is-mobile-extra": index >= 3 }]}
                data-filter={topic.id}
                data-topic-extra={index >= 3 ? "true" : undefined}
              >
                {topic.label}
              </button>
            ))}

            {topicFilters.length > 3 && (
              <button
                type="button"
                class="blog-filter-chip blog-filter-more"
                data-topic-more
                aria-expanded="false"
              >
                More topics
              </button>
            )}
          </div>
        </section>

        <section class="blog-widget">
          <h2>Archive</h2>

          <ul class="blog-mini-list">
            {archiveMonths.map((month) => (
              <li>
                <span>
                  <strong>{month.label}</strong>
                  <span>{month.count} post{month.count === 1 ? "" : "s"}</span>
                </span>
              </li>
            ))}
          </ul>
        </section>

        <section class="blog-widget featured-shop-widget">
          <p class="eyebrow">Featured</p>
          <h2>Crochet Planner</h2>
          <p>
            A cosy project planner for crochet and knitting notes, pattern ideas,
            yarn details and creative scribbles.
          </p>
          <a href="/shop/project-planner-crochet-knitting/" class="featured-shop-link">
            View in shop
          </a>
        </section>

        <section class="blog-widget">
          <h2>Latest Notes</h2>

          <ul class="blog-mini-list">
            {latestPosts.map((post) => (
              <li>
                <button type="button" data-jump-post={post.id}>
                  <strong>{post.data.title}</strong>
                  <span>
                    {post.data.pubDate.toLocaleDateString("en-GB", {
                      day: "numeric",
                      month: "short",
                      year: "numeric",
                    })}
                  </span>
                </button>
              </li>
            ))}
          </ul>
        </section>
      </aside>
    </div>
  </main>

  <script>
    // @ts-nocheck

    const cards = Array.from(document.querySelectorAll("[data-blog-card]"));
    const filterButtons = Array.from(document.querySelectorAll("[data-filter]"));
    let calendarButtons = [];
    const clearDateButton = document.querySelector("[data-clear-date-filter]");
    const jumpButtons = Array.from(document.querySelectorAll("[data-jump-post]"));
    const calendar = document.querySelector("[data-calendar]");
    const calendarLabel = document.querySelector("[data-calendar-label]");
    const calendarGrid = document.querySelector("[data-calendar-grid]");
    const calendarResults = document.querySelector("[data-calendar-results]");
    const calendarPrevMonth = document.querySelector("[data-calendar-prev-month]");
    const calendarNextMonth = document.querySelector("[data-calendar-next-month]");
    const calendarPrevYear = document.querySelector("[data-calendar-prev-year]");
    const calendarNextYear = document.querySelector("[data-calendar-next-year]");
    const blogTools = document.querySelector("[data-blog-tools]");
    const blogToolsToggle = document.querySelector("[data-blog-tools-toggle]");
    const blogToolsClose = document.querySelector("[data-blog-tools-close]");
    const topicMoreButton = document.querySelector("[data-topic-more]");
    const topicExtraButtons = Array.from(document.querySelectorAll("[data-topic-extra]"));

    const pagination = document.querySelector("[data-blog-pagination]");
    const pageNumbers = document.querySelector("[data-page-numbers]");
    const prevButton = document.querySelector("[data-page-prev]");
    const nextButton = document.querySelector("[data-page-next]");
    const jumpForm = document.querySelector("[data-page-jump-form]");
    const jumpInput = document.querySelector("[data-page-jump-input]");
    const emptyMessage = document.querySelector("[data-empty-message]");

    const postsPerPage = 8;
    const dayNames = ["M", "T", "W", "T", "F", "S", "S"];
    const postIndex = calendar?.dataset.postIndex
      ? JSON.parse(calendar.dataset.postIndex)
      : [];
    const postsByDate = postIndex.reduce((dates, post) => {
      dates[post.isoDate] = [...(dates[post.isoDate] || []), post];

      return dates;
    }, {});

    let activeFilter = "all";
    let activeDate = "all";
    let currentPage = 1;
    let calendarYear = Number(calendar?.dataset.calendarYear || new Date().getFullYear());
    let calendarMonth = Number(calendar?.dataset.calendarMonth || new Date().getMonth());

    function formatCalendarDate(year, month, day) {
      return [
        year,
        String(month + 1).padStart(2, "0"),
        String(day).padStart(2, "0"),
      ].join("-");
    }

    function updateBlogTools(open) {
      if (!(blogTools instanceof HTMLElement)) return;
      if (!(blogToolsToggle instanceof HTMLButtonElement)) return;

      blogTools.classList.toggle("is-open", open);
      blogToolsToggle.setAttribute("aria-expanded", String(open));
      blogToolsToggle.setAttribute("aria-label", open ? "Close blog tools" : "Open blog tools");
      document.body.classList.toggle("blog-tools-open", open);
    }

    function renderCalendarResults(date = activeDate) {
      if (!(calendarResults instanceof HTMLElement)) return;

      if (date === "all") {
        calendarResults.textContent = "Select a highlighted date to show posts.";
        return;
      }

      const dayPosts = postsByDate[date] || [];

      if (dayPosts.length === 0) {
        calendarResults.textContent = "No posts on this date.";
        return;
      }

      calendarResults.innerHTML = [
        `<strong>${dayPosts.length} post${dayPosts.length === 1 ? "" : "s"} on ${date}</strong>`,
        ...dayPosts.map((post) => `<span>${post.title}</span>`),
      ].join("");
    }

    function bindCalendarButtons() {
      calendarButtons = Array.from(document.querySelectorAll("[data-calendar-date]"));

      calendarButtons.forEach((button) => {
        if (!(button instanceof HTMLButtonElement)) return;

        button.addEventListener("click", () => {
          const selectedDate = button.dataset.calendarDate || "all";

          activeDate = activeDate === selectedDate ? "all" : selectedDate;
          currentPage = 1;

          calendarButtons.forEach((calendarButton) => {
            if (!(calendarButton instanceof HTMLButtonElement)) return;

            calendarButton.classList.toggle(
              "is-active",
              calendarButton.dataset.calendarDate === activeDate
            );
          });

          renderCalendarResults();
          applyBlogView();
        });
      });
    }

    function renderCalendar() {
      if (!(calendarGrid instanceof HTMLElement)) return;
      if (!(calendarLabel instanceof HTMLElement)) return;

      const labelDate = new Date(calendarYear, calendarMonth, 1);
      const daysInMonth = new Date(calendarYear, calendarMonth + 1, 0).getDate();
      const firstDay = new Date(calendarYear, calendarMonth, 1).getDay();
      const mondayOffset = firstDay === 0 ? 6 : firstDay - 1;

      calendarLabel.textContent = labelDate.toLocaleDateString("en-GB", {
        month: "long",
        year: "numeric",
      });

      calendarGrid.setAttribute("aria-label", `${calendarLabel.textContent} blog calendar`);
      calendarGrid.innerHTML = "";

      dayNames.forEach((day) => {
        const dayLabel = document.createElement("span");

        dayLabel.className = "blog-calendar-day";
        dayLabel.textContent = day;
        calendarGrid.appendChild(dayLabel);
      });

      Array.from({ length: mondayOffset }).forEach(() => {
        const emptyCell = document.createElement("span");

        emptyCell.className = "blog-calendar-empty";
        calendarGrid.appendChild(emptyCell);
      });

      Array.from({ length: daysInMonth }, (_, index) => index + 1).forEach((day) => {
        const isoDate = formatCalendarDate(calendarYear, calendarMonth, day);
        const dayPosts = postsByDate[isoDate] || [];
        const button = document.createElement("button");

        button.type = "button";
        button.className = "blog-calendar-date";
        button.textContent = String(day);
        button.dataset.calendarDate = isoDate;
        button.title = dayPosts.length
          ? `Show ${dayPosts.length} post${dayPosts.length === 1 ? "" : "s"} from ${isoDate}`
          : "No posts";
        button.disabled = dayPosts.length === 0;
        button.classList.toggle("has-post", dayPosts.length > 0);
        button.classList.toggle("is-active", activeDate === isoDate);

        calendarGrid.appendChild(button);
      });

      bindCalendarButtons();
      renderCalendarResults();
    }

    function closePost(card) {
      const content = card.querySelector("[data-post-content]");
      const label = card.querySelector("[data-read-label]");

      if (content instanceof HTMLElement) {
        content.hidden = true;
      }

      if (label instanceof HTMLElement) {
        label.textContent = "Open post";
      }

      card.classList.remove("is-open");
    }

    function closeOtherPosts(activeCard) {
      cards.forEach((card) => {
        if (card !== activeCard) {
          closePost(card);
        }
      });
    }

    function cardMatchesFilters(card) {
      const category = card.getAttribute("data-category") || "";
      const date = card.getAttribute("data-date") || "";

      const tags = (card.getAttribute("data-tags") || "")
        .split(",")
        .map((tag) => tag.trim())
        .filter(Boolean);

      const matchesTopic =
        activeFilter === "all" ||
        category === activeFilter ||
        tags.includes(activeFilter);

      const matchesDate = activeDate === "all" || date === activeDate;

      return matchesTopic && matchesDate;
    }

    function getFilteredCards() {
      return cards.filter((card) => cardMatchesFilters(card));
    }

    function renderPagination(totalPages) {
      if (!(pageNumbers instanceof HTMLElement)) return;
      if (!(pagination instanceof HTMLElement)) return;

      pageNumbers.innerHTML = "";
      pagination.hidden = totalPages <= 1;

      for (let page = 1; page <= totalPages; page += 1) {
        const button = document.createElement("button");

        button.type = "button";
        button.className = "blog-page-number";
        button.textContent = String(page);
        button.classList.toggle("is-active", page === currentPage);

        button.addEventListener("click", () => {
          currentPage = page;
          applyBlogView();
        });

        pageNumbers.appendChild(button);
      }

      if (prevButton instanceof HTMLButtonElement) {
        prevButton.disabled = currentPage <= 1;
      }

      if (nextButton instanceof HTMLButtonElement) {
        nextButton.disabled = currentPage >= totalPages;
      }

      if (jumpInput instanceof HTMLInputElement) {
        jumpInput.max = String(totalPages);
        jumpInput.value = String(currentPage);
      }
    }

    function applyBlogView() {
      const filteredCards = getFilteredCards();
      const totalPages = Math.max(1, Math.ceil(filteredCards.length / postsPerPage));

      currentPage = Math.min(Math.max(currentPage, 1), totalPages);

      cards.forEach((card) => {
        const isFiltered = filteredCards.includes(card);

        card.classList.toggle("is-hidden-by-filter", !isFiltered);
        card.classList.remove("is-page-hidden");

        if (!isFiltered) {
          closePost(card);
        }
      });

      filteredCards.forEach((card, index) => {
        const page = Math.floor(index / postsPerPage) + 1;
        const isOnCurrentPage = page === currentPage;

        card.classList.toggle("is-page-hidden", !isOnCurrentPage);

        if (!isOnCurrentPage) {
          closePost(card);
        }
      });

      if (emptyMessage instanceof HTMLElement) {
        emptyMessage.hidden = filteredCards.length > 0;
      }

      renderPagination(totalPages);
    }

    cards.forEach((card) => {
      const toggle = card.querySelector("[data-post-toggle]");
      const content = card.querySelector("[data-post-content]");
      const label = card.querySelector("[data-read-label]");

      if (!(toggle instanceof HTMLButtonElement)) return;
      if (!(content instanceof HTMLElement)) return;

      toggle.addEventListener("click", () => {
        const isOpening = content.hidden;

        closeOtherPosts(card);

        content.hidden = !isOpening;
        card.classList.toggle("is-open", isOpening);

        if (label instanceof HTMLElement) {
          label.textContent = isOpening ? "Close post" : "Open post";
        }
      });
    });

    filterButtons.forEach((button) => {
      if (!(button instanceof HTMLButtonElement)) return;

      button.addEventListener("click", () => {
        const selectedFilter = button.dataset.filter || "all";
        const isAlreadyActive = button.classList.contains("is-active");

        activeFilter =
          isAlreadyActive && selectedFilter !== "all" ? "all" : selectedFilter;

        currentPage = 1;

        filterButtons.forEach((filterButton) => {
          if (!(filterButton instanceof HTMLButtonElement)) return;

          filterButton.classList.toggle(
            "is-active",
            filterButton.dataset.filter === activeFilter
          );
        });

        if (!filterButtons.some((filterButton) => filterButton.classList.contains("is-active"))) {
          const allButton = document.querySelector('[data-filter="all"]');
          allButton?.classList.add("is-active");
        }

        applyBlogView();
      });
    });

    if (clearDateButton instanceof HTMLButtonElement) {
      clearDateButton.addEventListener("click", () => {
        activeDate = "all";
        currentPage = 1;

        calendarButtons.forEach((calendarButton) => {
          calendarButton.classList.remove("is-active");
        });

        renderCalendarResults();
        applyBlogView();
      });
    }

    if (calendarPrevMonth instanceof HTMLButtonElement) {
      calendarPrevMonth.addEventListener("click", () => {
        calendarMonth -= 1;

        if (calendarMonth < 0) {
          calendarMonth = 11;
          calendarYear -= 1;
        }

        renderCalendar();
      });
    }

    if (calendarNextMonth instanceof HTMLButtonElement) {
      calendarNextMonth.addEventListener("click", () => {
        calendarMonth += 1;

        if (calendarMonth > 11) {
          calendarMonth = 0;
          calendarYear += 1;
        }

        renderCalendar();
      });
    }

    if (calendarPrevYear instanceof HTMLButtonElement) {
      calendarPrevYear.addEventListener("click", () => {
        calendarYear -= 1;
        renderCalendar();
      });
    }

    if (calendarNextYear instanceof HTMLButtonElement) {
      calendarNextYear.addEventListener("click", () => {
        calendarYear += 1;
        renderCalendar();
      });
    }

    if (blogToolsToggle instanceof HTMLButtonElement) {
      blogToolsToggle.addEventListener("click", () => {
        const isOpen = blogTools instanceof HTMLElement && blogTools.classList.contains("is-open");

        updateBlogTools(!isOpen);
      });
    }

    if (blogToolsClose instanceof HTMLButtonElement) {
      blogToolsClose.addEventListener("click", () => {
        updateBlogTools(false);
      });
    }

    if (topicMoreButton instanceof HTMLButtonElement) {
      topicMoreButton.addEventListener("click", () => {
        const isExpanded = topicMoreButton.getAttribute("aria-expanded") === "true";

        topicMoreButton.setAttribute("aria-expanded", String(!isExpanded));
        topicMoreButton.textContent = isExpanded ? "More topics" : "Less topics";

        topicExtraButtons.forEach((button) => {
          button.classList.toggle("is-mobile-revealed", !isExpanded);
        });
      });
    }

    if (prevButton instanceof HTMLButtonElement) {
      prevButton.addEventListener("click", () => {
        currentPage -= 1;
        applyBlogView();
      });
    }

    if (nextButton instanceof HTMLButtonElement) {
      nextButton.addEventListener("click", () => {
        currentPage += 1;
        applyBlogView();
      });
    }

    if (jumpForm instanceof HTMLFormElement && jumpInput instanceof HTMLInputElement) {
      jumpForm.addEventListener("submit", (event) => {
        event.preventDefault();

        const requestedPage = Number(jumpInput.value);

        if (Number.isFinite(requestedPage)) {
          currentPage = requestedPage;
          applyBlogView();
        }
      });

      jumpInput.addEventListener("change", () => {
        const requestedPage = Number(jumpInput.value);

        if (Number.isFinite(requestedPage)) {
          currentPage = requestedPage;
          applyBlogView();
        }
      });
    }

    jumpButtons.forEach((button) => {
      if (!(button instanceof HTMLButtonElement)) return;

      button.addEventListener("click", () => {
        const id = button.dataset.jumpPost;
        if (!id) return;

        const card = document.querySelector(`[data-post-id="${id}"]`);

        if (card instanceof HTMLElement) {
          activeFilter = "all";
          activeDate = "all";
          currentPage = 1;

          filterButtons.forEach((filterButton) => {
            if (!(filterButton instanceof HTMLButtonElement)) return;

            filterButton.classList.toggle(
              "is-active",
              filterButton.dataset.filter === "all"
            );
          });

          calendarButtons.forEach((calendarButton) => {
            calendarButton.classList.remove("is-active");
          });

          renderCalendarResults();
          applyBlogView();

          setTimeout(() => {
            card.scrollIntoView({ behavior: "smooth", block: "center" });
          }, 50);
        }
      });
    });

    renderCalendar();
    applyBlogView();
  </script>

