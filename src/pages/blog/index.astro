---
import Layout from "../../layouts/Layout.astro";
import Breadcrumbs from "../../components/site/Breadcrumbs.astro";
import { getCollection, render } from "astro:content";

const categoryLabels: Record<string, string> = {
  crochet: "Crochet",
  laser: "Laser",
  "3d-printing": "3D Printing",
  "books-patterns": "Books / Patterns",
  shop: "Shop",
  website: "Website",
  "behind-the-scenes": "Behind the Scenes",
};

const categoryOrder = [
  "crochet",
  "laser",
  "3d-printing",
  "books-patterns",
  "shop",
  "website",
  "behind-the-scenes",
];

function formatISODate(date: Date) {
  const year = date.getFullYear();
  const month = String(date.getMonth() + 1).padStart(2, "0");
  const day = String(date.getDate()).padStart(2, "0");

  return `${year}-${month}-${day}`;
}

const rawPosts = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => {
    if (a.data.pinned && !b.data.pinned) return -1;
    if (!a.data.pinned && b.data.pinned) return 1;

    return b.data.pubDate.valueOf() - a.data.pubDate.valueOf();
  });

const posts = await Promise.all(
  rawPosts.map(async (post) => {
    const { Content } = await render(post);

    const categoryLabel =
      categoryLabels[post.data.category] ?? post.data.category;

    return {
      ...post,
      Content,
      categoryLabel,
      isoDate: formatISODate(post.data.pubDate),
      displayTags: [categoryLabel, ...post.data.tags.map((tag) => `#${tag}`)],
    };
  }),
);

const usedCategories = categoryOrder
  .filter((category) =>
    rawPosts.some((post) => post.data.category === category),
  )
  .map((category) => ({
    id: category,
    label: categoryLabels[category] ?? category,
  }));

const allTags = [...new Set(rawPosts.flatMap((post) => post.data.tags))].sort();

const latestPosts = rawPosts.slice(0, 4);

const archiveMonths = [
  ...new Map(
    rawPosts.map((post) => {
      const date = post.data.pubDate;
      const key = `${date.getFullYear()}-${String(date.getMonth() + 1).padStart(2, "0")}`;

      const count = rawPosts.filter((item) => {
        const itemDate = item.data.pubDate;

        return (
          itemDate.getFullYear() === date.getFullYear() &&
          itemDate.getMonth() === date.getMonth()
        );
      }).length;

      return [
        key,
        {
          label: date.toLocaleDateString("en-GB", {
            month: "long",
            year: "numeric",
          }),
          count,
        },
      ];
    }),
  ).values(),
];

const latestPublishedPost = [...rawPosts].sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
)[0];

const calendarBaseDate = latestPublishedPost?.data.pubDate ?? new Date();
const calendarYear = calendarBaseDate.getFullYear();
const calendarMonth = calendarBaseDate.getMonth();
---

<Layout
  title="The Blog | Virtual Ventures"
  description="Updates from the Virtual Ventures workshop, including crochet progress, pattern plans, laser engraving notes, 3D printed helpers, shop news, tutorials, videos and behind-the-scenes stories."
  footerBreadcrumbs={[{ label: "Home", href: "/" }, { label: "Blog" }]}
>
  <section class="blog-hero-banner">
    <div class="blog-hero-banner-inner">
      <p class="eyebrow">Workshop Notes</p>
      <h1>The Blog</h1>
      <p>
        Project updates, pattern plans, videos, shop news and behind-the-scenes
        stories from the cosy handmade corner of Virtual Ventures.
      </p>
    </div>
  </section>

  <Breadcrumbs items={[{ label: "Home", href: "/" }, { label: "Blog" }]} />

  <main class="page-shell blog-page">
    <div class="blog-layout has-mobile-side-drawer">
      <button
        class="mobile-side-drawer-toggle"
        type="button"
        aria-label="Open blog tools"
        aria-controls="blog-side-drawer"
        aria-expanded="false"
        data-mobile-side-toggle
      >
        Blog Tools
      </button>

      <button
        class="mobile-side-drawer-backdrop"
        type="button"
        aria-label="Close blog tools"
        hidden
        data-mobile-side-backdrop></button>

      <section class="blog-posts-area" aria-label="Blog posts">
        <div class="blog-grid" data-blog-grid>
          {
            posts.map((post) => (
              <article
                id={`post-${post.id}`}
                class:list={["blog-card", { "is-pinned": post.data.pinned }]}
                data-blog-card
                data-post-id={post.id}
                data-category={post.data.category}
                data-tags={post.data.tags.join(",")}
                data-date={post.isoDate}
              >
                <button class="blog-card-toggle" type="button" data-post-toggle>
                  <span class="blog-card-topline">
                    <span class="blog-date">
                      {post.data.pubDate.toLocaleDateString("en-GB", {
                        day: "numeric",
                        month: "long",
                        year: "numeric",
                      })}
                    </span>

                    <span class="blog-card-top-tags">
                      {post.displayTags.map((tag) => (
                        <span>{tag}</span>
                      ))}
                    </span>
                  </span>

                  <span class="blog-card-title-row">
                    <span class="blog-card-emoji" aria-hidden="true">
                      {post.data.emoji}
                    </span>

                    {post.data.pinned && (
                      <span class="blog-pin-badge">
                        ✦ {post.data.pinLabel || "Pinned"}
                      </span>
                    )}
                  </span>

                  <span class="blog-card-title">{post.data.title}</span>

                  <span class="blog-card-description">
                    {post.data.description}
                  </span>

                  {post.data.images && post.data.images.length > 0 && (
                    <span
                      class="blog-card-preview-thumbs"
                      aria-label="Images in this post"
                    >
                      {post.data.images.slice(0, 3).map((image) => (
                        <span class="blog-card-preview-thumb">
                          <img src={image.src} alt="" loading="lazy" />
                        </span>
                      ))}

                      {post.data.images.length > 3 && (
                        <span class="blog-card-preview-more" aria-hidden="true">
                          +{post.data.images.length - 3}
                        </span>
                      )}
                    </span>
                  )}

                  <span class="blog-read-more" data-read-label>
                    Open post
                  </span>
                </button>

                <div class="blog-card-expanded" hidden data-post-content>
                  {post.data.image && (
                    <img
                      src={post.data.image}
                      alt=""
                      loading="lazy"
                      class="blog-card-image"
                    />
                  )}

                  <div class="blog-post-content blog-post-content-inline">
                    <post.Content />
                  </div>

                  <div class="blog-inline-actions">
                    {post.data.shopUrl && (
                      <a href={post.data.shopUrl} class="featured-shop-link">
                        View in shop
                      </a>
                    )}

                    <a href={`/blog/${post.id}/`} class="blog-full-link">
                      Open standalone post
                    </a>
                  </div>
                </div>
              </article>
            ))
          }
        </div>

        <nav
          class="blog-pagination"
          data-blog-pagination
          aria-label="Blog pagination"
        >
          <button type="button" class="blog-page-button" data-page-prev
            >‹</button
          >

          <div class="blog-page-numbers" data-page-numbers></div>

          <button type="button" class="blog-page-button" data-page-next
            >›</button
          >

          <form class="blog-page-jump" data-page-jump-form>
            <label for="blog-page-jump-input">Go to page</label>
            <input
              id="blog-page-jump-input"
              type="number"
              min="1"
              value="1"
              data-page-jump-input
            />
          </form>
        </nav>

        <p class="blog-empty-message" data-empty-message hidden>
          No posts found for this filter. Try ✨ All Posts.
        </p>
      </section>

      <aside
        id="blog-side-drawer"
        class="blog-sidebar mobile-side-drawer"
        aria-label="Blog sidebar"
        data-mobile-side-drawer
      >
        <section class="blog-widget blog-calendar-widget">
          <h2>Post Calendar</h2>

          <div
            class="blog-calendar"
            data-blog-calendar
            data-calendar-year={calendarYear}
            data-calendar-month={calendarMonth}
          >
            <div class="blog-calendar-header">
              <button
                type="button"
                class="blog-calendar-arrow"
                data-calendar-prev
                aria-label="Previous"
                title="Previous"
              >
                ‹
              </button>

              <button
                type="button"
                class="blog-calendar-title-button"
                data-calendar-title-button
                aria-label="Choose year"
                title="Choose year"
              >
                <span data-calendar-label></span>
              </button>

              <button
                type="button"
                class="blog-calendar-arrow"
                data-calendar-next
                aria-label="Next"
                title="Next"
              >
                ›
              </button>
            </div>

            <div
              class="blog-calendar-view"
              data-calendar-view
              aria-label="Blog calendar"
            >
            </div>

            <button
              type="button"
              class="blog-calendar-clear"
              data-clear-date-filter
              title="Show all dates"
              aria-label="Show all dates"
            >
              Clear Date
            </button>
          </div>
        </section>

        <section class="blog-widget">
          <h2>Filter Topics</h2>

          <div class="blog-filter-stack" data-blog-filters>
            <button
              type="button"
              class="blog-filter-chip is-active"
              data-filter="all"
            >
              ✨ All Posts
            </button>

            {
              usedCategories.map((category, index) => (
                <button
                  type="button"
                  class:list={[
                    "blog-filter-chip",
                    { "is-mobile-extra": index >= 2 },
                  ]}
                  data-filter={category.id}
                >
                  {category.label}
                </button>
              ))
            }

            {
              allTags.map((tag) => (
                <button
                  type="button"
                  class:list={["blog-filter-chip", "is-mobile-extra"]}
                  data-filter={tag}
                >
                  #{tag}
                </button>
              ))
            }

            <button
              type="button"
              class="blog-filter-chip blog-filter-more"
              data-topic-more
              aria-expanded="false"
            >
              More topics
            </button>
          </div>
        </section>

        <section class="blog-widget">
          <h2>Archive</h2>

          <ul class="blog-mini-list">
            {
              archiveMonths.map((month) => (
                <li>
                  <span>
                    <strong>{month.label}</strong>
                    <span>
                      {month.count} post{month.count === 1 ? "" : "s"}
                    </span>
                  </span>
                </li>
              ))
            }
          </ul>
        </section>

        <section class="blog-widget featured-shop-widget">
          <p class="eyebrow">Featured</p>
          <h2>Crochet Planner</h2>
          <p>
            A cosy project planner for crochet and knitting notes, pattern
            ideas, yarn details and creative scribbles.
          </p>
          <a
            href="/shop/project-planner-crochet-knitting/"
            class="featured-shop-link"
          >
            View in shop
          </a>
        </section>

        <section class="blog-widget">
          <h2>Latest Notes</h2>

          <ul class="blog-mini-list">
            {
              latestPosts.map((post) => (
                <li>
                  <button type="button" data-jump-post={post.id}>
                    <strong>{post.data.title}</strong>
                    <span>
                      {post.data.pubDate.toLocaleDateString("en-GB", {
                        day: "numeric",
                        month: "short",
                        year: "numeric",
                      })}
                    </span>
                  </button>
                </li>
              ))
            }
          </ul>
        </section>
      </aside>
    </div>
  </main>

  <script>
    // @ts-nocheck

    const cards = Array.from(document.querySelectorAll("[data-blog-card]"));
    const filterButtons = Array.from(
      document.querySelectorAll("[data-filter]"),
    );
    const jumpButtons = Array.from(
      document.querySelectorAll("[data-jump-post]"),
    );
    const topicMoreButton = document.querySelector("[data-topic-more]");
    const topicExtraButtons = Array.from(
      document.querySelectorAll(".blog-filter-chip.is-mobile-extra"),
    );
    const pagination = document.querySelector("[data-blog-pagination]");
    const pageNumbers = document.querySelector("[data-page-numbers]");
    const prevButton = document.querySelector("[data-page-prev]");
    const nextButton = document.querySelector("[data-page-next]");
    const jumpForm = document.querySelector("[data-page-jump-form]");
    const jumpInput = document.querySelector("[data-page-jump-input]");
    const emptyMessage = document.querySelector("[data-empty-message]");

    const blogCalendar = document.querySelector("[data-blog-calendar]");
    const calendarView = document.querySelector("[data-calendar-view]");
    const calendarLabelElement = document.querySelector(
      "[data-calendar-label]",
    );
    const calendarTitleButton = document.querySelector(
      "[data-calendar-title-button]",
    );
    const calendarPrevButton = document.querySelector("[data-calendar-prev]");
    const calendarNextButton = document.querySelector("[data-calendar-next]");
    const clearDateButton = document.querySelector("[data-clear-date-filter]");

    const mobileSideToggle = document.querySelector(
      "[data-mobile-side-toggle]",
    );
    const mobileSideDrawer = document.querySelector(
      "[data-mobile-side-drawer]",
    );
    const mobileSideBackdrop = document.querySelector(
      "[data-mobile-side-backdrop]",
    );

    const postsPerPage = 8;
    const postDates = new Set(
      cards.map((card) => card.getAttribute("data-date")).filter(Boolean),
    );

    let activeFilter = "all";
    let activeDate = "all";
    let currentPage = 1;

    let calendarMode = "days";
    let visibleCalendarYear =
      blogCalendar instanceof HTMLElement
        ? Number(blogCalendar.dataset.calendarYear)
        : new Date().getFullYear();

    let visibleCalendarMonth =
      blogCalendar instanceof HTMLElement
        ? Number(blogCalendar.dataset.calendarMonth)
        : new Date().getMonth();

    let visibleYearPageStart = visibleCalendarYear - 5;

    function closePost(card) {
      const content = card.querySelector("[data-post-content]");
      const label = card.querySelector("[data-read-label]");

      if (content instanceof HTMLElement) {
        content.hidden = true;
      }

      if (label instanceof HTMLElement) {
        label.textContent = "Open post";
      }

      card.classList.remove("is-open");
    }

    function closeOtherPosts(activeCard) {
      cards.forEach((card) => {
        if (card !== activeCard) closePost(card);
      });
    }

    function cardMatchesFilters(card) {
      const category = card.getAttribute("data-category") || "";
      const date = card.getAttribute("data-date") || "";
      const tags = (card.getAttribute("data-tags") || "")
        .split(",")
        .map((tag) => tag.trim())
        .filter(Boolean);

      const matchesTopic =
        activeFilter === "all" ||
        category === activeFilter ||
        tags.includes(activeFilter);

      const matchesDate = activeDate === "all" || date === activeDate;

      return matchesTopic && matchesDate;
    }

    function getFilteredCards() {
      return cards.filter((card) => cardMatchesFilters(card));
    }

    function renderPagination(totalPages) {
      if (!(pageNumbers instanceof HTMLElement)) return;
      if (!(pagination instanceof HTMLElement)) return;

      pageNumbers.innerHTML = "";
      pagination.hidden = totalPages <= 1;

      for (let page = 1; page <= totalPages; page += 1) {
        const button = document.createElement("button");

        button.type = "button";
        button.className = "blog-page-number";
        button.textContent = String(page);
        button.classList.toggle("is-active", page === currentPage);

        button.addEventListener("click", () => {
          currentPage = page;
          applyBlogView();
        });

        pageNumbers.appendChild(button);
      }

      if (prevButton instanceof HTMLButtonElement) {
        prevButton.disabled = currentPage <= 1;
      }

      if (nextButton instanceof HTMLButtonElement) {
        nextButton.disabled = currentPage >= totalPages;
      }

      if (jumpInput instanceof HTMLInputElement) {
        jumpInput.max = String(totalPages);
        jumpInput.value = String(currentPage);
      }
    }

    function applyBlogView() {
      const filteredCards = getFilteredCards();
      const totalPages = Math.max(
        1,
        Math.ceil(filteredCards.length / postsPerPage),
      );

      currentPage = Math.min(Math.max(currentPage, 1), totalPages);

      cards.forEach((card) => {
        const isFiltered = filteredCards.includes(card);

        card.classList.toggle("is-hidden-by-filter", !isFiltered);
        card.classList.remove("is-page-hidden");

        if (!isFiltered) closePost(card);
      });

      filteredCards.forEach((card, index) => {
        const page = Math.floor(index / postsPerPage) + 1;
        const isOnCurrentPage = page === currentPage;

        card.classList.toggle("is-page-hidden", !isOnCurrentPage);

        if (!isOnCurrentPage) closePost(card);
      });

      if (emptyMessage instanceof HTMLElement) {
        emptyMessage.hidden = filteredCards.length > 0;
      }

      renderPagination(totalPages);
    }

    function formatCalendarIsoDate(year, month, day) {
      return [
        year,
        String(month + 1).padStart(2, "0"),
        String(day).padStart(2, "0"),
      ].join("-");
    }

    function getCalendarMonthLabel(year, month) {
      return new Date(year, month, 1).toLocaleDateString("en-GB", {
        month: "long",
        year: "numeric",
      });
    }

    function setCalendarLabel(text, ariaLabel) {
      if (calendarLabelElement instanceof HTMLElement) {
        calendarLabelElement.textContent = text;
      }

      if (calendarTitleButton instanceof HTMLButtonElement) {
        calendarTitleButton.setAttribute("aria-label", ariaLabel);
        calendarTitleButton.setAttribute("title", ariaLabel);
      }
    }

    function createPickerButton(text, className, onClick, isActive = false) {
      const button = document.createElement("button");

      button.type = "button";
      button.className = className;
      button.textContent = text;
      button.classList.toggle("is-active", isActive);
      button.addEventListener("click", onClick);

      return button;
    }

    function renderDaysCalendar() {
      if (!(calendarView instanceof HTMLElement)) return;

      calendarMode = "days";

      const monthLabel = getCalendarMonthLabel(
        visibleCalendarYear,
        visibleCalendarMonth,
      );

      setCalendarLabel(monthLabel, "Choose year");
      calendarView.className = "blog-calendar-view blog-calendar-grid";
      calendarView.setAttribute("aria-label", `${monthLabel} blog calendar`);
      calendarView.innerHTML = "";

      ["M", "T", "W", "T", "F", "S", "S"].forEach((dayLabel) => {
        const day = document.createElement("span");
        day.className = "blog-calendar-day";
        day.textContent = dayLabel;
        calendarView.appendChild(day);
      });

      const daysInMonth = new Date(
        visibleCalendarYear,
        visibleCalendarMonth + 1,
        0,
      ).getDate();

      const firstDay = new Date(
        visibleCalendarYear,
        visibleCalendarMonth,
        1,
      ).getDay();

      const mondayOffset = firstDay === 0 ? 6 : firstDay - 1;

      for (let index = 0; index < mondayOffset; index += 1) {
        const empty = document.createElement("span");
        empty.className = "blog-calendar-empty";
        calendarView.appendChild(empty);
      }

      for (let day = 1; day <= daysInMonth; day += 1) {
        const isoDate = formatCalendarIsoDate(
          visibleCalendarYear,
          visibleCalendarMonth,
          day,
        );

        const hasPost = postDates.has(isoDate);

        const button = document.createElement("button");
        button.type = "button";
        button.className = "blog-calendar-date";
        button.textContent = String(day);
        button.dataset.calendarDate = isoDate;
        button.disabled = !hasPost;
        button.title = hasPost ? `Show posts from ${isoDate}` : "No posts";
        button.classList.toggle("has-post", hasPost);
        button.classList.toggle("is-active", activeDate === isoDate);

        button.addEventListener("click", () => {
          activeDate = activeDate === isoDate ? "all" : isoDate;
          currentPage = 1;

          renderDaysCalendar();
          applyBlogView();
          closeMobileSideDrawer();
        });

        calendarView.appendChild(button);
      }
    }

    function renderMonthPicker() {
      if (!(calendarView instanceof HTMLElement)) return;

      calendarMode = "months";

      setCalendarLabel(String(visibleCalendarYear), "Choose year");
      calendarView.className =
        "blog-calendar-view blog-calendar-picker-grid blog-calendar-month-grid";
      calendarView.setAttribute(
        "aria-label",
        `Choose month in ${visibleCalendarYear}`,
      );
      calendarView.innerHTML = "";

      Array.from({ length: 12 }, (_, index) => {
        const monthName = new Date(
          visibleCalendarYear,
          index,
          1,
        ).toLocaleDateString("en-GB", {
          month: "short",
        });

        const button = createPickerButton(
          monthName,
          "blog-calendar-picker-button",
          () => {
            visibleCalendarMonth = index;
            renderDaysCalendar();
          },
          index === visibleCalendarMonth,
        );

        calendarView.appendChild(button);
      });
    }

    function renderYearPicker() {
      if (!(calendarView instanceof HTMLElement)) return;

      calendarMode = "years";

      const endYear = visibleYearPageStart + 11;

      setCalendarLabel(
        `${visibleYearPageStart} - ${endYear}`,
        "Choose year range",
      );
      calendarView.className =
        "blog-calendar-view blog-calendar-picker-grid blog-calendar-year-grid";
      calendarView.setAttribute("aria-label", "Choose year");
      calendarView.innerHTML = "";

      Array.from({ length: 12 }, (_, index) => {
        const year = visibleYearPageStart + index;

        const button = createPickerButton(
          String(year),
          "blog-calendar-picker-button",
          () => {
            visibleCalendarYear = year;
            renderMonthPicker();
          },
          year === visibleCalendarYear,
        );

        calendarView.appendChild(button);
      });
    }

    function nudgeCalendarBack() {
      if (calendarMode === "days") {
        visibleCalendarMonth -= 1;

        if (visibleCalendarMonth < 0) {
          visibleCalendarMonth = 11;
          visibleCalendarYear -= 1;
        }

        renderDaysCalendar();
        return;
      }

      if (calendarMode === "months") {
        visibleCalendarYear -= 1;
        renderMonthPicker();
        return;
      }

      visibleYearPageStart -= 12;
      renderYearPicker();
    }

    function nudgeCalendarForward() {
      if (calendarMode === "days") {
        visibleCalendarMonth += 1;

        if (visibleCalendarMonth > 11) {
          visibleCalendarMonth = 0;
          visibleCalendarYear += 1;
        }

        renderDaysCalendar();
        return;
      }

      if (calendarMode === "months") {
        visibleCalendarYear += 1;
        renderMonthPicker();
        return;
      }

      visibleYearPageStart += 12;
      renderYearPicker();
    }

    function openMobileSideDrawer() {
      if (!(mobileSideToggle instanceof HTMLButtonElement)) return;
      if (!(mobileSideDrawer instanceof HTMLElement)) return;
      if (!(mobileSideBackdrop instanceof HTMLElement)) return;

      mobileSideDrawer.classList.add("is-open");
      mobileSideBackdrop.hidden = false;
      document.body.classList.add("has-open-mobile-side-drawer");

      mobileSideToggle.setAttribute("aria-expanded", "true");
      mobileSideToggle.setAttribute("aria-label", "Close blog tools");
      mobileSideToggle.textContent = "Close";
    }

    function closeMobileSideDrawer() {
      if (!(mobileSideToggle instanceof HTMLButtonElement)) return;
      if (!(mobileSideDrawer instanceof HTMLElement)) return;
      if (!(mobileSideBackdrop instanceof HTMLElement)) return;

      mobileSideDrawer.classList.remove("is-open");
      mobileSideBackdrop.hidden = true;
      document.body.classList.remove("has-open-mobile-side-drawer");

      mobileSideToggle.setAttribute("aria-expanded", "false");
      mobileSideToggle.setAttribute("aria-label", "Open blog tools");
      mobileSideToggle.textContent = "Blog Tools";
    }

    cards.forEach((card) => {
      const toggle = card.querySelector("[data-post-toggle]");
      const content = card.querySelector("[data-post-content]");
      const label = card.querySelector("[data-read-label]");

      if (!(toggle instanceof HTMLButtonElement)) return;
      if (!(content instanceof HTMLElement)) return;

      toggle.addEventListener("click", () => {
        const isOpening = content.hidden;

        closeOtherPosts(card);

        content.hidden = !isOpening;
        card.classList.toggle("is-open", isOpening);

        if (label instanceof HTMLElement) {
          label.textContent = isOpening ? "Close post" : "Open post";
        }
      });
    });

    filterButtons.forEach((button) => {
      if (!(button instanceof HTMLButtonElement)) return;

      button.addEventListener("click", () => {
        const selectedFilter = button.dataset.filter || "all";
        const isAlreadyActive = button.classList.contains("is-active");

        activeFilter =
          isAlreadyActive && selectedFilter !== "all" ? "all" : selectedFilter;

        currentPage = 1;

        filterButtons.forEach((filterButton) => {
          if (!(filterButton instanceof HTMLButtonElement)) return;

          filterButton.classList.toggle(
            "is-active",
            filterButton.dataset.filter === activeFilter,
          );
        });

        if (
          !filterButtons.some((filterButton) =>
            filterButton.classList.contains("is-active"),
          )
        ) {
          const allButton = document.querySelector('[data-filter="all"]');
          allButton?.classList.add("is-active");
        }

        applyBlogView();
        closeMobileSideDrawer();
      });
    });

    if (calendarTitleButton instanceof HTMLButtonElement) {
      calendarTitleButton.addEventListener("click", () => {
        if (calendarMode === "days") {
          visibleYearPageStart = visibleCalendarYear - 5;
          renderYearPicker();
          return;
        }

        if (calendarMode === "months") {
          visibleYearPageStart = visibleCalendarYear - 5;
          renderYearPicker();
          return;
        }

        renderDaysCalendar();
      });
    }

    if (calendarPrevButton instanceof HTMLButtonElement) {
      calendarPrevButton.addEventListener("click", nudgeCalendarBack);
    }

    if (calendarNextButton instanceof HTMLButtonElement) {
      calendarNextButton.addEventListener("click", nudgeCalendarForward);
    }

    if (clearDateButton instanceof HTMLButtonElement) {
      clearDateButton.addEventListener("click", () => {
        activeDate = "all";
        currentPage = 1;

        renderDaysCalendar();
        applyBlogView();
      });
    }

    if (topicMoreButton instanceof HTMLButtonElement) {
      topicMoreButton.addEventListener("click", () => {
        const isExpanded =
          topicMoreButton.getAttribute("aria-expanded") === "true";

        topicMoreButton.setAttribute("aria-expanded", String(!isExpanded));
        topicMoreButton.textContent = isExpanded
          ? "More topics"
          : "Less topics";

        topicExtraButtons.forEach((button) => {
          button.classList.toggle("is-mobile-revealed", !isExpanded);
        });
      });
    }

    if (prevButton instanceof HTMLButtonElement) {
      prevButton.addEventListener("click", () => {
        currentPage -= 1;
        applyBlogView();
      });
    }

    if (nextButton instanceof HTMLButtonElement) {
      nextButton.addEventListener("click", () => {
        currentPage += 1;
        applyBlogView();
      });
    }

    if (
      jumpForm instanceof HTMLFormElement &&
      jumpInput instanceof HTMLInputElement
    ) {
      jumpForm.addEventListener("submit", (event) => {
        event.preventDefault();

        const requestedPage = Number(jumpInput.value);

        if (Number.isFinite(requestedPage)) {
          currentPage = requestedPage;
          applyBlogView();
        }
      });

      jumpInput.addEventListener("change", () => {
        const requestedPage = Number(jumpInput.value);

        if (Number.isFinite(requestedPage)) {
          currentPage = requestedPage;
          applyBlogView();
        }
      });
    }

    jumpButtons.forEach((button) => {
      if (!(button instanceof HTMLButtonElement)) return;

      button.addEventListener("click", () => {
        const id = button.dataset.jumpPost;
        if (!id) return;

        const card = document.querySelector(`[data-post-id="${id}"]`);

        if (card instanceof HTMLElement) {
          activeFilter = "all";
          activeDate = "all";
          currentPage = 1;

          filterButtons.forEach((filterButton) => {
            if (!(filterButton instanceof HTMLButtonElement)) return;

            filterButton.classList.toggle(
              "is-active",
              filterButton.dataset.filter === "all",
            );
          });

          renderDaysCalendar();
          applyBlogView();
          closeMobileSideDrawer();

          setTimeout(() => {
            card.scrollIntoView({ behavior: "smooth", block: "center" });
          }, 50);
        }
      });
    });

    if (
      mobileSideToggle instanceof HTMLButtonElement &&
      mobileSideDrawer instanceof HTMLElement &&
      mobileSideBackdrop instanceof HTMLElement
    ) {
      mobileSideToggle.addEventListener("click", () => {
        const isOpen = mobileSideDrawer.classList.contains("is-open");

        if (isOpen) {
          closeMobileSideDrawer();
        } else {
          openMobileSideDrawer();
        }
      });

      mobileSideBackdrop.addEventListener("click", closeMobileSideDrawer);

      document.addEventListener("keydown", (event) => {
        if (event.key === "Escape") closeMobileSideDrawer();
      });
    }

    renderDaysCalendar();
    applyBlogView();
  </script>
</Layout>
