---
import Layout from "../../layouts/Layout.astro";
import Breadcrumbs from "../../components/site/Breadcrumbs.astro";
import { getCollection, render } from "astro:content";
import PageHero from "../../components/page/PageHero.astro";

const categoryLabels: Record<string, string> = {
  crochet: "Crochet",
  laser: "Laser",
  "3d-printing": "3D Printing",
  "books-patterns": "Books / Patterns",
  shop: "Shop",
  website: "Website",
  "behind-the-scenes": "Behind the Scenes",
};

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => !data.draft);

  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const allPosts = (await getCollection("blog"))
  .filter((item) => !item.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const currentIndex = allPosts.findIndex((item) => item.id === post.id);
const previousPost = allPosts[currentIndex + 1];
const nextPost = allPosts[currentIndex - 1];

const categoryLabel = categoryLabels[post.data.category] ?? post.data.category;

const relatedPosts = allPosts
  .filter((item) => item.id !== post.id)
  .filter((item) => {
    const sameCategory = item.data.category === post.data.category;
    const sharedTag = item.data.tags.some((tag) =>
      post.data.tags.includes(tag),
    );

    return sameCategory || sharedTag;
  })
  .slice(0, 3);
---

<Layout
  title={`${post.data.title} | Virtual Ventures`}
  description={post.data.description}
  footerBreadcrumbs={[
    { label: "Home", href: "/" },
    { label: "Blog", href: "/blog/" },
    { label: post.data.title },
  ]}
>
  <PageHero
    eyebrow="Blog Post"
    title={post.data.title}
    description={post.data.description}
  />

  <Breadcrumbs
    items={[
      { label: "Home", href: "/" },
      { label: "Blog", href: "/blog/" },
      { label: post.data.title },
    ]}
  />

  <main class="page-shell blog-post-page">
    <article class="blog-post">
      <a href="/blog/" class="blog-back-link blog-back-link-top">
        ← Back to all blog posts
      </a>

      <header class="blog-post-header">
        <p class="eyebrow">{categoryLabel}</p>

        <div class="blog-post-emoji" aria-hidden="true">
          {post.data.emoji}
        </div>

        <h1>{post.data.title}</h1>

        <p class="blog-post-meta">
          Published {
            post.data.pubDate.toLocaleDateString("en-GB", {
              day: "numeric",
              month: "long",
              year: "numeric",
            })
          }
        </p>

        <p class="blog-post-description">{post.data.description}</p>

        <div class="blog-post-tags">
          <span>{categoryLabel}</span>
          {post.data.tags.map((tag) => <span>#{tag}</span>)}
        </div>
      </header>

      {
        post.data.image && (
          <figure class="blog-post-figure">
            <img
              src={post.data.image}
              alt=""
              loading="lazy"
              class="blog-post-feature-image"
            />
            <figcaption>{post.data.title}</figcaption>
          </figure>
        )
      }

      <div class="blog-post-content">
        <Content />
      </div>

      <nav
        class="blog-post-prev-next"
        aria-label="Previous and next blog posts"
      >
        {
          previousPost ? (
            <a href={`/blog/${previousPost.id}/`} class="blog-prev-next-card">
              <span>← Previous</span>
              <strong>{previousPost.data.title}</strong>
            </a>
          ) : (
            <span />
          )
        }

        {
          nextPost ? (
            <a href={`/blog/${nextPost.id}/`} class="blog-prev-next-card">
              <span>Next →</span>
              <strong>{nextPost.data.title}</strong>
            </a>
          ) : (
            <span />
          )
        }
      </nav>

      {
        relatedPosts.length > 0 && (
          <section class="related-posts">
            <p class="eyebrow">More to explore</p>
            <h2>Related Posts</h2>

            <div class="related-post-grid">
              {relatedPosts.map((relatedPost) => (
                <a href={`/blog/${relatedPost.id}/`} class="related-post-card">
                  <span>
                    {relatedPost.data.pubDate.toLocaleDateString("en-GB", {
                      day: "numeric",
                      month: "short",
                      year: "numeric",
                    })}
                  </span>
                  <strong>{relatedPost.data.title}</strong>
                  <small>{relatedPost.data.description}</small>
                </a>
              ))}
            </div>
          </section>
        )
      }

      <footer class="blog-post-footer-actions">
        <a href="/blog/" class="blog-back-link"> ← Back to all blog posts </a>

        {
          post.data.shopUrl && (
            <a href={post.data.shopUrl} class="featured-shop-link">
              View in shop
            </a>
          )
        }
      </footer>
    </article>
  </main>

  <div class="blog-image-lightbox" data-blog-lightbox hidden>
    <button class="blog-lightbox-close" type="button" aria-label="Close image">
      ×
    </button>

    <button
      class="blog-lightbox-arrow blog-lightbox-prev"
      type="button"
      aria-label="Previous image"
    >
      ‹
    </button>

    <figure class="blog-lightbox-figure">
      <img src="" alt="" data-lightbox-image />
      <figcaption data-lightbox-caption></figcaption>
    </figure>

    <button
      class="blog-lightbox-arrow blog-lightbox-next"
      type="button"
      aria-label="Next image"
    >
      ›
    </button>
  </div>

  <script>
    // @ts-nocheck

    const lightbox = document.querySelector("[data-blog-lightbox]");
    const lightboxImage = document.querySelector("[data-lightbox-image]");
    const lightboxCaption = document.querySelector("[data-lightbox-caption]");
    const closeButton = document.querySelector(".blog-lightbox-close");
    const prevButton = document.querySelector(".blog-lightbox-prev");
    const nextButton = document.querySelector(".blog-lightbox-next");

    const postImages = Array.from(
      document.querySelectorAll(".blog-post-content img"),
    );

    let currentImageIndex = 0;
    let touchStartX = 0;

    function getCaptionForImage(image) {
      const nextElement = image.parentElement?.nextElementSibling;

      if (
        nextElement &&
        nextElement.tagName.toLowerCase() === "p" &&
        nextElement.querySelector("em")
      ) {
        return nextElement.textContent?.trim() ?? "";
      }

      return image.alt ?? "";
    }

    function openLightbox(index) {
      const image = postImages[index];

      if (!lightbox || !lightboxImage || !lightboxCaption || !image) {
        return;
      }

      currentImageIndex = index;

      lightboxImage.src = image.currentSrc || image.src;
      lightboxImage.alt = image.alt || "";
      lightboxCaption.textContent = getCaptionForImage(image);

      lightbox.hidden = false;
      document.body.classList.add("lightbox-open");
    }

    function closeLightbox() {
      if (!lightbox || !lightboxImage) {
        return;
      }

      lightbox.hidden = true;
      lightboxImage.src = "";
      document.body.classList.remove("lightbox-open");
    }

    function showNextImage() {
      if (postImages.length === 0) {
        return;
      }

      openLightbox((currentImageIndex + 1) % postImages.length);
    }

    function showPreviousImage() {
      if (postImages.length === 0) {
        return;
      }

      openLightbox(
        (currentImageIndex - 1 + postImages.length) % postImages.length,
      );
    }

    postImages.forEach((image, index) => {
      image.classList.add("blog-clickable-image");
      image.setAttribute("tabindex", "0");
      image.setAttribute("role", "button");
      image.setAttribute("aria-label", "Open image larger");

      image.addEventListener("click", () => openLightbox(index));

      image.addEventListener("keydown", (event) => {
        if (event.key === "Enter" || event.key === " ") {
          event.preventDefault();
          openLightbox(index);
        }
      });
    });

    closeButton?.addEventListener("click", closeLightbox);
    nextButton?.addEventListener("click", showNextImage);
    prevButton?.addEventListener("click", showPreviousImage);

    lightbox?.addEventListener("click", (event) => {
      if (event.target === lightbox) {
        closeLightbox();
      }
    });

    lightbox?.addEventListener("touchstart", (event) => {
      touchStartX = event.changedTouches[0].screenX;
    });

    lightbox?.addEventListener("touchend", (event) => {
      const touchEndX = event.changedTouches[0].screenX;
      const swipeDistance = touchEndX - touchStartX;

      if (Math.abs(swipeDistance) < 50) {
        return;
      }

      if (swipeDistance < 0) {
        showNextImage();
      } else {
        showPreviousImage();
      }
    });

    document.addEventListener("keydown", (event) => {
      if (!lightbox || lightbox.hidden) {
        return;
      }

      if (event.key === "Escape") {
        closeLightbox();
      }

      if (event.key === "ArrowRight") {
        showNextImage();
      }

      if (event.key === "ArrowLeft") {
        showPreviousImage();
      }
    });
  </script>
</Layout>
