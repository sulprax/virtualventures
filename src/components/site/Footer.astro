---
import { footerNavGroups } from "../../data/navigation";
import { visibleSocials } from "../../data/socials";

const year = new Date().getFullYear();
---

<footer class="site-footer" aria-labelledby="footer-title">
  <div class="footer-inner footer-layout">
    <section class="footer-left">
      <nav class="footer-socials" aria-label="Social media links">
        {
          visibleSocials.map((social) => (
            <a
              href={social.href}
              aria-label={social.label}
              title={social.label}
              target="_blank"
              rel="noopener noreferrer"
            >
              <span aria-hidden="true">{social.icon}</span>
            </a>
          ))
        }
      </nav>

      <nav class="footer-tree" aria-label="Footer navigation">
        {
          footerNavGroups.map((group) => (
            <section class="footer-column">
              <h3>{group.title}</h3>

              <ul>
                {group.links.map((link) => (
                  <li>
                    <a href={link.href}>{link.label}</a>
                  </li>
                ))}
              </ul>
            </section>
          ))
        }
      </nav>

      <div class="footer-actions">
        <div class="footer-action-stack">
          <form
            class="footer-search"
            action="/search/"
            method="get"
            role="search"
          >
            <label for="footer-search">Search</label>

            <div class="footer-form-row">
              <input
                id="footer-search"
                name="q"
                type="search"
                placeholder="Search patterns, blog posts..."
              />

              <button
                class="footer-icon-button"
                type="submit"
                aria-label="Search the site"
                title="Search"
              >
                <svg aria-hidden="true" viewBox="0 0 24 24">
                  <path d="M10.7 5.4a5.3 5.3 0 1 1 0 10.6a5.3 5.3 0 0 1 0-10.6Z"
                  ></path>
                  <path d="M14.8 14.9 19 19"></path>
                </svg>
              </button>
            </div>
          </form>

          <div class="footer-feed-links" aria-label="Blog feed links">
            <div class="footer-form-row footer-rss-row">
              <a
                class="footer-rss-button"
                href="/rss.xml"
                aria-label="RSS feed"
                title="RSS feed"
              >
                <svg aria-hidden="true" viewBox="0 0 24 24">
                  <path d="M5 5c7.7 0 14 6.3 14 14"></path>
                  <path d="M5 10c5 0 9 4 9 9"></path>
                  <path d="M7 18.2a1.2 1.2 0 1 1 0-2.4a1.2 1.2 0 0 1 0 2.4Z"></path>
                </svg>
                <span>RSS</span>
              </a>

              <a
                class="footer-rss-button"
                href="https://feedly.com/i/subscription/feed/https://virtualventures.uk/rss.xml"
                target="_blank"
                rel="noopener noreferrer"
                aria-label="Follow in Feedly"
                title="Follow in Feedly"
              >
                <svg aria-hidden="true" viewBox="0 0 24 24">
                  <path d="M6 4.5a3 3 0 1 0 0 6a3 3 0 0 0 0-6Z"></path>
                  <path d="M5 14a3 3 0 1 0 0 6a3 3 0 0 0 0-6Z"></path>
                  <path d="M13 14a3 3 0 1 0 0 6a3 3 0 0 0 0-6Z"></path>
                </svg>
                <span>Feedly</span>
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="footer-right" aria-labelledby="footer-title">
      <div class="footer-brand-lockup">
        <img
          class="footer-logo"
          src="/images/brand/logo.png"
          alt="Virtual Ventures logo"
          loading="lazy"
        />
        <h2 id="footer-title">Virtual<br />Ventures</h2>
      </div>

      <p class="footer-description">
        Crochet patterns, laser engraved pieces, handmade gifts, blog posts, and
        creative experiments with a warm woodland feel.
      </p>
    </section>
  </div>

  <div class="footer-bottom">
    <p>
      © {year} Virtual Ventures. All designs, photos, patterns, artwork, and original
      content belong to Virtual Ventures unless stated otherwise.
    </p>
  </div>
</footer>

<style>
  .footer-action-stack {
    width: 100%;

    display: grid;
    gap: 0.7rem;
    justify-items: center;
  }

  .footer-action-stack .footer-search,
  .footer-action-stack .footer-feed-links {
    width: min(100%, 24rem) !important;
    margin-inline: auto !important;
  }

  .footer-action-stack .footer-form-row:not(.footer-rss-row) {
    width: 100% !important;
  }

  .footer-action-stack .footer-form-row.footer-rss-row {
    width: min(100%, 18rem) !important;
    margin-inline: auto !important;
  }

  .footer-action-stack .footer-rss-button {
    min-width: 0 !important;
  }
</style>
