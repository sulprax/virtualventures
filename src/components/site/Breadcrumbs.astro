---
type BreadcrumbItem = {
  label: string;
  href?: string;
};

const { items = [] } = Astro.props as {
  items?: BreadcrumbItem[];
};

const crumbItems =
  items.length > 0
    ? items
    : [{ label: "Home", href: "/" }, { label: "Current page" }];
---

<nav class="breadcrumb-trail" aria-label="Breadcrumb">
  <span class="breadcrumb-glow-icon" aria-hidden="true">✦</span>

  {
    crumbItems.map((item, index) => (
      <>
        {item.href ? (
          <a href={item.href} class="breadcrumb-link">
            {item.label}
          </a>
        ) : (
          <strong class="breadcrumb-current" aria-current="page">
            {item.label}
          </strong>
        )}

        {index < crumbItems.length - 1 && (
          <span class="breadcrumb-separator" aria-hidden="true" />
        )}
      </>
    ))
  }
</nav>
