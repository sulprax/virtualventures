---
import { siteNav } from "../../data/navigation";
import { visibleSocials } from "../../data/socials";

const { mode = "sticky" } = Astro.props;
const navItems = siteNav;
const leftNavItems = navItems.slice(0, 3);
const rightNavItems = navItems.slice(3);
const currentPath = Astro.url.pathname;
const isHomeHeader = mode === "home";
const brandLogoSrc = "/images/brand/logo.png?v=7001";

const navIconClasses: Record<string, string> = {
  "/blog/": "site-header-nav-icon-book",
  "/gallery/": "site-header-nav-icon-gallery",
  "/shop/": "site-header-nav-icon-shop",
  "/about/": "site-header-nav-icon-spark",
  "/contact/": "site-header-nav-icon-mail",
  "/faq/": "site-header-nav-icon-help",
};

function isActivePath(href: string) {
  if (href === "/") return currentPath === "/";

  const normalizedHref = href.endsWith("/") ? href : `${href}/`;

  return (
    currentPath === normalizedHref || currentPath.startsWith(normalizedHref)
  );
}
---

<header class:list={["site-header", `site-header-${mode}`]} data-site-header>
  <a class="site-header-mobile-brand" href="/" aria-label="Virtual Ventures home">
    <img class="site-header-brand-logo" src={brandLogoSrc} alt="" />

    <span class="site-header-brand-text">
      <span>Virtual</span>
      <span class="site-header-brand-line-two">Ventures</span>
    </span>
  </a>

  {
    isHomeHeader && (
      <div class="site-header-home-socials site-header-mobile-socials" aria-label="Social links">
        {visibleSocials.map((social) => (
          <a
            href={social.href}
            aria-label={social.label}
            target="_blank"
            rel="noopener noreferrer"
          >
            {social.icon}
          </a>
        ))}
      </div>
    )
  }

  <a class="site-header-desktop-brand" href="/" aria-label="Virtual Ventures home">
    <img class="site-header-brand-logo" src={brandLogoSrc} alt="" />

    <span class="site-header-brand-text">
      <span>Virtual</span>
      <span class="site-header-brand-line-two">Ventures</span>
    </span>
  </a>

  <nav class="site-header-nav" aria-label="Main navigation">
    {
      leftNavItems.map((item) => (
        <a
          class:list={[
            "site-header-nav-link",
            { "is-active": isActivePath(item.href) },
          ]}
          href={item.href}
          aria-current={isActivePath(item.href) ? "page" : undefined}
        >
          <span class="site-header-nav-label">{item.label}</span>
          <span
            class:list={[
              "site-header-nav-icon",
              navIconClasses[item.href] ?? "site-header-nav-icon-spark",
            ]}
            aria-hidden="true"
          ></span>
        </a>
      ))
    }

    {
      isHomeHeader ? (
        <div class="site-header-social-tab" aria-label="Social links">
          <span class="site-header-social-kicker">Follow</span>
          <span class="site-header-home-socials site-header-social-icons">
            {visibleSocials.map((social) => (
              <a
                href={social.href}
                aria-label={social.label}
                target="_blank"
                rel="noopener noreferrer"
              >
                {social.icon}
              </a>
            ))}
          </span>
        </div>
      ) : (
        <a
          class:list={[
            "site-header-home-tab",
            { "is-active": currentPath === "/" },
          ]}
          href="/"
          aria-label="Virtual Ventures home"
          aria-current={currentPath === "/" ? "page" : undefined}
        >
          <img class="site-header-home-tab-logo" src={brandLogoSrc} alt="" />
          <span class="site-header-home-tab-text">
            <span>Virtual</span>
            <span>Ventures</span>
            <span class="site-header-home-tab-star" aria-hidden="true">✦</span>
          </span>
        </a>
      )
    }

    {
      rightNavItems.map((item) => (
        <a
          class:list={[
            "site-header-nav-link",
            { "is-active": isActivePath(item.href) },
          ]}
          href={item.href}
          aria-current={isActivePath(item.href) ? "page" : undefined}
        >
          <span class="site-header-nav-label">{item.label}</span>
          <span
            class:list={[
              "site-header-nav-icon",
              navIconClasses[item.href] ?? "site-header-nav-icon-spark",
            ]}
            aria-hidden="true"
          ></span>
        </a>
      ))
    }
  </nav>

  <form class="site-header-search" action="/search/" method="get" role="search">
    <label for="site-header-search-input">Search the site</label>
    <input
      id="site-header-search-input"
      type="search"
      name="q"
      placeholder="Search..."
    />
    <button type="submit" aria-label="Search">⌕</button>
  </form>

  <button
    class="site-header-menu-button"
    type="button"
    aria-label="Open menu"
    aria-controls="site-header-nav-drawer"
    aria-expanded="false"
    data-site-menu-toggle
  >
    <span class="site-header-menu-icon" aria-hidden="true">
      <span></span>
      <span></span>
      <span></span>
    </span>
  </button>

  <div
    id="site-header-nav-drawer"
    class="site-header-nav-drawer"
    hidden
    data-site-menu-drawer
  >
    <nav aria-label="Mobile navigation">
      {
        navItems.map((item) => (
          <a
            href={item.href}
            class:list={[{ "is-active": isActivePath(item.href) }]}
            aria-current={isActivePath(item.href) ? "page" : undefined}
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <form
      class="site-header-drawer-search"
      action="/search/"
      method="get"
      role="search"
    >
      <label for="site-header-drawer-search-input">Search the site</label>
      <input
        id="site-header-drawer-search-input"
        type="search"
        name="q"
        placeholder="Search..."
      />
      <button type="submit" aria-label="Search">⌕</button>
    </form>
  </div>
</header>

<script>
  const siteMenuToggle = document.querySelector("[data-site-menu-toggle]");
  const siteMenuDrawer = document.querySelector("[data-site-menu-drawer]");
  let siteMenuCloseTimer;

  function closeSiteMenu() {
    if (!(siteMenuToggle instanceof HTMLButtonElement)) return;
    if (!(siteMenuDrawer instanceof HTMLElement)) return;

    window.clearTimeout(siteMenuCloseTimer);

    siteMenuDrawer.classList.remove("is-open");
    siteMenuDrawer.classList.add("is-closing");

    siteMenuToggle.classList.remove("is-menu-open");
    siteMenuToggle.setAttribute("aria-expanded", "false");
    siteMenuToggle.setAttribute("aria-label", "Open menu");

    siteMenuCloseTimer = window.setTimeout(() => {
      siteMenuDrawer.hidden = true;
      siteMenuDrawer.classList.remove("is-closing");
    }, 260);
  }

  function openSiteMenu() {
    if (!(siteMenuToggle instanceof HTMLButtonElement)) return;
    if (!(siteMenuDrawer instanceof HTMLElement)) return;

    window.clearTimeout(siteMenuCloseTimer);

    siteMenuDrawer.hidden = false;
    siteMenuDrawer.classList.remove("is-closing");

    requestAnimationFrame(() => {
      siteMenuDrawer.classList.add("is-open");
    });

    siteMenuToggle.classList.add("is-menu-open");
    siteMenuToggle.setAttribute("aria-expanded", "true");
    siteMenuToggle.setAttribute("aria-label", "Close menu");
  }

  if (
    siteMenuToggle instanceof HTMLButtonElement &&
    siteMenuDrawer instanceof HTMLElement
  ) {
    siteMenuDrawer.hidden = true;
    siteMenuDrawer.classList.remove("is-open", "is-closing");
    siteMenuToggle.classList.remove("is-menu-open");

    siteMenuToggle.addEventListener("click", () => {
      const isOpen =
        !siteMenuDrawer.hidden || siteMenuDrawer.classList.contains("is-open");

      if (isOpen) {
        closeSiteMenu();
      } else {
        openSiteMenu();
      }
    });

    siteMenuDrawer.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", closeSiteMenu);
    });

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape") {
        closeSiteMenu();
      }
    });
  }
</script>
