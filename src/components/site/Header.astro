---
import { mainNav, heroNav } from "../../data/navigation";

const { mode = "sticky" } = Astro.props;
const navItems = [...mainNav, ...heroNav];
const currentPath = Astro.url.pathname;

function isActivePath(href: string) {
  if (href === "/") return currentPath === "/";

  const normalizedHref = href.endsWith("/") ? href : `${href}/`;

  return currentPath === normalizedHref || currentPath.startsWith(normalizedHref);
}
---

<header class:list={["site-header", `site-header-${mode}`]} data-site-header>
  <a class="site-header-brand" href="/" aria-label="Virtual Ventures home">
    <img src="/images/brand/logo.png" alt="" />
    <span>Virtual Ventures</span>
  </a>

  <nav class="site-header-nav" aria-label="Main navigation">
    {navItems.map((item, index) => (
      <>
        <a
          href={item.href}
          class:list={[{ "is-active": isActivePath(item.href) }]}
          aria-current={isActivePath(item.href) ? "page" : undefined}
        >
          {item.label}
        </a>

        {index < navItems.length - 1 && (
          <span class="site-header-star" aria-hidden="true">✦</span>
        )}
      </>
    ))}
  </nav>

  <form class="site-header-search" action="/search/" method="get" role="search">
    <label for="site-header-search-input">Search the site</label>
    <input
      id="site-header-search-input"
      type="search"
      name="q"
      placeholder="Search..."
    />
    <button type="submit" aria-label="Search">⌕</button>
  </form>

  <button
    class="site-header-menu-button"
    type="button"
    aria-label="Open menu"
    aria-controls="site-header-nav-drawer"
    aria-expanded="false"
    data-site-menu-toggle
  >
    ☰
  </button>

  <div
    id="site-header-nav-drawer"
    class="site-header-nav-drawer"
    hidden
    data-site-menu-drawer
  >
    <nav aria-label="Mobile navigation">
      {navItems.map((item) => (
        <a
          href={item.href}
          class:list={[{ "is-active": isActivePath(item.href) }]}
          aria-current={isActivePath(item.href) ? "page" : undefined}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <form class="site-header-drawer-search" action="/search/" method="get" role="search">
      <label for="site-header-drawer-search-input">Search the site</label>
      <input
        id="site-header-drawer-search-input"
        type="search"
        name="q"
        placeholder="Search..."
      />
      <button type="submit" aria-label="Search">⌕</button>
    </form>
  </div>
</header>

<script>
  const siteMenuToggle = document.querySelector("[data-site-menu-toggle]");
  const siteMenuDrawer = document.querySelector("[data-site-menu-drawer]");

  if (
    siteMenuToggle instanceof HTMLButtonElement &&
    siteMenuDrawer instanceof HTMLElement
  ) {
    siteMenuToggle.addEventListener("click", () => {
      const isOpen = siteMenuDrawer.hidden;

      siteMenuDrawer.hidden = !isOpen;
      siteMenuToggle.setAttribute("aria-expanded", String(isOpen));
      siteMenuToggle.setAttribute("aria-label", isOpen ? "Close menu" : "Open menu");
    });
  }
</script>