---
import Layout from "../../layouts/Layout.astro";
import PageHero from "./PageHero.astro";

interface Props {
  title: string;
  eyebrow: string;
  description: string;
  introEyebrow: string;
  introTitle: string;
  introText: string;
}

const { title, eyebrow, description, introEyebrow, introTitle, introText } = Astro.props;
const pageTitle = `${title} | Virtual Ventures`;
---

<Layout title={pageTitle} description={description} showFooterBreadcrumbs={false}>
  <PageHero eyebrow={eyebrow} title={title} description={description} />

  <main class="page-shell">
    <section class="page-intro">
      <p class="eyebrow">{introEyebrow}</p>
      <h1>{introTitle}</h1>
      <p>{introText}</p>
    </section>
  </main>
</Layout>
