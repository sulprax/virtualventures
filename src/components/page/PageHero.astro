---
import CoverSlideshow from "../site/CoverSlideshow.astro";
import { getCoverMedia } from "../../lib/getCoverMedia";

interface Props {
  eyebrow: string;
  title: string;
  description: string;
}

const { eyebrow, title, description } = Astro.props;
const coverSlides = await getCoverMedia();

const iconSource = `${eyebrow} ${title}`.toLowerCase();
const iconMatches = [
  ["blog", "page-hero-mini-icon--blog"],
  ["gallery", "page-hero-mini-icon--gallery"],
  ["shop", "page-hero-mini-icon--shop"],
  ["contact", "page-hero-mini-icon--contact"],
  ["f.a.q", "page-hero-mini-icon--faq"],
  ["faq", "page-hero-mini-icon--faq"],
  ["about", "page-hero-mini-icon--about"],
  ["crochet", "page-hero-mini-icon--crochet"],
  ["laser", "page-hero-mini-icon--laser"],
  ["3d", "page-hero-mini-icon--printing"],
  ["printing", "page-hero-mini-icon--printing"],
  ["pattern", "page-hero-mini-icon--patterns"],
] as const;

const pageHeroIconClass =
  iconMatches.find(([keyword]) => iconSource.includes(keyword))?.[1] ??
  "page-hero-mini-icon--default";
---

<section class="blog-hero-banner page-hero-banner" data-compact-header-trigger>
  <CoverSlideshow slides={coverSlides} variant="page" />

  <div class="blog-hero-banner-inner">
    <div class="page-hero-title-row">
      <i class:list={["page-hero-mini-icon", pageHeroIconClass]} aria-hidden="true"></i>
      <h1>{title}</h1>
    </div>

    <hr class="page-hero-card-rule" aria-hidden="true" />

    <h2 class="eyebrow">{eyebrow}</h2>
    <h3>{description}</h3>
  </div>
</section>
