---
import CoverSlideshow from "../site/CoverSlideshow.astro";
import { getCoverMedia } from "../../lib/getCoverMedia";

interface Props {
  eyebrow: string;
  title: string;
  description: string;
}

const { eyebrow, title, description } = Astro.props;
const coverSlides = await getCoverMedia();

const iconSource = `${eyebrow} ${title}`.toLowerCase();

const pageHeroIconClass = iconSource.includes("blog")
  ? "page-hero-mini-icon--blog"
  : iconSource.includes("gallery")
    ? "page-hero-mini-icon--gallery"
    : iconSource.includes("shop")
      ? "page-hero-mini-icon--shop"
      : iconSource.includes("contact")
        ? "page-hero-mini-icon--contact"
        : iconSource.includes("f.a.q") || iconSource.includes("faq")
          ? "page-hero-mini-icon--faq"
          : iconSource.includes("about")
            ? "page-hero-mini-icon--about"
            : iconSource.includes("crochet")
              ? "page-hero-mini-icon--crochet"
              : iconSource.includes("laser")
                ? "page-hero-mini-icon--laser"
                : iconSource.includes("3d") || iconSource.includes("printing")
                  ? "page-hero-mini-icon--printing"
                  : iconSource.includes("pattern")
                    ? "page-hero-mini-icon--patterns"
                    : "page-hero-mini-icon--default";
---

<section class="blog-hero-banner page-hero-banner" data-compact-header-trigger>
  <CoverSlideshow slides={coverSlides} variant="page" />

  <div class="blog-hero-banner-inner">
    <div class="page-hero-title-row">
      <i class:list={["page-hero-mini-icon", pageHeroIconClass]} aria-hidden="true"></i>
      <h1>{title}</h1>
    </div>

    <hr class="page-hero-card-rule" aria-hidden="true" />

    <h2 class="eyebrow">{eyebrow}</h2>
    <h3>{description}</h3>
  </div>
</section>
