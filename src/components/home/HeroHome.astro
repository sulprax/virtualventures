---
import { mainNav } from "../../data/navigation";
import { visibleSocials } from "../../data/socials";
---

<section class="hero">
  <div class="hero-top-fade" aria-hidden="true"></div>
  <div class="hero-bottom-fade" aria-hidden="true"></div>

  <header class="hero-topbar">
    <nav class="hero-socials" aria-label="Social links">
      {visibleSocials.map((social) => (
        <a
          href={social.href}
          aria-label={social.label}
          title={social.label}
          target="_blank"
          rel="noopener noreferrer"
        >
          <span aria-hidden="true">{social.icon}</span>
        </a>
      ))}
    </nav>

    <nav
      id="hero-navigation"
      class="hero-menu"
      aria-label="Main navigation"
      data-hero-menu
    >
      <div class="hero-menu-links">
        {mainNav.map((item) => (
          <a href={item.href}>{item.label}</a>
        ))}
      </div>

      <form class="hero-search" action="/search/" method="get" role="search">
        <label class="sr-only" for="hero-search">Search the site</label>
        <input id="hero-search" name="q" type="search" placeholder="Search..." />
        <button type="submit" aria-label="Search">⌕</button>
      </form>
    </nav>

    <button
      class="mobile-menu"
      type="button"
      aria-label="Open menu"
      aria-controls="hero-navigation"
      aria-expanded="false"
      data-mobile-menu
    >
      ☰
    </button>
  </header>

  <div class="hero-panel">
    <div class="hero-logo-wrap">
      <img
        src="/images/brand/logo.png"
        alt="Virtual Ventures logo"
        class="hero-logo"
        width="1536"
        height="1024"
        loading="eager"
        decoding="async"
      />
    </div>

    <h1>Virtual Ventures</h1>
    <h2>Handmade with a little everyday magic</h2>

    <div class="hero-divider" aria-hidden="true">
      <span></span>
      <strong>✦</strong>
      <span></span>
    </div>

    <p>
      A cozy craft workshop for crochet creatures, fantasy-inspired makes,
      laser engraved details, 3D printed helpers, patterns, stories, and small
      handmade treasures.
    </p>
  </div>

  <nav class="hero-buttons" aria-label="Featured homepage links">
    <a href="/blog/">
      <span class="button-icon" aria-hidden="true">
        <svg viewBox="0 0 24 24">
          <path d="M4 5.5C4 4.7 4.7 4 5.5 4H10c1.1 0 2 .9 2 2v14c0-1.1-.9-2-2-2H5.5C4.7 18 4 17.3 4 16.5v-11Z"></path>
          <path d="M20 5.5C20 4.7 19.3 4 18.5 4H14c-1.1 0-2 .9-2 2v14c0-1.1.9-2 2-2h4.5c.8 0 1.5-.7 1.5-1.5v-11Z"></path>
        </svg>
      </span>
      <span>Blog</span>
    </a>

    <a href="/gallery/">
      <span class="button-icon" aria-hidden="true">
        <svg viewBox="0 0 24 24">
          <rect x="4" y="5" width="16" height="14" rx="2"></rect>
          <circle cx="9" cy="10" r="1.5"></circle>
          <path d="M7 17l4.2-4.2 2.5 2.5L16 13l3 4"></path>
        </svg>
      </span>
      <span>Gallery</span>
    </a>

    <a href="/shop/">
      <span class="button-icon" aria-hidden="true">
        <svg viewBox="0 0 24 24">
          <path d="M6 8h12l-1 12H7L6 8Z"></path>
          <path d="M9 8V6a3 3 0 0 1 6 0v2"></path>
        </svg>
      </span>
      <span>Shop</span>
    </a>
  </nav>
</section>

<script>
  const mobileMenuButton = document.querySelector("[data-mobile-menu]");
  const heroNavigation = document.querySelector("[data-hero-menu]");

  if (
    mobileMenuButton instanceof HTMLButtonElement &&
    heroNavigation instanceof HTMLElement
  ) {
    mobileMenuButton.addEventListener("click", () => {
      const isOpen = heroNavigation.classList.toggle("is-open");

      mobileMenuButton.setAttribute("aria-expanded", String(isOpen));
      mobileMenuButton.setAttribute("aria-label", isOpen ? "Close menu" : "Open menu");
    });

    heroNavigation.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", () => {
        heroNavigation.classList.remove("is-open");
        mobileMenuButton.setAttribute("aria-expanded", "false");
        mobileMenuButton.setAttribute("aria-label", "Open menu");
      });
    });
  }
</script>