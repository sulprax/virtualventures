---
import CoverSlideshow from "../site/CoverSlideshow.astro";
import { getCoverMedia } from "../../lib/getCoverMedia";
import "../../styles/pages/home.css";

const coverSlides = await getCoverMedia();
const brandLogoSrc = "/images/brand/logo.png?v=9000";

const heroCopySlides = coverSlides
  .map((slide) => {
    const item = slide as any;

    const tag = item.category || item.type || item.eyebrow || "Featured";
    const title = item.title || item.name || item.alt || "";
    const description =
      item.description || item.summary || item.caption || item.alt || "";
    const href = item.href || item.url || item.link || item.postHref || "";

    return {
      tag,
      title,
      description,
      href,
    };
  })
  .filter((slide) => slide.title || slide.description);
---

<section class="hero" aria-labelledby="home-title" data-compact-header-trigger>
  <CoverSlideshow slides={coverSlides} variant="home" />

  <div class="hero-shade" aria-hidden="true"></div>

  <div class="hero-content">
    <article class="hero-panel" aria-label="Virtual Ventures introduction">
      <div class="hero-logo-wrap" aria-hidden="true">
        <img
          src={brandLogoSrc}
          alt=""
          class="hero-logo"
          width="1536"
          height="1024"
          loading="eager"
          decoding="async"
        />
      </div>

      <svg
        class="hero-mobile-curve-brand"
        viewBox="0 0 560 190"
        aria-hidden="true"
        preserveAspectRatio="xMidYMid meet"
      >
        <defs>
          <path
            id="hero-mobile-brand-arc"
            d="M 38 142 C 150 20, 410 20, 522 142"></path>
        </defs>

        <text>
          <textPath
            href="#hero-mobile-brand-arc"
            startOffset="50%"
            text-anchor="middle"
            textLength="500"
            lengthAdjust="spacingAndGlyphs"
          >
            Virtual Ventures
          </textPath>
        </text>
      </svg>

      <h1 id="home-title">Virtual Ventures</h1>

      <p class="hero-kicker">
        Handmade with a<br />little everyday magic
      </p>

      <div class="hero-divider" aria-hidden="true">
        <span></span>
        <strong>✦</strong>
        <span></span>
      </div>

      <p class="hero-intro">
        Crochet creatures, pattern books, laser engraved details, 3D printed
        helpers, shop notes and cosy handmade experiments.
      </p>
    </article>
  </div>

  <span class="hero-mobile-star hero-mobile-star-top" aria-hidden="true">✦</span
  >
  <span class="hero-mobile-star hero-mobile-star-bottom" aria-hidden="true"
    >✦</span
  >

  <aside class="hero-slide-copy" aria-label="Featured slide details">
    {
      heroCopySlides.map((slide, index) => (
        <article
          class:list={["hero-slide-copy-card", { "is-active": index === 0 }]}
          data-hero-slide-copy
        >
          <p class="hero-slide-copy-tag">{slide.tag}</p>
          <h2>{slide.title}</h2>
          {slide.description && (
            <p class="hero-slide-copy-description">{slide.description}</p>
          )}
          {slide.href && (
            <a class="hero-slide-copy-link" href={slide.href}>
              Read the blog ✦
            </a>
          )}
        </article>
      ))
    }
  </aside>

  <nav class="hero-buttons" aria-label="Featured homepage links">
    <a href="/blog/">
      <span aria-hidden="true">▯</span>
      Blog
    </a>
    <a href="/gallery/">
      <span aria-hidden="true">▧</span>
      Gallery
    </a>
    <a href="/shop/">
      <span aria-hidden="true">▱</span>
      Shop
    </a>
  </nav>
</section>
