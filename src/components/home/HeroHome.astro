---
import CoverSlideshow from "../site/CoverSlideshow.astro";
import { getCoverMedia } from "../../lib/getCoverMedia";
import "../../styles/pages/home.css";

const coverSlides = await getCoverMedia();

const heroCopySlides = coverSlides
  .map((slide) => {
    const item = slide as any;

    const tag = item.category || item.type || item.eyebrow || "Featured";
    const title = item.title || item.name || item.alt || "";
    const description =
      item.description || item.summary || item.caption || item.alt || "";
    const href = item.href || item.url || item.link || item.postHref || "";

    return {
      tag,
      title,
      description,
      href,
    };
  })
  .filter((slide) => slide.title || slide.description);
---

<section class="hero" aria-labelledby="home-title">
  <CoverSlideshow slides={coverSlides} variant="home" />

  <div class="hero-shade" aria-hidden="true"></div>

  <div class="hero-content">
    <article class="hero-panel" aria-label="Virtual Ventures introduction">
      <div class="hero-logo-wrap" aria-hidden="true">
        <img
          src="/images/brand/logo.png"
          alt=""
          class="hero-logo"
          width="1536"
          height="1024"
          loading="eager"
          decoding="async"
        />
      </div>

      <svg
        class="hero-mobile-curve-brand"
        viewBox="0 0 560 190"
        aria-hidden="true"
        preserveAspectRatio="xMidYMid meet"
      >
        <defs>
          <path
            id="hero-mobile-brand-arc"
            d="M 38 142 C 150 20, 410 20, 522 142"></path>
        </defs>

        <text>
          <textPath
            href="#hero-mobile-brand-arc"
            startOffset="50%"
            text-anchor="middle"
            textLength="500"
            lengthAdjust="spacingAndGlyphs"
          >
            Virtual Ventures
          </textPath>
        </text>
      </svg>

      <h1 id="home-title">Virtual Ventures</h1>

      <p class="hero-kicker">
        Handmade with a<br />little everyday magic
      </p>

      <div class="hero-divider" aria-hidden="true">
        <span></span>
        <strong>✦</strong>
        <span></span>
      </div>

      <p class="hero-intro">
        Crochet creatures, pattern books, laser engraved details, 3D printed
        helpers, shop notes and cosy handmade experiments.
      </p>
    </article>
  </div>

  <span class="hero-mobile-star hero-mobile-star-top" aria-hidden="true">✦</span
  >
  <span class="hero-mobile-star hero-mobile-star-bottom" aria-hidden="true"
    >✦</span
  >

  <aside class="hero-slide-copy" aria-label="Featured slide details">
    {
      heroCopySlides.map((slide, index) => (
        <article
          class:list={["hero-slide-copy-card", { "is-active": index === 0 }]}
          data-hero-slide-copy
        >
          <p class="hero-slide-copy-tag">{slide.tag}</p>
          <h2>{slide.title}</h2>
          {slide.description && (
            <p class="hero-slide-copy-description">{slide.description}</p>
          )}
          {slide.href && (
            <a class="hero-slide-copy-link" href={slide.href}>
              Read the blog ✦
            </a>
          )}
        </article>
      ))
    }
  </aside>

  <nav class="hero-buttons" aria-label="Featured homepage links">
    <a href="/blog/">
      <span class="button-icon" aria-hidden="true">
        <svg viewBox="0 0 24 24">
          <path
            d="M4 5.5C4 4.7 4.7 4 5.5 4H10c1.1 0 2 .9 2 2v14c0-1.1-.9-2-2-2H5.5C4.7 18 4 17.3 4 16.5v-11Z"
          ></path>
          <path
            d="M20 5.5C20 4.7 19.3 4 18.5 4H14c-1.1 0-2 .9-2 2v14c0-1.1.9-2 2-2h4.5c.8 0 1.5-.7 1.5-1.5v-11Z"
          ></path>
        </svg>
      </span>
      <span>Blog</span>
    </a>

    <a href="/gallery/">
      <span class="button-icon" aria-hidden="true">
        <svg viewBox="0 0 24 24">
          <rect x="4" y="5" width="16" height="14" rx="2"></rect>
          <circle cx="9" cy="10" r="1.5"></circle>
          <path d="M7 17l4.2-4.2 2.5 2.5L16 13l3 4"></path>
        </svg>
      </span>
      <span>Gallery</span>
    </a>

    <a href="/shop/">
      <span class="button-icon" aria-hidden="true">
        <svg viewBox="0 0 24 24">
          <path d="M6 8h12l-1 12H7L6 8Z"></path>
          <path d="M9 8V6a3 3 0 0 1 6 0v2"></path>
        </svg>
      </span>
      <span>Shop</span>
    </a>
  </nav>

  <script>
    function syncHeroSlideCopy() {
      const slides = Array.from(
        document.querySelectorAll(".cover-slideshow__slide"),
      );
      const copySlides = Array.from(
        document.querySelectorAll("[data-hero-slide-copy]"),
      );

      if (!slides.length || !copySlides.length) return;

      const activeIndex = Math.max(
        0,
        slides.findIndex((slide) => slide.classList.contains("is-active")),
      );

      copySlides.forEach((slide, index) => {
        if (!(slide instanceof HTMLElement)) return;
        slide.classList.toggle("is-active", index === activeIndex);
      });
    }

    document.addEventListener("DOMContentLoaded", () => {
      syncHeroSlideCopy();

      const slideshow = document.querySelector(".cover-slideshow");
      if (slideshow) {
        new MutationObserver(syncHeroSlideCopy).observe(slideshow, {
          attributes: true,
          childList: true,
          subtree: true,
        });
      }

      window.setInterval(syncHeroSlideCopy, 750);
    });
  </script>
</section>
